---
import EntityLinks from '../components/EntityLinks.astro';
import { url } from '../utils/url';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  // Path under /public for the social preview image, overridable per page.
  ogImage?: string;
}

const {
  title,
  description = 'A chronicle of our Dragon of Icespire Peak campaign.',
  ogImage = '/images/social-card.jpg',
} = Astro.props;

const fullTitle = `${title} · Dragon of Icespire Peak`;
// Astro.url.pathname already includes the configured base at build time.
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const ogImageUrl = new URL(url(ogImage), Astro.site);

// The nav is grouped so the top bar stays short: Home stands alone, and the
// rest fall under "The Story" (the campaign as it unfolds) or "The World"
// (the reference atlas of people, places, and powers).
interface NavItem {
  href: string;
  label: string;
  match: string[];
}
interface NavGroup {
  label: string;
  items: NavItem[];
}
const homeItem: NavItem = { href: '/', label: 'Home', match: [] };
const navGroups: NavGroup[] = [
  {
    label: 'The Story',
    items: [
      { href: '/sessions/', label: 'Recaps', match: ['/sessions/'] },
      { href: '/timeline/', label: 'Timeline', match: ['/timeline/'] },
      { href: '/campaign/', label: 'Campaign', match: ['/campaign/'] },
    ],
  },
  {
    label: 'The World',
    items: [
      { href: '/map/', label: 'Map', match: ['/map/'] },
      { href: '/characters/', label: 'Roster', match: ['/characters/'] },
      { href: '/npcs/', label: 'NPCs', match: ['/npcs/'] },
      { href: '/graph/', label: 'Relations', match: ['/graph/'] },
      { href: '/codex/', label: 'Codex', match: ['/codex/', '/factions/', '/lore/'] },
    ],
  },
];
// Flat list for the footer, where there's room to show every page at once.
const allItems: NavItem[] = [homeItem, ...navGroups.flatMap((g) => g.items)];

const currentPath = Astro.url.pathname;
const isActive = (item: NavItem) =>
  item.href === '/'
    ? currentPath.replace(/\/$/, '') === url('/').replace(/\/$/, '')
    : item.match.some((prefix) => currentPath.startsWith(url(prefix)));
const groupActive = (group: NavGroup) => group.items.some(isActive);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{fullTitle}</title>
    <link rel="icon" href={url('/favicon.svg')} type="image/svg+xml" />
    <link rel="icon" href={url('/favicon-96.png')} type="image/png" sizes="96x96" />
    <link rel="apple-touch-icon" href={url('/apple-touch-icon.png')} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:site_name" content="Dragon of Icespire Peak" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <script is:inline>
      // Apply saved theme before first paint to avoid a flash. Dark
      // ("Night in the Wilds") is the default; light is "Snowfield".
      if (localStorage.getItem('icespire-theme') === 'light') {
        document.documentElement.setAttribute('data-theme', 'light');
      }
    </script>
  </head>
  <body>
    <header class="site-header">
      <a class="site-title" href={url('/')}>Dragon of <span class="gold">Icespire Peak</span></a>
      <nav class="site-nav" aria-label="Primary">
        <a href={url(homeItem.href)} aria-current={isActive(homeItem) ? 'page' : undefined}>
          {homeItem.label}
        </a>
        {
          navGroups.map((group) => (
            <div class="nav-group" data-nav-group>
              <button
                type="button"
                class="nav-trigger"
                aria-haspopup="true"
                aria-expanded="false"
                aria-current={groupActive(group) ? 'page' : undefined}
              >
                {group.label}
                <span class="nav-caret" aria-hidden="true">▾</span>
              </button>
              <div class="nav-menu" role="menu">
                {group.items.map((item) => (
                  <a
                    href={url(item.href)}
                    role="menuitem"
                    aria-current={isActive(item) ? 'page' : undefined}
                  >
                    {item.label}
                  </a>
                ))}
              </div>
            </div>
          ))
        }
      </nav>
      <button class="theme-toggle" id="theme-toggle" type="button">Snowfield</button>
    </header>
    <main class="page">
      <slot />
    </main>
    <footer class="site-footer">
      <nav class="footer-nav">
        {allItems.map((item) => <a href={url(item.href)}>{item.label}</a>)}
      </nav>
      A chronicle kept by the party. Updated between sessions.
    </footer>
    <EntityLinks />
    <script is:inline>
      (() => {
        const root = document.documentElement;
        const button = document.getElementById('theme-toggle');
        // The button names the theme it switches TO.
        const label = () =>
          root.getAttribute('data-theme') === 'light' ? 'Night in the Wilds' : 'Snowfield';
        button.textContent = label();
        button.addEventListener('click', () => {
          const toLight = root.getAttribute('data-theme') !== 'light';
          if (toLight) {
            root.setAttribute('data-theme', 'light');
          } else {
            root.removeAttribute('data-theme');
          }
          localStorage.setItem('icespire-theme', toLight ? 'light' : 'dark');
          button.textContent = label();
        });
      })();
    </script>
    <script is:inline>
      // Grouped nav: each "The Story" / "The World" trigger toggles its menu.
      // Click-based (not hover) so it behaves the same for touch, mouse, and
      // keyboard; a click anywhere else, or Escape, closes any open menu.
      (() => {
        const groups = Array.from(document.querySelectorAll('[data-nav-group]'));
        const closeAll = (except) => {
          for (const group of groups) {
            if (group === except) continue;
            group.classList.remove('open');
            group.querySelector('.nav-trigger')?.setAttribute('aria-expanded', 'false');
          }
        };
        for (const group of groups) {
          const trigger = group.querySelector('.nav-trigger');
          if (!trigger) continue;
          trigger.addEventListener('click', (e) => {
            e.stopPropagation();
            const open = group.classList.toggle('open');
            trigger.setAttribute('aria-expanded', open ? 'true' : 'false');
            closeAll(group);
          });
        }
        document.addEventListener('click', () => closeAll(null));
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape') closeAll(null);
        });
      })();
    </script>
  </body>
</html>
