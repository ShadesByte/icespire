---
import Base from './Base.astro';

interface Props {
  frontmatter: {
    title: string;
    description?: string;
    kicker?: string;
  };
  headings?: { depth: number; slug: string; text: string }[];
}

const { frontmatter, headings = [] } = Astro.props;

// Build a contents rail from the section headings (h2/h3). It fills the
// space beside the reading column on long pages and doubles as in-page
// navigation. Skip it on short pages that don't have enough sections.
const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);
const showToc = toc.length >= 3;
---

<Base title={frontmatter.title} description={frontmatter.description}>
  {frontmatter.kicker && <div class="kicker">{frontmatter.kicker}</div>}
  <div class={`doc-layout${showToc ? '' : ' no-aside'}`}>
    <div class="prose">
      <slot />
    </div>
    {
      showToc && (
        <aside class="doc-toc" aria-label="On this page">
          <div class="doc-toc-title">On this page</div>
          <nav>
            <ul>
              {toc.map((h) => (
                <li class={h.depth === 3 ? 'sub' : undefined}>
                  <a href={`#${h.slug}`}>{h.text}</a>
                </li>
              ))}
            </ul>
          </nav>
        </aside>
      )
    }
  </div>
  {
    showToc && (
      <script is:inline>
        (() => {
          const links = Array.from(document.querySelectorAll('.doc-toc a'));
          if (!links.length) return;
          // Map each heading element to its rail link via the '#slug' hash.
          const byId = new Map();
          for (const link of links) {
            const id = decodeURIComponent((link.getAttribute('href') || '').slice(1));
            const heading = id && document.getElementById(id);
            if (heading) byId.set(heading, link);
          }
          if (!byId.size) return;

          let current = null;
          const setActive = (link) => {
            if (link === current) return;
            if (current) current.classList.remove('active');
            if (link) link.classList.add('active');
            current = link;
          };

          // The section the reader is in is the lowest heading still above the
          // reading line near the top of the viewport.
          const pick = () => {
            // At the bottom of the page the last section can't scroll up to the
            // reading line, so highlight it once we've reached the end.
            if (window.innerHeight + window.scrollY >= document.body.scrollHeight - 2) {
              const headings = Array.from(byId.keys());
              setActive(byId.get(headings[headings.length - 1]) || null);
              return;
            }
            let best = null;
            let bestTop = -Infinity;
            for (const heading of byId.keys()) {
              const top = heading.getBoundingClientRect().top;
              if (top <= 120 && top > bestTop) {
                bestTop = top;
                best = heading;
              }
            }
            // Before scrolling past the first heading, highlight the first one.
            if (!best) best = byId.keys().next().value;
            setActive(byId.get(best) || null);
          };

          pick();
          window.addEventListener('scroll', pick, { passive: true });
          window.addEventListener('resize', pick, { passive: true });
        })();
      </script>
    )
  }
</Base>
