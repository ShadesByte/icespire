---
// Local map of the Mountain's Toe Gold Mine, drawn from the official map's
// layout (offical-assets/Maps/map-10.02-mountains-toe-gold-mine.jpg —
// reference only). A warren of galleries with west and east entrances.
// viewBox 900 × 560; north is up.

// Galleries as [cx, cy, rx, ry].
const galleries: [number, number, number, number][] = [
  [220, 185, 26, 20], [330, 120, 26, 22], [405, 195, 26, 19], [520, 195, 28, 20],
  [610, 185, 18, 15], [200, 320, 24, 18], [180, 425, 28, 20], [108, 472, 18, 14],
  [330, 330, 32, 24], [300, 435, 32, 24], [405, 455, 24, 18], [475, 345, 36, 26],
  [570, 435, 26, 19], [640, 345, 28, 20], [700, 455, 26, 19], [745, 330, 28, 21],
];

// Tunnels between galleries.
const tunnels = [
  'M 95 330 L 178 322',
  'M 205 338 L 190 408',
  'M 158 438 L 124 466',
  'M 222 315 L 300 328',
  'M 224 200 L 214 302',
  'M 244 176 L 306 132',
  'M 352 132 L 388 180',
  'M 428 200 L 494 198',
  'M 546 198 L 594 188',
  'M 610 200 L 648 328',
  'M 340 352 L 320 412',
  'M 330 438 L 382 450',
  'M 358 336 L 442 342',
  'M 428 448 L 548 440',
  'M 508 350 L 614 348',
  'M 594 428 L 678 450',
  'M 664 336 L 718 332',
  'M 724 452 L 772 448',
  'M 748 350 L 760 400',
  'M 405 214 L 405 430',
  'M 475 220 L 475 320',
];

// The tailings field east of the mine as [x, y].
const tailings: [number, number][] = [
  [822, 130], [852, 150], [828, 176], [860, 196], [834, 220], [864, 244],
];

const trees: [number, number, number][] = [
  [60, 130, 12], [95, 200, 10], [60, 280, 11], [858, 90, 12], [880, 300, 10],
  [858, 505, 12], [820, 530, 10], [120, 540, 11], [60, 480, 9],
];

// Cliff ticks along the massif rim.
const rimTicks: [number, number, number][] = [
  [190, 70, -30], [280, 48, -10], [380, 40, 0], [480, 44, 8], [580, 56, 15],
  [670, 84, 30], [740, 130, 50], [780, 190, 65], [796, 260, 80], [800, 330, 90],
  [796, 400, 100], [780, 460, 115], [130, 120, -50], [96, 180, -70], [84, 250, -85],
  [80, 320, -90], [86, 390, -100], [100, 450, -110], [150, 510, -140], [240, 532, -170],
  [360, 540, 175], [480, 536, 170], [600, 528, 168], [700, 510, 150],
];
---

<g class="submap-goldmine" aria-hidden="true">
  <rect class="sm-ground" x="0" y="0" width="900" height="560"></rect>

  <!-- The rock massif -->
  <path
    class="sm-rock"
    d="M 150 100 C 240 40 420 24 560 44 C 680 60 780 130 800 240
       C 812 320 804 420 760 480 C 700 540 540 552 400 546
       C 260 540 140 520 100 440 C 66 370 70 260 96 190 C 110 150 126 118 150 100 Z"></path>
  <g class="sm-cliff">
    {rimTicks.map(([x, y, r]) => (
      <path d="M0 0 l 9 3" transform={`translate(${x} ${y}) rotate(${r})`} />
    ))}
  </g>

  <!-- Tunnels then galleries -->
  {
    [0, 1].map((pass) => (
      <g class={pass === 0 ? 'sm-hall-wall' : 'sm-hall'} style={pass === 0 ? 'stroke-width: 13;' : 'stroke-width: 8;'}>
        {tunnels.map((d) => (
          <path d={d} />
        ))}
      </g>
    ))
  }
  <g>
    {galleries.map(([cx, cy, rx, ry]) => (
      <ellipse class="sm-floor" cx={cx} cy={cy} rx={rx} ry={ry} style="stroke-width: 2;" />
    ))}
  </g>

  <!-- Doors -->
  <g class="sm-door">
    <rect x="252" y="172" width="8" height="6"></rect>
    <rect x="366" y="128" width="8" height="6"></rect>
    <rect x="456" y="196" width="8" height="6"></rect>
    <rect x="238" y="312" width="8" height="6"></rect>
    <rect x="472" y="252" width="8" height="6"></rect>
    <rect x="614" y="252" width="8" height="6"></rect>
  </g>

  <!-- Entrances -->
  <path class="sm-path" d="M 30 330 L 92 330"></path>
  <path class="sm-path" d="M 774 448 C 820 448 850 470 878 496"></path>
  <text class="sm-note" x="26" y="312">west entrance</text>
  <text class="sm-note" x="742" y="520">east entrance</text>

  <!-- Tailings -->
  <g class="sm-crack">
    {tailings.map(([x, y]) => (
      <path d={`M ${x - 8} ${y} q 8 -5 16 0`} />
    ))}
  </g>
  <text class="sm-note" x="812" y="272">spoil heaps</text>

  <!-- Trees -->
  <g>
    {trees.map(([x, y, r]) => (
      <circle class="sm-tree" cx={x} cy={y} r={r} />
    ))}
  </g>

  <!-- Numbered points of interest -->
  <g class="sm-poi" data-tip-title="West entrance" data-tip-sub="The miners' way in">
    <circle cx="60" cy="348" r="8"></circle><text x="60" y="348">1</text>
  </g>
  <g class="sm-poi" data-tip-title="The great gallery" data-tip-sub="Heart of the diggings">
    <circle cx="475" cy="300" r="8"></circle><text x="475" y="300">2</text>
  </g>
  <g class="sm-poi danger" data-tip-title="Deep galleries" data-tip-sub="Something dens in the dark east halls">
    <circle cx="640" cy="316" r="8"></circle><text x="640" y="316">3</text>
  </g>
  <g class="sm-poi" data-tip-title="East entrance" data-tip-sub="Quieter. Too quiet.">
    <circle cx="836" cy="478" r="8"></circle><text x="836" y="478">4</text>
  </g>

  <!-- Scale -->
  <g class="sm-scale" transform="translate(742 62)">
    <line x1="0" y1="0" x2="110" y2="0"></line>
    <line x1="0" y1="-4" x2="0" y2="4"></line>
    <line x1="110" y1="-4" x2="110" y2="4"></line>
    <text x="55" y="-8">≈ 60 feet</text>
  </g>

  <!-- Compass -->
  <g class="m-compass" transform="translate(64 66)">
    <circle r="18"></circle>
    <line x1="0" y1="13" x2="0" y2="-9"></line>
    <path class="m-compass-arrow" d="M0 -16 L5 -5 L0 -8 L-5 -5 Z"></path>
    <text y="-25">N</text>
  </g>
</g>
