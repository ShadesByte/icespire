---
// Local map of the Loggers' Camp, drawn from the official map's layout
// (offical-assets/Maps/map-09.02-loggers-camp.jpg — reference only).
// A timber camp where the river leaves Neverwinter Wood. viewBox 900 × 560;
// north is up.

// Tents as [x, y, rot] — two clusters on the sandy clearing.
const tents: [number, number, number][] = [
  [648, 175, 10], [688, 158, -15], [726, 180, 20], [744, 220, 0],
  [712, 252, -20], [668, 248, 15], [630, 218, -5],
  [610, 388, 5], [652, 372, -12], [696, 386, 18], [716, 424, 0],
  [688, 458, -15], [644, 462, 10], [606, 432, -8],
];

// Log piles as [x, y, rot].
const logPiles: [number, number, number][] = [
  [432, 198, 8], [512, 248, -6], [590, 222, 14], [548, 300, -4],
];

// Trees and bushes.
const trees: [number, number, number][] = [
  [95, 180, 13], [150, 150, 9], [70, 320, 11], [120, 420, 10], [180, 500, 12],
  [330, 490, 10], [430, 520, 11], [560, 520, 12], [840, 160, 13], [860, 300, 10],
  [810, 480, 12], [250, 160, 8], [380, 350, 8], [770, 320, 8],
];

// Ankheg eruption marks as [x, y].
const eruptions: [number, number][] = [[318, 292], [600, 408], [742, 432]];
---

<g class="submap-loggerscamp" aria-hidden="true">
  <rect class="sm-ground" x="0" y="0" width="900" height="560"></rect>

  <!-- The sandy clearing east -->
  <path
    class="sm-open"
    d="M 420 130 C 500 150 560 160 620 150 C 700 138 780 150 850 140 L 900 150 L 900 470
       C 840 500 760 480 700 500 C 640 520 560 500 500 470 C 460 448 440 400 452 350
       C 400 340 380 300 396 260 C 408 228 410 170 420 130 Z"
    style="stroke: none;"></path>

  <!-- The river -->
  <path
    class="sm-water"
    d="M 0 0 L 900 0 L 900 88 C 800 116 720 96 640 108 C 540 122 460 100 380 118 C 260 140 120 108 0 132 Z"></path>
  <g class="sm-detail" style="opacity:.5;">
    <path d="M 150 50 q 14 -6 28 0 q 14 6 28 0"></path>
    <path d="M 520 40 q 14 -6 28 0 q 14 6 28 0"></path>
    <path d="M 760 56 q 14 -6 28 0 q 14 6 28 0"></path>
  </g>

  <!-- The pier -->
  <g class="sm-bridge">
    <rect x="344" y="60" width="14" height="66" fill="none"></rect>
    {[72, 84, 96, 108].map((y) => (
      <line x1="344" y1={y} x2="358" y2={y} />
    ))}
  </g>

  <!-- Escarpment through the west (about ten feet of drop) -->
  <g class="sm-cliff">
    <path d="M 40 170 C 120 200 190 240 224 296 C 252 342 260 400 236 452"></path>
    {[[70, 182, 60], [120, 208, 50], [170, 240, 40], [206, 280, 25], [230, 330, 10], [240, 386, 0], [232, 434, -15]].map(
      ([x, y, r]) => (
        <path d="M0 0 l 9 4" transform={`translate(${x} ${y}) rotate(${r})`} />
      )
    )}
  </g>
  <text class="sm-note" x="150" y="266">+10 ft.</text>

  <!-- Bunkhouse -->
  <g transform="translate(295 262)">
    <path class="sm-building" d="M -34 -26 H 10 V -4 H 34 V 26 H -12 V 4 H -34 Z"></path>
    <line class="sm-roofline" x1="-26" y1="-10" x2="20" y2="12"></line>
  </g>

  <!-- Old foundations -->
  <g class="sm-crack">
    <rect x="66" y="336" width="52" height="34" rx="2"></rect>
    <rect x="96" y="452" width="26" height="54" rx="2"></rect>
  </g>

  <!-- The knoll with ruined walls -->
  <ellipse class="sm-ground" cx="472" cy="352" rx="52" ry="40" style="stroke: var(--map-ridge); stroke-width: 1;"></ellipse>
  <g class="sm-crack">
    <rect x="448" y="334" width="48" height="30" rx="2"></rect>
  </g>

  <!-- Log piles -->
  <g>
    {logPiles.map(([x, y, r]) => (
      <g transform={`translate(${x} ${y}) rotate(${r})`}>
        <rect class="sm-building" x="-20" y="-9" width="40" height="18" rx="2" />
        <path class="sm-roofline" d="M-20 -3 H20 M-20 3 H20" />
      </g>
    ))}
  </g>

  <!-- Tents -->
  <g>
    {tents.map(([x, y, r]) => (
      <path
        class="sm-building"
        d="M -8 5 Q 0 -9 8 5 L 5 7 L -5 7 Z"
        transform={`translate(${x} ${y}) rotate(${r})`}
      />
    ))}
  </g>

  <!-- Ankheg eruptions -->
  <g class="sm-detail" style="stroke-width: 1.5;">
    {eruptions.map(([x, y]) => (
      <path
        d="M0 -7 L2 -2 L7 -3 L3 1 L6 6 L0 3 L-6 6 L-3 1 L-7 -3 L-2 -2 Z"
        transform={`translate(${x} ${y})`}
      />
    ))}
  </g>

  <!-- Trees -->
  <g>
    {trees.map(([x, y, r]) => (
      <circle class="sm-tree" cx={x} cy={y} r={r} />
    ))}
  </g>

  <!-- Numbered points of interest -->
  <g class="sm-poi" data-tip-title="The pier" data-tip-sub="Timber floats downstream from here">
    <circle cx="376" cy="66" r="8"></circle><text x="376" y="66">1</text>
  </g>
  <g class="sm-poi danger" data-tip-title="The bunkhouse" data-tip-sub="Something erupted through the floor">
    <circle cx="295" cy="228" r="8"></circle><text x="295" y="228">2</text>
  </g>
  <g class="sm-poi" data-tip-title="Tent rows" data-tip-sub="The loggers' camp proper">
    <circle cx="676" cy="130" r="8"></circle><text x="676" y="130">3</text>
  </g>
  <g class="sm-poi danger" data-tip-title="Churned earth" data-tip-sub="Eruption mounds pock the clearing">
    <circle cx="742" cy="408" r="8"></circle><text x="742" y="408">4</text>
  </g>
  <g class="sm-poi" data-tip-title="Old foundations" data-tip-sub="An earlier camp, long gone">
    <circle cx="92" cy="316" r="8"></circle><text x="92" y="316">5</text>
  </g>

  <!-- Scale -->
  <g class="sm-scale" transform="translate(742 530)">
    <line x1="0" y1="0" x2="110" y2="0"></line>
    <line x1="0" y1="-4" x2="0" y2="4"></line>
    <line x1="110" y1="-4" x2="110" y2="4"></line>
    <text x="55" y="-8">≈ 60 feet</text>
  </g>

  <!-- Compass -->
  <g class="m-compass" transform="translate(846 490)">
    <circle r="18"></circle>
    <line x1="0" y1="13" x2="0" y2="-9"></line>
    <path class="m-compass-arrow" d="M0 -16 L5 -5 L0 -8 L-5 -5 Z"></path>
    <text y="-25">N</text>
  </g>
</g>
