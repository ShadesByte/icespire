---
// Local map of the Circle of Thunder, drawn from the official map's layout
// (offical-assets/Maps/map-03.02-circle-of-thunder.jpg — reference only).
// A ring of standing stones on a bald hilltop deep in Neverwinter Wood.
// viewBox 900 × 560; north is up.

// The eight stones of the ring, around (450, 280).
const stones: [number, number, number][] = (() => {
  const out: [number, number, number][] = [];
  for (let i = 0; i < 8; i++) {
    const a = (i / 8) * Math.PI * 2 + 0.35;
    out.push([450 + Math.cos(a) * 74, 280 + Math.sin(a) * 62, (a * 180) / Math.PI + 90]);
  }
  return out;
})();

// Woodland pressing in on the clearing.
const trees: [number, number, number][] = [
  [120, 80, 16], [190, 50, 13], [280, 90, 15], [370, 40, 12], [520, 50, 14],
  [640, 60, 12], [760, 90, 15], [830, 150, 13], [860, 260, 15], [830, 380, 13],
  [760, 460, 15], [650, 510, 13], [520, 530, 14], [380, 520, 12], [260, 500, 15],
  [150, 460, 13], [80, 380, 14], [60, 250, 13], [70, 160, 11], [560, 130, 10],
  [320, 440, 10], [600, 420, 11], [220, 200, 10], [680, 220, 10],
];

// Cave mouths down to the burrows.
const caves: [number, number][] = [[335, 250], [560, 232], [482, 402]];
---

<g class="submap-circleofthunder" aria-hidden="true">
  <rect class="sm-ground" x="0" y="0" width="900" height="560"></rect>

  <!-- The hill -->
  <g class="sm-contour">
    <ellipse cx="450" cy="280" rx="330" ry="240"></ellipse>
    <ellipse cx="450" cy="280" rx="255" ry="185"></ellipse>
    <ellipse cx="450" cy="280" rx="180" ry="130"></ellipse>
    <ellipse cx="450" cy="280" rx="115" ry="86"></ellipse>
  </g>
  <text class="sm-note" x="770" y="270">+60 ft.</text>
  <text class="sm-note" x="694" y="272">+70 ft.</text>
  <text class="sm-note" x="622" y="274">+80 ft.</text>
  <text class="sm-note" x="556" y="276">+90 ft.</text>

  <!-- Trails circling the hill and away southwest -->
  <path class="sm-path" d="M 210 60 C 300 140 380 160 450 158 C 560 156 640 190 700 260"></path>
  <path class="sm-path" d="M 190 520 C 260 470 300 420 340 400"></path>
  <text class="sm-note" x="120" y="544">To the Woodland Manse</text>

  <!-- The stone ring -->
  <g>
    {stones.map(([x, y, r]) => (
      <g transform={`translate(${x} ${y}) rotate(${r})`}>
        <rect class="sm-rock" x="-9" y="-14" width="18" height="28" rx="3" />
        <rect class="sm-inner" x="-5" y="-9" width="10" height="18" rx="2" style="stroke-dasharray: 3 2;" />
      </g>
    ))}
  </g>

  <!-- Fallen arches on the slopes -->
  {
    [[298, 128], [622, 92], [582, 468]].map(([x, y]) => (
      <g class="sm-rock" transform={`translate(${x} ${y})`}>
        <path d="M -10 8 L -7 -8 L -2 -8 L -4 8 Z" />
        <path d="M 10 8 L 7 -8 L 2 -8 L 4 8 Z" />
        <path d="M -9 -6 L 9 -6 L 8 -1 L -8 -1 Z" transform="rotate(-8)" />
      </g>
    ))
  }

  <!-- Cave mouths -->
  <g>
    {caves.map(([x, y]) => (
      <>
        <circle class="sm-rock" cx={x} cy={y} r="7" />
        <circle class="sm-detail-fill" cx={x} cy={y} r="3" style="stroke:none;" />
      </>
    ))}
  </g>

  <!-- The wood -->
  <g>
    {trees.map(([x, y, r]) => (
      <circle class="sm-tree" cx={x} cy={y} r={r} />
    ))}
  </g>

  <!-- Numbered points of interest -->
  <g class="sm-poi danger" data-tip-title="The stone ring" data-tip-sub="Thunder rolls out of it on clear days">
    <circle cx="450" cy="280" r="8"></circle><text x="450" y="280">1</text>
  </g>
  <g class="sm-poi" data-tip-title="Fallen arches" data-tip-sub="Older than the stones, maybe">
    <circle cx="298" cy="104" r="8"></circle><text x="298" y="104">2</text>
  </g>
  <g class="sm-poi danger" data-tip-title="Cave mouths" data-tip-sub="Burrows worm beneath the hill">
    <circle cx="508" cy="402" r="8"></circle><text x="508" y="402">3</text>
  </g>

  <!-- Scale -->
  <g class="sm-scale" transform="translate(742 530)">
    <line x1="0" y1="0" x2="110" y2="0"></line>
    <line x1="0" y1="-4" x2="0" y2="4"></line>
    <line x1="110" y1="-4" x2="110" y2="4"></line>
    <text x="55" y="-8">≈ 60 feet</text>
  </g>

  <!-- Compass -->
  <g class="m-compass" transform="translate(846 66)">
    <circle r="18"></circle>
    <line x1="0" y1="13" x2="0" y2="-9"></line>
    <path class="m-compass-arrow" d="M0 -16 L5 -5 L0 -8 L-5 -5 Z"></path>
    <text y="-25">N</text>
  </g>
</g>
