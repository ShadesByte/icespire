---
// Local map of the Tower of Storms, drawn from the official map's layout
// (offical-assets/Maps/map-12.02-tower-of-storms.jpg — reference only).
// A dark lighthouse on a rocky headland, ringed by wrecks. viewBox 900 × 560;
// north is up.

// Shipwreck hulks as [x, y, rot].
const wrecks: [number, number, number][] = [
  [160, 105, 20], [75, 195, -10], [120, 320, 35], [70, 460, -25], [190, 470, 10],
];

// Fish in the water as [x, y].
const fish: [number, number][] = [[110, 150], [90, 390], [150, 520], [560, 520]];

// Cliff hachures around the islet rim.
const rimTicks: [number, number, number][] = [
  [232, 62, -20], [300, 48, 0], [370, 60, 20], [430 ,90, 40], [470, 150, 60],
  [488, 220, 80], [484, 290, 95], [462, 350, 115], [420, 400, 135], [360, 440, 160],
  [290, 452, 175], [225, 435, -160], [180, 395, -140], [152, 340, -115],
  [140, 270, -95], [146, 200, -75], [170, 130, -50],
];
---

<g class="submap-towerofstorms" aria-hidden="true">
  <rect class="sm-water" x="0" y="0" width="900" height="560" style="stroke: none;"></rect>

  <!-- Ripples -->
  <g class="sm-detail" style="opacity:.4;">
    <path d="M 560 120 q 14 -6 28 0 q 14 6 28 0"></path>
    <path d="M 640 260 q 14 -6 28 0 q 14 6 28 0"></path>
    <path d="M 300 520 q 14 -6 28 0 q 14 6 28 0"></path>
    <path d="M 700 60 q 14 -6 28 0 q 14 6 28 0"></path>
  </g>

  <!-- The shore, east -->
  <path class="sm-open" d="M 828 0 C 840 80 830 180 842 280 C 852 360 840 460 850 560 L 900 560 L 900 0 Z" style="stroke:none;"></path>
  <path class="sm-rock" d="M 874 0 C 884 100 876 240 886 360 C 892 440 884 500 890 560 L 900 560 L 900 0 Z" style="stroke:none;"></path>
  <text class="sm-note" transform="translate(862 300) rotate(-90)">to the clifftop</text>

  <!-- The islet -->
  <path
    class="sm-rock"
    d="M 240 70 C 320 40 420 60 466 130 C 500 184 498 260 478 320
       C 460 376 420 430 350 448 C 280 464 210 440 170 386
       C 136 340 132 250 150 190 C 166 136 196 90 240 70 Z"></path>
  <g class="sm-cliff">
    {rimTicks.map(([x, y, r]) => (
      <path d="M0 0 l 9 3" transform={`translate(${x} ${y}) rotate(${r})`} />
    ))}
  </g>

  <!-- The lighthouse and its halls -->
  <circle class="sm-rock" cx="255" cy="230" r="24" style="stroke-width: 2.5;"></circle>
  <g class="sm-detail" transform="translate(255 230)">
    <circle r="10"></circle>
    <path d="M0 0 L10 0 M0 0 L-7 7 M0 0 L-3 -9"></path>
  </g>
  <rect class="sm-floor" x="292" y="166" width="48" height="32" rx="3"></rect>
  <rect class="sm-floor" x="294" y="226" width="44" height="32" rx="3"></rect>
  <rect class="sm-floor" x="330" y="314" width="48" height="38" rx="3"></rect>
  {
    [0, 1].map((pass) => (
      <g class={pass === 0 ? 'sm-hall-wall' : 'sm-hall'} style={pass === 0 ? 'stroke-width: 12;' : 'stroke-width: 7;'}>
        <path d="M 279 226 L 294 234" />
        <path d="M 316 200 L 316 224" />
        <path d="M 322 258 L 344 312" />
        <path d="M 354 352 C 350 386 380 400 420 408" />
      </g>
    ))
  }

  <!-- The winding causeway to shore -->
  {
    [0, 1].map((pass) => (
      <g class={pass === 0 ? 'sm-hall-wall' : 'sm-hall'} style={pass === 0 ? 'stroke-width: 15;' : 'stroke-width: 10;'}>
        <path d="M 420 408 C 480 424 520 408 570 424 C 620 440 660 428 700 440 C 740 452 790 444 830 452" />
      </g>
    ))
  }

  <!-- Sea rocks and the cave -->
  <path class="sm-rock" d="M 640 452 C 652 434 680 430 694 446 C 706 460 700 480 682 486 C 662 492 644 478 640 452 Z" style="fill: var(--map-peak-fill);"></path>
  <path class="sm-rock" d="M 716 468 C 732 456 754 460 762 476 C 768 490 756 504 738 504 C 722 504 712 488 716 468 Z"></path>
  <circle class="sm-detail-fill" cx="688" cy="462" r="4" style="stroke:none;"></circle>

  <!-- Wrecks on the reefs -->
  <g class="sm-detail" style="stroke-width: 1.6; opacity: .85;">
    {wrecks.map(([x, y, r]) => (
      <g transform={`translate(${x} ${y}) rotate(${r})`}>
        <path d="M -18 0 Q 0 10 18 0" />
        <path d="M -12 3 L -12 -8 M -4 5 L -4 -12 M 4 5 L 4 -10 M 12 3 L 12 -6" />
      </g>
    ))}
  </g>

  <!-- Fish -->
  <g class="sm-detail" style="opacity:.6;">
    {fish.map(([x, y]) => (
      <path d={`M ${x} ${y} q 5 -4 10 0 q -5 4 -10 0 M ${x + 10} ${y} l 4 -3 M ${x + 10} ${y} l 4 3`} />
    ))}
  </g>

  <!-- Numbered points of interest -->
  <g class="sm-poi" data-tip-title="The tower" data-tip-sub="Its beacon has been dark for years">
    <circle cx="255" cy="196" r="8"></circle><text x="255" y="196">1</text>
  </g>
  <g class="sm-poi danger" data-tip-title="The wrecks" data-tip-sub="The reefs collect ships">
    <circle cx="128" cy="440" r="8"></circle><text x="128" y="440">2</text>
  </g>
  <g class="sm-poi danger" data-tip-title="Sea caves" data-tip-sub="Something dens in the rocks">
    <circle cx="688" cy="428" r="8"></circle><text x="688" y="428">3</text>
  </g>
  <g class="sm-poi" data-tip-title="The causeway" data-tip-sub="A wave-swept scramble from shore">
    <circle cx="770" cy="424" r="8"></circle><text x="770" y="424">4</text>
  </g>

  <!-- Scale -->
  <g class="sm-scale" transform="translate(560 62)">
    <line x1="0" y1="0" x2="110" y2="0"></line>
    <line x1="0" y1="-4" x2="0" y2="4"></line>
    <line x1="110" y1="-4" x2="110" y2="4"></line>
    <text x="55" y="-8">≈ 60 feet</text>
  </g>

  <!-- Compass -->
  <g class="m-compass" transform="translate(64 500)">
    <circle r="18"></circle>
    <line x1="0" y1="13" x2="0" y2="-9"></line>
    <path class="m-compass-arrow" d="M0 -16 L5 -5 L0 -8 L-5 -5 Z"></path>
    <text y="-25">N</text>
  </g>
</g>
