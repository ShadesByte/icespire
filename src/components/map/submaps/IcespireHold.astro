---
// Local map of Icespire Hold, drawn from the official map's layout
// (offical-assets/Maps/map-08.02-icespire-hold.jpg — reference only).
// A ruined mountain fortress: main floor and gatehouse, with the roof and
// the undercroft as insets. viewBox 900 × 560; north is up.

const mainRooms: [number, number, number, number][] = [
  [215, 270, 40, 34],  // stair room
  [272, 276, 56, 46],  // great chamber
  [170, 341, 34, 30],
  [216, 341, 38, 30],
  [273, 370, 52, 40],
  [196, 377, 48, 36],
];

const undercroftRooms: [number, number, number, number][] = [
  [742, 362, 42, 38],  // central vault
  [678, 362, 34, 30],  // west crypt
  [806, 362, 34, 30],  // east crypt
  [742, 468, 38, 62],  // long tomb hall
];

// Crypt niches as [x, y].
const niches: [number, number][] = [
  [656, 344], [656, 362], [656, 380], [828, 344], [828, 362], [828, 380],
  [730, 448], [754, 448], [730, 488], [754, 488],
];

// Ridge lines radiating down the mountainside.
const ridges: [number, number, number][] = [
  [80, 140, 30], [150, 500, -20], [420, 500, 15], [560, 120, -35],
  [540, 480, 25], [60, 380, 10], [340, 60, -15], [600, 380, 40],
];
---

<g class="submap-icespirehold" aria-hidden="true">
  <rect class="sm-rock" x="0" y="0" width="900" height="560" style="stroke:none;"></rect>
  <g class="sm-crack">
    {ridges.map(([x, y, r]) => (
      <path d="M-16 0 Q-5 -5 2 0 Q9 5 16 1" transform={`translate(${x} ${y}) rotate(${r})`} />
    ))}
  </g>

  <!-- The icy mountain path, winding in from the northwest -->
  <path
    class="sm-snowpath"
    d="M 50 70 C 140 40 230 80 205 122 C 180 162 275 168 340 150 C 415 130 430 190 385 215
       C 350 234 380 240 405 235 C 480 220 545 250 555 305 C 563 355 530 415 470 440
       C 430 456 400 470 380 490"></path>

  <!-- Main fortress: crenellated outer wall and interior -->
  <rect class="sm-open" x="58" y="208" width="306" height="240" rx="8"></rect>
  <rect class="sm-crenel" x="58" y="208" width="306" height="240" rx="8"></rect>
  <!-- Breaches in the wall -->
  {
    [[132, 448], [352, 390], [58, 302]].map(([x, y]) => (
      <g class="sm-detail">
        <circle cx={x} cy={y} r="3.4" />
        <circle cx={x + 7} cy={y - 4} r="2.6" />
        <circle cx={x - 3} cy={y + 6} r="2.4" />
      </g>
    ))
  }

  {
    [0, 1].map((pass) => (
      <g class={pass === 0 ? 'sm-hall-wall' : 'sm-hall'}>
        <path d="M 215 289 L 215 324" />
        <path d="M 238 341 L 196 358" />
        <path d="M 273 300 L 273 348" />
        <path d="M 236 270 L 242 272" />
      </g>
    ))
  }
  <g>
    {mainRooms.map(([cx, cy, w, h]) => (
      <rect class="sm-floor" x={cx - w / 2} y={cy - h / 2} width={w} height={h} rx="3" />
    ))}
  </g>
  <!-- Spiral stair -->
  <g class="sm-detail" transform="translate(206 262)">
    <circle r="7"></circle>
    <path d="M0 0 L7 0 M0 0 L-5 5 M0 0 L-2 -6.5"></path>
  </g>

  <!-- The bridge over the drop -->
  <g class="sm-bridge">
    <line x1="366" y1="278" x2="424" y2="278"></line>
    <line x1="366" y1="286" x2="424" y2="286"></line>
  </g>

  <!-- Gatehouse -->
  <rect class="sm-open" x="420" y="240" width="96" height="170" rx="8"></rect>
  <rect class="sm-crenel" x="420" y="240" width="96" height="170" rx="8"></rect>
  <rect class="sm-floor" x="428" y="262" width="44" height="56" rx="3"></rect>
  <rect class="sm-floor" x="476" y="274" width="24" height="42" rx="3"></rect>
  <rect class="sm-floor" x="478" y="340" width="30" height="28" rx="3"></rect>
  <rect class="sm-floor" x="432" y="350" width="26" height="22" rx="3"></rect>
  <rect class="sm-floor" x="448" y="378" width="40" height="26" rx="3"></rect>
  <g class="sm-stairs">
    <g transform="translate(487 292) rotate(90)">
      <path d="M-8 -5 H8 M-8 -1 H8 M-8 3 H8 M-8 7 H8"></path>
    </g>
  </g>

  <!-- Roof inset -->
  <rect class="sm-inner" x="612" y="46" width="272" height="196" rx="4" style="stroke: var(--map-ridge); opacity:.7;"></rect>
  <text class="sm-note" x="628" y="66">Roof of the fortress</text>
  <path
    class="sm-floor"
    d="M 648 100 L 672 100 L 672 84 L 700 84 L 700 100 L 722 100 L 722 128 L 706 128 L 706 152 L 672 152 L 672 136 L 648 136 Z"></path>
  <g class="sm-detail" transform="translate(688 118)">
    <circle r="7"></circle>
    <path d="M0 0 L7 0 M0 0 L-5 5 M0 0 L-2 -6.5"></path>
  </g>
  <rect class="sm-floor" x="742" y="84" width="118" height="134" rx="3"></rect>
  <rect class="sm-crenel" x="742" y="84" width="118" height="134" rx="3" style="stroke-width: 3.5; stroke-dasharray: 5 3;"></rect>
  <g class="sm-detail">
    <circle cx="775" cy="175" r="2.6"></circle>
    <circle cx="800" cy="172" r="2.6"></circle>
    <circle cx="828" cy="176" r="2.6"></circle>
  </g>
  <text class="sm-note" x="762" y="205">chimneys</text>

  <!-- Undercroft inset -->
  <rect class="sm-inner" x="612" y="290" width="272" height="240" rx="4" style="stroke: var(--map-ridge); opacity:.7;"></rect>
  <text class="sm-note" x="628" y="310">Undercroft</text>
  {
    [0, 1].map((pass) => (
      <g class={pass === 0 ? 'sm-hall-wall' : 'sm-hall'}>
        <path d="M 695 362 L 721 362" />
        <path d="M 763 362 L 789 362" />
        <path d="M 742 381 L 742 437" />
      </g>
    ))
  }
  <g>
    {undercroftRooms.map(([cx, cy, w, h]) => (
      <rect class="sm-floor" x={cx - w / 2} y={cy - h / 2} width={w} height={h} rx="3" />
    ))}
    {niches.map(([x, y]) => (
      <rect class="sm-inner" x={x - 4} y={y - 6} width="8" height="12" rx="1" />
    ))}
  </g>
  <text class="sm-note" x="750" y="516">s</text>

  <!-- Labels -->
  <text class="sm-note" x="66" y="196">Main floor of the fortress</text>
  <text class="sm-note" x="424" y="432">Gatehouse</text>
  <text class="sm-note" x="60" y="490">Icespire Peak rises southwest</text>

  <!-- Numbered points of interest -->
  <g class="sm-poi" data-tip-title="The gatehouse" data-tip-sub="First stop on the icy path">
    <circle cx="468" cy="228" r="8"></circle><text x="468" y="228">1</text>
  </g>
  <g class="sm-poi" data-tip-title="The bridge" data-tip-sub="A narrow span over a long drop">
    <circle cx="394" cy="260" r="8"></circle><text x="394" y="260">2</text>
  </g>
  <g class="sm-poi" data-tip-title="The great courtyard" data-tip-sub="Open to the sky — and to wings">
    <circle cx="112" cy="270" r="8"></circle><text x="112" y="270">3</text>
  </g>
  <g class="sm-poi" data-tip-title="The keep" data-tip-sub="Halls and chambers of the old garrison">
    <circle cx="272" cy="250" r="8"></circle><text x="272" y="250">4</text>
  </g>
  <g class="sm-poi danger" data-tip-title="The roof" data-tip-sub="A throne with a view, for something large">
    <circle cx="742" cy="66" r="8"></circle><text x="742" y="66">5</text>
  </g>
  <g class="sm-poi" data-tip-title="The undercroft" data-tip-sub="Cold tombs beneath the keep">
    <circle cx="700" cy="330" r="8"></circle><text x="700" y="330">6</text>
  </g>

  <!-- Scale -->
  <g class="sm-scale" transform="translate(60 528)">
    <line x1="0" y1="0" x2="95" y2="0"></line>
    <line x1="0" y1="-4" x2="0" y2="4"></line>
    <line x1="95" y1="-4" x2="95" y2="4"></line>
    <text x="47" y="-8">≈ 50 feet</text>
  </g>

  <!-- Compass -->
  <g class="m-compass" transform="translate(560 66)">
    <circle r="18"></circle>
    <line x1="0" y1="13" x2="0" y2="-9"></line>
    <path class="m-compass-arrow" d="M0 -16 L5 -5 L0 -8 L-5 -5 Z"></path>
    <text y="-25">N</text>
  </g>
</g>
