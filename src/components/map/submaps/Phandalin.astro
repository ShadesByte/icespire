---
// Local map of Phandalin, drawn from the official town map's layout
// (offical-assets/Maps/map-00.04-phandalin.jpg — reference only).
// viewBox 900 × 650; north is up; 100 units ≈ 200 feet.

// Unnamed houses as [x, y, w, h, rotate].
const houses: [number, number, number, number, number][] = [
  [445, 122, 26, 16, -10], [472, 95, 20, 14, 6], [428, 168, 24, 15, 8],
  [368, 226, 24, 16, -5], [421, 237, 20, 14, 12], [338, 300, 22, 15, -12],
  [455, 290, 22, 14, 6], [502, 300, 26, 16, -4], [543, 286, 20, 14, 8],
  [566, 312, 18, 13, 0], [350, 396, 22, 15, -8], [330, 470, 20, 14, 5],
  [392, 472, 24, 15, -10], [432, 442, 20, 14, 6], [278, 312, 20, 14, -5],
  [256, 342, 18, 13, 8], [508, 210, 20, 14, -8],
];

// Orchard rows northwest: [x, y].
const orchard: [number, number][] = [];
for (let row = 0; row < 3; row++) {
  for (let col = 0; col < 5; col++) {
    orchard.push([148 + col * 19 + (row % 2) * 6, 172 + row * 24]);
  }
}

// Eastern woods as [x, y, r].
const woods: [number, number, number][] = [
  [800, 368, 12], [826, 390, 15], [856, 372, 11], [872, 412, 13],
  [812, 428, 12], [844, 448, 14], [876, 470, 11], [820, 486, 12],
  [852, 512, 13], [880, 540, 10], [812, 540, 10], [846, 566, 11],
];

// Scattered lone trees.
const trees: [number, number, number][] = [
  [540, 150, 8], [620, 210, 9], [300, 240, 7], [230, 390, 8],
  [560, 420, 8], [190, 480, 7], [640, 130, 7], [480, 530, 8],
  [590, 545, 7], [700, 120, 8],
];

const hillArcs: [number, number, number][] = [
  [150, 305, 1.0], [205, 425, 0.9], [600, 155, 1.0], [702, 505, 0.9],
  [122, 122, 0.9], [822, 122, 1.0], [652, 602, 0.8], [98, 570, 0.8],
  [755, 55, 0.8], [280, 555, 0.9],
];

// Field hachures: [cx, cy, halfW, rows, rot].
const fields: { cx: number; cy: number; w: number; rows: number; rot: number }[] = [
  { cx: 610, cy: 462, w: 46, rows: 5, rot: -12 },
  { cx: 330, cy: 575, w: 44, rows: 4, rot: 8 },
  { cx: 100, cy: 565, w: 38, rows: 4, rot: -6 },
];
---

<g class="submap-phandalin" aria-hidden="true">
  <rect class="sm-ground" x="0" y="0" width="900" height="650"></rect>

  <!-- Rolling hill hints -->
  <g class="m-hill">
    {hillArcs.map(([x, y, s]) => (
      <path d="M-14 0 Q0 -12 14 0" transform={`translate(${x} ${y}) scale(${s})`} />
    ))}
  </g>

  <!-- Stream in the northwest corner -->
  <path class="m-river" d="M 30 78 C 85 94 130 86 170 98 C 200 106 222 120 238 136" style="stroke-width:2;"></path>

  <!-- The eastern ravine, cliffs and all -->
  <g class="sm-cliff">
    <path d="M 728 150 C 742 210 758 258 764 310 C 770 362 762 410 752 452"></path>
    <path d="M 762 142 C 778 205 792 260 796 315 C 800 368 790 420 778 464"></path>
    {[170, 210, 250, 290, 330, 370, 410].map((y) => (
      <path d={`M ${730 + (y - 150) * 0.11} ${y} l 8 3`} />
    ))}
  </g>
  <path class="m-river" d="M 748 165 C 758 230 770 290 776 350 C 780 400 772 430 764 452" style="stroke-width:1.6; opacity:.8;"></path>
  <!-- Broken walls of the old ruin above the ravine -->
  <g class="sm-detail">
    <path d="M 800 236 l 18 -4 l 2 9 l -12 3 M 812 258 l 16 -5 M 798 276 l 10 -3 l 3 8"></path>
  </g>
  <text class="sm-note" x="828" y="250">old ruins</text>

  <!-- Streets -->
  <g class="sm-street">
    <path d="M 472 58 C 462 120 450 170 430 215 C 415 250 400 270 390 292"></path>
    <path d="M 390 292 C 440 300 500 308 560 300 C 620 295 672 286 716 276"></path>
    <path d="M 390 292 C 370 330 342 362 320 396 C 300 430 250 502 172 568"></path>
    <path d="M 392 298 C 412 330 442 356 480 370 C 510 380 546 372 566 352"></path>
  </g>
  <circle class="sm-plaza" cx="390" cy="292" r="17"></circle>

  <!-- Orchard -->
  <g>
    {orchard.map(([x, y]) => (
      <circle class="sm-tree" cx={x} cy={y} r="6.5" />
    ))}
  </g>

  <!-- Woods and lone trees -->
  <g>
    {woods.map(([x, y, r]) => (
      <circle class="sm-tree" cx={x} cy={y} r={r} />
    ))}
    {trees.map(([x, y, r]) => (
      <circle class="sm-tree" cx={x} cy={y} r={r} />
    ))}
  </g>

  <!-- Fields -->
  <g class="sm-field">
    {fields.map((f) =>
      Array.from({ length: f.rows }, (_, i) => (
        <path
          d={`M ${-f.w} ${(i - (f.rows - 1) / 2) * 9} h ${f.w * 2}`}
          transform={`translate(${f.cx} ${f.cy}) rotate(${f.rot})`}
        />
      ))
    )}
  </g>

  <!-- Unnamed houses -->
  <g>
    {houses.map(([x, y, w, h, r]) => (
      <g transform={`translate(${x} ${y}) rotate(${r})`}>
        <rect class="sm-building" x={-w / 2} y={-h / 2} width={w} height={h} rx="1.5" />
        <line class="sm-roofline" x1={-w / 2 + 2} y1="0" x2={w / 2 - 2} y2="0" />
      </g>
    ))}
  </g>

  <!-- Named buildings -->
  <!-- 1 · Stonehill Inn -->
  <g transform="translate(407 268) rotate(4)">
    <rect class="sm-building" x="-17" y="-11" width="34" height="22" rx="1.5"></rect>
    <line class="sm-roofline" x1="-14" y1="0" x2="14" y2="0"></line>
  </g>
  <!-- 2 · Barthen's Provisions -->
  <g transform="translate(464 212) rotate(-8)">
    <rect class="sm-building" x="-18" y="-12" width="36" height="24" rx="1.5"></rect>
    <line class="sm-roofline" x1="-15" y1="0" x2="15" y2="0"></line>
  </g>
  <!-- 3 · Lionshield Coster -->
  <g transform="translate(310 351) rotate(10)">
    <rect class="sm-building" x="-14" y="-10" width="28" height="20" rx="1.5"></rect>
    <line class="sm-roofline" x1="-11" y1="0" x2="11" y2="0"></line>
  </g>
  <!-- 4 · Phandalin Miner's Exchange (pyramid roof) -->
  <g transform="translate(299 434)">
    <rect class="sm-building" x="-13" y="-13" width="26" height="26" rx="1.5"></rect>
    <path class="sm-roofline" d="M-13 -13 L13 13 M13 -13 L-13 13"></path>
  </g>
  <!-- 5 · Townmaster's Hall -->
  <g transform="translate(392 342) rotate(-4)">
    <rect class="sm-building" x="-17" y="-11" width="34" height="22" rx="1.5"></rect>
    <line class="sm-roofline" x1="-14" y1="0" x2="14" y2="0"></line>
  </g>
  <!-- 6 · Harbin Wester's home -->
  <g transform="translate(477 369) rotate(-6)">
    <rect class="sm-building" x="-12" y="-8" width="24" height="16" rx="1.5"></rect>
    <line class="sm-roofline" x1="-9" y1="0" x2="9" y2="0"></line>
  </g>
  <!-- 7 · Shrine of Luck -->
  <g transform="translate(351 266)">
    <rect class="sm-building" x="-6" y="-6" width="12" height="12" rx="1"></rect>
  </g>

  <!-- Numbered points of interest -->
  <g class="sm-poi" data-tip-title="Stonehill Inn" data-tip-sub="Rooms, stew, and one watchful stranger">
    <circle cx="407" cy="245" r="8"></circle><text x="407" y="245">1</text>
  </g>
  <g class="sm-poi" data-tip-title="Barthen's Provisions" data-tip-sub="General goods">
    <circle cx="486" cy="196" r="8"></circle><text x="486" y="196">2</text>
  </g>
  <g class="sm-poi" data-tip-title="Lionshield Coster" data-tip-sub="Arms and armor">
    <circle cx="288" cy="362" r="8"></circle><text x="288" y="362">3</text>
  </g>
  <g class="sm-poi danger" data-tip-title="Phandalin Miner's Exchange" data-tip-sub="Guildmaster Thornton. Mind the crossbows.">
    <circle cx="277" cy="420" r="8"></circle><text x="277" y="420">4</text>
  </g>
  <g class="sm-poi" data-tip-title="Townmaster's Hall" data-tip-sub="Harbin's office, behind several bolts">
    <circle cx="392" cy="322" r="8"></circle><text x="392" y="322">5</text>
  </g>
  <g class="sm-poi" data-tip-title="Harbin Wester's home" data-tip-sub="Site of Bean's unauthorized visit">
    <circle cx="499" cy="380" r="8"></circle><text x="499" y="380">6</text>
  </g>
  <g class="sm-poi" data-tip-title="Shrine of Luck" data-tip-sub="Tymora's small shrine on the square">
    <circle cx="351" cy="248" r="8"></circle><text x="351" y="248">7</text>
  </g>

  <!-- Road notes -->
  <text class="sm-note" x="488" y="46">To the Triboar Trail</text>
  <text class="sm-note" x="60" y="612">Miners' Trail</text>

  <!-- Scale -->
  <g class="sm-scale" transform="translate(740 622)">
    <line x1="0" y1="0" x2="100" y2="0"></line>
    <line x1="0" y1="-4" x2="0" y2="4"></line>
    <line x1="100" y1="-4" x2="100" y2="4"></line>
    <text x="50" y="-8">≈ 200 feet</text>
  </g>

  <!-- Compass -->
  <g class="m-compass" transform="translate(64 84)">
    <circle r="18"></circle>
    <line x1="0" y1="13" x2="0" y2="-9"></line>
    <path class="m-compass-arrow" d="M0 -16 L5 -5 L0 -8 L-5 -5 Z"></path>
    <text y="-25">N</text>
  </g>
</g>
