---
// Local map of Phandalin, traced 1-to-1 from the official town map
// (offical-assets/Maps/map-00.04-phandalin.jpg — reference only). Feature
// positions are measured against that scan on a 900 × 646 grid (the scan's
// exact aspect); only the rendering style departs from the original.
// North is up; the scale bar reads ≈ 200 feet.

// Deterministic small-integer noise for organic contours.
function makeRnd(seed: number) {
  return () => ((seed = (seed * 1103515245 + 12345) & 0x7fffffff) / 0x7fffffff);
}

// A closed, slightly irregular contour ring (points list).
function blob(cx: number, cy: number, rx: number, ry: number, rot: number, seed: number): string {
  const rnd = makeRnd(seed);
  const n = 14;
  const rad = (rot * Math.PI) / 180;
  const cos = Math.cos(rad), sin = Math.sin(rad);
  const pts: string[] = [];
  for (let i = 0; i < n; i++) {
    const a = (i / n) * Math.PI * 2;
    const j = 0.9 + rnd() * 0.2;
    const ex = Math.cos(a) * rx * j;
    const ey = Math.sin(a) * ry * j;
    pts.push(`${(cx + ex * cos - ey * sin).toFixed(1)},${(cy + ex * sin + ey * cos).toFixed(1)}`);
  }
  return pts.join(' ');
}

// --- Rolling-hill contours: [cx, cy, rx, ry, rot, rings, seed] ---
const hills: [number, number, number, number, number, number, number][] = [
  [298, 230, 110, 74, -12, 3, 11], [612, 202, 96, 62, 8, 3, 22],
  [728, 268, 68, 48, -18, 2, 33], [184, 320, 60, 44, 20, 2, 44],
  [452, 150, 58, 38, -8, 2, 55], [614, 470, 90, 52, 10, 2, 66],
  [706, 522, 80, 46, -8, 2, 77], [500, 548, 70, 42, 14, 2, 88],
  [298, 428, 54, 40, 0, 1, 99],
];

// --- Unnamed houses: [x, y, w, h, rot] ---
const houses: [number, number, number, number, number][] = [
  // Triboar road / Barthen's cluster (north)
  [536, 132, 34, 18, 22], [510, 176, 56, 12, -4], [502, 164, 20, 14, 12],
  [511, 213, 38, 30, 8], [505, 262, 26, 16, -12], [531, 256, 20, 14, 6],
  [561, 192, 24, 16, 18], [586, 205, 18, 13, 30], [604, 202, 16, 10, 25],
  // Town centre — north side
  [396, 296, 26, 16, -6], [476, 289, 28, 18, -14], [440, 300, 24, 16, 8],
  [500, 300, 26, 18, -18], [540, 292, 26, 16, -20],
  // Town centre — east row
  [561, 320, 24, 16, -22], [600, 300, 28, 18, -25],
  // West / Lionshield approach
  [270, 340, 26, 16, -6], [230, 346, 24, 15, -8], [282, 380, 26, 18, -10],
  // The lane south of the square
  [352, 378, 42, 16, -6], [360, 398, 16, 10, -8], [340, 408, 14, 10, 10],
  [450, 390, 24, 15, 10],
  // Around the Miner's Exchange / south-west
  [290, 456, 22, 16, -14], [307, 464, 20, 14, 6], [178, 486, 30, 20, -8],
  [193, 588, 28, 20, 10],
  // Harbin / south-east
  [561, 356, 26, 16, -18], [540, 416, 26, 16, -8], [576, 426, 20, 14, 6],
  [486, 401, 24, 15, 10], [561, 462, 18, 12, 20],
];

// --- The natural tree stand west of the square: irregular clump ---
const treeStand: [number, number][] = [
  [268, 262], [300, 256], [332, 262], [262, 288], [292, 284], [324, 286],
  [356, 282], [280, 312], [312, 308], [344, 310], [372, 306], [298, 336],
  [330, 334], [360, 334], [316, 356], [346, 356],
];

// --- Scattered lone trees: [x, y, r] ---
const trees: [number, number, number][] = [
  [392, 176, 8], [300, 165, 7], [430, 112, 7], [536, 250, 8],
  [330, 396, 8], [280, 430, 7], [456, 396, 7], [312, 470, 8],
  [782, 346, 11], [806, 362, 12], [836, 336, 10], [870, 326, 9],
  [760, 376, 10], [700, 402, 8], [652, 546, 8], [240, 600, 7], [352, 470, 6],
];

// --- The dense wood filling the south-east ---
const forestPoly: [number, number][] = [
  [726, 352], [700, 384], [684, 426], [690, 468], [712, 524], [752, 560],
  [794, 572], [894, 576], [894, 344], [842, 338], [790, 344], [754, 348],
];
const forestPath = 'M ' + forestPoly.map(([x, y]) => `${x} ${y}`).join(' L ') + ' Z';
function inPoly(x: number, y: number, poly: [number, number][]) {
  let c = false;
  for (let i = 0, j = poly.length - 1; i < poly.length; j = i++) {
    const [xi, yi] = poly[i], [xj, yj] = poly[j];
    if (yi > y !== yj > y && x < ((xj - xi) * (y - yi)) / (yj - yi) + xi) c = !c;
  }
  return c;
}
const forest: [number, number, number][] = [];
{
  const rnd = makeRnd(20240707);
  for (let gx = 686; gx <= 894; gx += 18) {
    for (let gy = 344; gy <= 576; gy += 18) {
      const x = gx + (rnd() - 0.5) * 16, y = gy + (rnd() - 0.5) * 16;
      if (inPoly(x, y, forestPoly)) forest.push([x, y, 8 + rnd() * 4]);
    }
  }
}

// --- Plowed fields: [cx, cy, halfW, rows, rot] (furrow hachures) ---
const fields: { cx: number; cy: number; w: number; rows: number; rot: number }[] = [
  { cx: 206, cy: 600, w: 96, rows: 6, rot: 14 },
  { cx: 396, cy: 604, w: 70, rows: 5, rot: -8 },
  { cx: 548, cy: 424, w: 78, rows: 7, rot: -22 },
];
---

<g class="submap-phandalin" aria-hidden="true">
  <rect class="sm-ground" x="0" y="0" width="900" height="646"></rect>

  <!-- Rolling grassland hills as soft concentric contours -->
  <g class="sm-contour">
    {hills.map(([cx, cy, rx, ry, rot, rings, seed]) =>
      Array.from({ length: rings }, (_, i) => {
        const k = 1 - i / (rings + 0.7);
        return <polygon points={blob(cx, cy, rx * k, ry * k, rot, seed + i)} />;
      })
    )}
  </g>

  <!-- Stream in the north-west corner -->
  <path
    class="m-river"
    d="M 24 262 C 90 250 128 300 168 320 C 206 338 236 312 268 276 C 288 252 296 224 300 206"
    style="stroke-width:2;"></path>

  <!-- Streets -->
  <g class="sm-street">
    <!-- Triboar Trail down into the square -->
    <path d="M 476 116 C 466 152 452 202 442 250 C 434 278 424 292 412 302"></path>
    <!-- Square down to the Miners' Trail (south-west) -->
    <path d="M 412 302 C 388 336 356 380 330 424 C 306 464 280 520 250 566 C 236 590 224 606 212 624"></path>
    <!-- East road out of the square -->
    <path d="M 428 302 C 480 312 542 318 598 322 C 650 326 682 346 696 388"></path>
    <!-- The lane east from Barthen's toward the ridge -->
    <path d="M 452 214 C 500 196 556 190 606 202 C 642 212 660 226 668 244"></path>
    <!-- West approach past Lionshield -->
    <path d="M 150 336 C 224 320 296 314 352 306"></path>
  </g>
  <circle class="sm-plaza" cx="410" cy="302" r="15"></circle>

  <!-- Plowed fields -->
  <g class="sm-field">
    {fields.map((f) =>
      Array.from({ length: f.rows }, (_, i) => (
        <path
          d={`M ${-f.w} ${(i - (f.rows - 1) / 2) * 8} h ${f.w * 2}`}
          transform={`translate(${f.cx} ${f.cy}) rotate(${f.rot})`}
        />
      ))
    )}
  </g>

  <!-- The south-east wood -->
  <path class="sm-canopy" d={forestPath}></path>
  <g>
    {forest.map(([x, y, r]) => (
      <circle class="sm-tree" cx={x} cy={y} r={r} />
    ))}
  </g>

  <!-- The natural tree stand and scattered lone trees -->
  <g>
    {treeStand.map(([x, y]) => (
      <circle class="sm-tree" cx={x} cy={y} r="9" />
    ))}
    {trees.map(([x, y, r]) => (
      <circle class="sm-tree" cx={x} cy={y} r={r} />
    ))}
  </g>

  <!-- The eastern ridge and ravine, with the ruined manor above it -->
  <g class="sm-cliff">
    <path d="M 812 300 C 826 348 840 400 842 452 C 844 500 836 548 826 588"></path>
    <path d="M 846 292 C 862 342 874 398 876 452 C 878 506 868 556 856 596"></path>
    {[320, 360, 400, 440, 480, 520, 560].map((y) => (
      <path d={`M ${814 + (y - 320) * 0.06} ${y} l 8 3`} />
    ))}
  </g>
  <g class="sm-detail">
    <path d="M 812 268 l 20 -4 l 2 10 l -14 3 M 826 292 l 18 -5 M 808 310 l 12 -3 l 3 9"></path>
  </g>
  <text class="sm-note" x="840" y="284">old ruins</text>

  <!-- Unnamed houses -->
  <g>
    {houses.map(([x, y, w, h, r]) => (
      <g transform={`translate(${x} ${y}) rotate(${r})`}>
        <rect class="sm-building" x={-w / 2} y={-h / 2} width={w} height={h} rx="1.5" />
        <line class="sm-roofline" x1={-w / 2 + 2} y1="0" x2={w / 2 - 2} y2="0" />
      </g>
    ))}
  </g>

  <!-- Named buildings -->
  <!-- 2 · Barthen's Provisions (cross-plan) -->
  <g transform="translate(467 204) rotate(-6)">
    <rect class="sm-building" x="-21" y="-15" width="42" height="44" rx="1.5"></rect>
    <rect class="sm-building" x="-13" y="-29" width="26" height="16" rx="1.5"></rect>
    <path class="sm-roofline" d="M-19 7 H19 M0 -27 V26"></path>
  </g>
  <!-- 1 · Stonehill Inn -->
  <g transform="translate(428 264) rotate(-20)">
    <rect class="sm-building" x="-24" y="-17" width="48" height="34" rx="1.5"></rect>
    <line class="sm-roofline" x1="-20" y1="0" x2="20" y2="0"></line>
  </g>
  <!-- 5 · Townmaster's Hall -->
  <g transform="translate(386 325) rotate(-3)">
    <rect class="sm-building" x="-23" y="-13" width="46" height="26" rx="1.5"></rect>
    <line class="sm-roofline" x1="-19" y1="0" x2="19" y2="0"></line>
  </g>
  <!-- 3 · Lionshield Coster -->
  <g transform="translate(311 329) rotate(-14)">
    <rect class="sm-building" x="-22" y="-17" width="44" height="34" rx="1.5"></rect>
    <line class="sm-roofline" x1="-18" y1="0" x2="18" y2="0"></line>
  </g>
  <!-- 6 · Harbin Wester's home -->
  <g transform="translate(458 356) rotate(8)">
    <rect class="sm-building" x="-22" y="-16" width="44" height="32" rx="1.5"></rect>
    <line class="sm-roofline" x1="-18" y1="0" x2="18" y2="0"></line>
  </g>
  <!-- 4 · Phandalin Miner's Exchange (walled, pyramid roof) -->
  <g transform="translate(298 425)">
    <rect class="sm-building" x="-18" y="-17" width="36" height="34" rx="1.5"></rect>
    <path class="sm-roofline" d="M-18 -17 L18 17 M18 -17 L-18 17"></path>
  </g>
  <!-- 7 · Shrine of Luck -->
  <g transform="translate(322 256)">
    <rect class="sm-building" x="-7" y="-7" width="14" height="14" rx="1"></rect>
  </g>

  <!-- Numbered points of interest -->
  <g class="sm-poi" data-tip-title="Stonehill Inn" data-tip-sub="Rooms, stew, and one watchful stranger">
    <circle cx="428" cy="238" r="8"></circle><text x="428" y="238">1</text>
  </g>
  <g class="sm-poi" data-tip-title="Barthen's Provisions" data-tip-sub="General goods">
    <circle cx="492" cy="188" r="8"></circle><text x="492" y="188">2</text>
  </g>
  <g class="sm-poi" data-tip-title="Lionshield Coster" data-tip-sub="Arms and armor">
    <circle cx="286" cy="329" r="8"></circle><text x="286" y="329">3</text>
  </g>
  <g class="sm-poi danger" data-tip-title="Phandalin Miner's Exchange" data-tip-sub="Guildmaster Thornton. Mind the crossbows.">
    <circle cx="274" cy="425" r="8"></circle><text x="274" y="425">4</text>
  </g>
  <g class="sm-poi" data-tip-title="Townmaster's Hall" data-tip-sub="Harbin's office, behind several bolts">
    <circle cx="386" cy="348" r="8"></circle><text x="386" y="348">5</text>
  </g>
  <g class="sm-poi" data-tip-title="Harbin Wester's home" data-tip-sub="Site of Bean's unauthorized visit">
    <circle cx="484" cy="360" r="8"></circle><text x="484" y="360">6</text>
  </g>
  <g class="sm-poi" data-tip-title="Shrine of Luck" data-tip-sub="Tymora's small shrine on the square">
    <circle cx="322" cy="238" r="8"></circle><text x="322" y="238">7</text>
  </g>

  <!-- Road notes -->
  <text class="sm-note" x="486" y="102">To the Triboar Trail</text>
  <text class="sm-note" x="238" y="576">Miners' Trail</text>

  <!-- Scale -->
  <g class="sm-scale" transform="translate(650 612)">
    <line x1="0" y1="0" x2="100" y2="0"></line>
    <line x1="0" y1="-4" x2="0" y2="4"></line>
    <line x1="100" y1="-4" x2="100" y2="4"></line>
    <text x="50" y="-8">≈ 200 feet</text>
  </g>

  <!-- Compass (bottom-left, as on the official town map) -->
  <g class="m-compass" transform="translate(150 466)">
    <circle r="18"></circle>
    <line x1="0" y1="13" x2="0" y2="-9"></line>
    <path class="m-compass-arrow" d="M0 -16 L5 -5 L0 -8 L-5 -5 Z"></path>
    <text y="-25">N</text>
  </g>
</g>
