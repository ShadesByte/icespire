---
// Local map of the Dragon Barrow, drawn from the official map's layout
// (offical-assets/Maps/map-04.02-dragon-barrow.jpg — reference only).
// A burial mound shaped like spread wings, and the catacombs beneath it.
// viewBox 900 × 560; north is up.

// Spine stones running down the mound's crest as [x, y].
const spineStones: [number, number][] = [
  [252, 130], [248, 170], [246, 210], [250, 250], [254, 292], [258, 332], [264, 370],
];

// Sarcophagus niches in the catacombs as [x, y, rot].
const tombs: [number, number, number][] = [
  [612, 92, 0], [668, 92, 0], [500, 262, 0], [556, 262, 0],
  [500, 342, 0], [556, 342, 0], [788, 302, 90], [842, 302, 90],
  [788, 366, 0], [842, 366, 0],
];

// Trap marks (⊠) as [x, y].
const traps: [number, number][] = [[640, 172], [586, 302], [658, 356]];
---

<g class="submap-dragonbarrow" aria-hidden="true">
  <rect class="sm-ground" x="0" y="0" width="450" height="560"></rect>
  <rect class="sm-rock" x="450" y="0" width="450" height="560" style="stroke:none;"></rect>
  <text class="sm-note" x="475" y="36">Catacombs</text>
  <text class="sm-note" x="60" y="530">Burial mound</text>

  <!-- The mound: a shape like spread wings -->
  <g class="sm-contour" style="opacity: .55;">
    <path d="M 250 90
             C 180 80 120 120 96 180 C 80 222 100 250 140 258
             C 100 290 76 340 92 390 C 108 438 160 452 204 432
             C 220 470 260 490 300 474 C 344 458 360 420 348 380
             C 392 372 420 336 412 296 C 404 258 368 238 330 244
             C 348 196 330 140 290 112 C 276 100 262 92 250 90 Z"></path>
    <path d="M 250 130 C 200 126 158 156 146 196 C 138 226 152 246 180 252
             C 150 278 136 314 148 350 C 160 384 198 396 230 382
             C 244 410 276 422 304 410 C 336 396 346 368 336 338
             C 368 330 388 302 382 272 C 376 246 350 232 322 236
             C 334 200 320 160 290 140 C 278 132 264 130 250 130 Z"></path>
    <path d="M 250 170 C 216 168 190 190 184 218 C 180 240 192 254 212 258
             C 192 278 184 304 194 330 C 204 354 232 362 254 352
             C 264 372 288 380 308 372 C 330 362 336 340 328 320
             C 350 314 362 294 358 274 C 354 254 336 244 316 248
             C 324 222 314 192 292 178 C 280 172 264 170 250 170 Z"></path>
  </g>
  <text class="sm-note" x="88" y="150">+10 ft.</text>
  <text class="sm-note" x="146" y="190">+20 ft.</text>
  <text class="sm-note" x="196" y="228">+30 ft.</text>

  <!-- Spine stones -->
  <g>
    {spineStones.map(([x, y]) => (
      <rect class="sm-rock" x={x - 3} y={y - 6} width="6" height="12" rx="2" transform={`rotate(8 ${x} ${y})`} />
    ))}
  </g>

  <!-- Secret entrance -->
  <circle class="sm-inner" cx="256" cy="310" r="10" style="stroke-dasharray: 3 3;"></circle>

  <!-- Catacomb halls -->
  {
    [0, 1].map((pass) => (
      <g class={pass === 0 ? 'sm-hall-wall' : 'sm-hall'}>
        <path d="M 640 130 L 640 210" />
        <path d="M 528 302 L 610 302" />
        <path d="M 668 270 L 668 302 L 815 302" />
        <path d="M 640 240 L 640 270" />
        <path d="M 658 330 L 658 388" />
        <path d="M 690 330 C 710 322 720 336 736 330" />
      </g>
    ))
  }

  <!-- Catacomb chambers -->
  <rect class="sm-floor" x="596" y="52" width="88" height="80" rx="10"></rect>
  <ellipse class="sm-floor" cx="640" cy="240" rx="46" ry="34"></ellipse>
  <rect class="sm-floor" x="478" y="244" width="100" height="118" rx="6"></rect>
  <rect class="sm-floor" x="764" y="282" width="102" height="104" rx="6"></rect>
  <rect class="sm-floor" x="630" y="330" width="56" height="58" rx="6"></rect>

  <!-- Spiral stair at the heart of the catacombs -->
  <g class="sm-detail" transform="translate(640 240)">
    <circle r="9"></circle>
    <path d="M0 0 L9 0 M0 0 L-6 6 M0 0 L-3 -8"></path>
  </g>

  <!-- Tombs -->
  <g>
    {tombs.map(([x, y, r]) => (
      <rect class="sm-inner" x={x - 8} y={y - 5} width="16" height="10" rx="1" transform={`rotate(${r} ${x} ${y})`} />
    ))}
  </g>

  <!-- Traps -->
  <g class="sm-detail">
    {traps.map(([x, y]) => (
      <g transform={`translate(${x} ${y})`}>
        <rect x="-5" y="-5" width="10" height="10" />
        <path d="M-5 -5 L5 5 M5 -5 L-5 5" />
      </g>
    ))}
  </g>

  <!-- Numbered points of interest -->
  <g class="sm-poi" data-tip-title="The burial mound" data-tip-sub="Shaped like something with wings">
    <circle cx="150" cy="90" r="8"></circle><text x="150" y="90">1</text>
  </g>
  <g class="sm-poi" data-tip-title="Secret entrance" data-tip-sub="Hidden among the spine-stones">
    <circle cx="284" cy="310" r="8"></circle><text x="284" y="310">2</text>
  </g>
  <g class="sm-poi" data-tip-title="The catacombs" data-tip-sub="A spiral stair at the heart of it">
    <circle cx="688" cy="240" r="8"></circle><text x="688" y="240">3</text>
  </g>
  <g class="sm-poi" data-tip-title="Tomb chambers" data-tip-sub="Sarcophagi in the alcoves">
    <circle cx="528" cy="230" r="8"></circle><text x="528" y="230">4</text>
  </g>
  <g class="sm-poi danger" data-tip-title="Warded corridors" data-tip-sub="Old traps, still armed">
    <circle cx="640" cy="160" r="8"></circle><text x="640" y="160">5</text>
  </g>

  <!-- Scale -->
  <g class="sm-scale" transform="translate(742 530)">
    <line x1="0" y1="0" x2="110" y2="0"></line>
    <line x1="0" y1="-4" x2="0" y2="4"></line>
    <line x1="110" y1="-4" x2="110" y2="4"></line>
    <text x="55" y="-8">≈ 60 feet</text>
  </g>

  <!-- Compass -->
  <g class="m-compass" transform="translate(846 66)">
    <circle r="18"></circle>
    <line x1="0" y1="13" x2="0" y2="-9"></line>
    <path class="m-compass-arrow" d="M0 -16 L5 -5 L0 -8 L-5 -5 Z"></path>
    <text y="-25">N</text>
  </g>
</g>
