---
// Local map of the Shrine of Savras, drawn from the official map's layout
// (offical-assets/Maps/map-11.02-shrine-of-savras.jpg — reference only).
// A walled compound gone to ruin around a cross-shaped shrine.
// viewBox 900 × 560; north is up.

// Broken outer-wall segments.
const walls = [
  'M 205 92 L 400 92', 'M 505 92 L 700 92',
  'M 172 130 L 172 300', 'M 172 340 L 172 476',
  'M 732 130 L 732 260', 'M 732 305 L 732 476',
  'M 205 512 L 380 512', 'M 430 512 L 700 512',
];

// Rubble along the wall lines as [x, y].
const rubble: [number, number][] = [
  [300, 92], [610, 92], [172, 200], [172, 420], [732, 200], [732, 420],
  [300, 512], [560, 512], [410, 92], [405, 512], [172, 320], [732, 282],
];

// Nave columns as [x, y].
const columns: [number, number][] = [
  [420, 232], [480, 232], [420, 268], [480, 268], [420, 342], [480, 342], [420, 378], [480, 378],
];
---

<g class="submap-shrineofsavras" aria-hidden="true">
  <rect class="sm-ground" x="0" y="0" width="900" height="560"></rect>

  <!-- Approach from the Triboar Trail -->
  <path class="sm-path" d="M 450 10 L 450 70"></path>

  <!-- Ruined outer wall -->
  <g class="sm-detail" style="stroke-width: 5; opacity: .9;">
    {walls.map((d) => (
      <path d={d} />
    ))}
  </g>
  {
    rubble.map(([x, y]) => (
      <g class="sm-detail">
        <circle cx={x} cy={y} r="2.8" />
        <circle cx={x + 6} cy={y + 3} r="2.2" />
        <circle cx={x - 5} cy={y + 4} r="2" />
      </g>
    ))
  }

  <!-- Corner towers: only the northeast one stands whole -->
  <circle class="sm-rock" cx="732" cy="92" r="26"></circle>
  <g class="sm-cliff" style="stroke-width: 2;">
    <path d="M 148 68 A 26 26 0 1 0 196 110"></path>
    <path d="M 150 534 A 26 26 0 0 1 194 490"></path>
    <path d="M 756 534 A 26 26 0 0 1 710 492"></path>
  </g>

  <!-- Gatehouse -->
  <rect class="sm-rock" x="412" y="72" width="76" height="40" rx="3"></rect>
  <path class="sm-hall" d="M 450 74 L 450 110" style="stroke-width: 12;"></path>
  <line class="sm-detail" x1="443" y1="104" x2="457" y2="104" stroke-dasharray="2 2"></line>

  <!-- The shrine: a cross-shaped hall -->
  <rect class="sm-floor" x="404" y="210" width="92" height="186" rx="4"></rect>
  <rect class="sm-floor" x="330" y="272" width="86" height="56" rx="4"></rect>
  <rect class="sm-floor" x="484" y="272" width="86" height="56" rx="4"></rect>
  <path class="sm-floor" d="M 424 394 A 26 26 0 0 0 476 394 Z"></path>

  <!-- Columns and the belfry hole -->
  <g class="sm-inner">
    {columns.map(([x, y]) => (
      <circle cx={x} cy={y} r="3.4" />
    ))}
    <rect x="432" y="288" width="36" height="34" style="stroke-dasharray: 4 3;"></rect>
  </g>

  <!-- Benches in the wings -->
  <g class="sm-inner">
    <rect x="344" y="286" width="18" height="6" rx="1"></rect>
    <rect x="344" y="308" width="18" height="6" rx="1"></rect>
    <rect x="538" y="286" width="18" height="6" rx="1"></rect>
    <rect x="538" y="308" width="18" height="6" rx="1"></rect>
  </g>

  <!-- Doors -->
  <g class="sm-door">
    <rect x="445" y="206" width="10" height="6"></rect>
    <rect x="445" y="392" width="10" height="6"></rect>
    <rect x="326" y="296" width="6" height="9"></rect>
    <rect x="568" y="296" width="6" height="9"></rect>
  </g>

  <!-- Courtyard labels -->
  <text class="sm-note" x="240" y="200">courtyard</text>
  <text class="sm-note" x="600" y="452">courtyard</text>
  <text class="sm-note" x="270" y="548">15-foot outer wall, ruined</text>

  <!-- Numbered points of interest -->
  <g class="sm-poi" data-tip-title="The gatehouse" data-tip-sub="The old north gate">
    <circle cx="500" cy="66" r="8"></circle><text x="500" y="66">1</text>
  </g>
  <g class="sm-poi" data-tip-title="The shrine" data-tip-sub="A cross-shaped hall to the All-Seeing">
    <circle cx="450" cy="186" r="8"></circle><text x="450" y="186">2</text>
  </g>
  <g class="sm-poi" data-tip-title="The belfry hole" data-tip-sub="A gap in the ceiling — a way up, or down">
    <circle cx="478" cy="305" r="8"></circle><text x="478" y="305">3</text>
  </g>
  <g class="sm-poi danger" data-tip-title="The standing tower" data-tip-sub="The only whole corner. Occupied?">
    <circle cx="732" cy="60" r="8"></circle><text x="732" y="60">4</text>
  </g>

  <!-- Scale -->
  <g class="sm-scale" transform="translate(60 62)">
    <line x1="0" y1="0" x2="110" y2="0"></line>
    <line x1="0" y1="-4" x2="0" y2="4"></line>
    <line x1="110" y1="-4" x2="110" y2="4"></line>
    <text x="55" y="-8">≈ 60 feet</text>
  </g>

  <!-- Compass -->
  <g class="m-compass" transform="translate(846 490)">
    <circle r="18"></circle>
    <line x1="0" y1="13" x2="0" y2="-9"></line>
    <path class="m-compass-arrow" d="M0 -16 L5 -5 L0 -8 L-5 -5 Z"></path>
    <text y="-25">N</text>
  </g>
</g>
