---
// Local map of Umbrage Hill, drawn from the official map's layout
// (offical-assets/Maps/map-13.02-umbrage-hill.jpg — reference only).
// Adabra Gwynn's windmill on its knoll, the ruined outbuilding beside it,
// and the boulder field on the high ground southeast. viewBox 900 × 570;
// north is up.

// Boulder clusters as [x, y].
const boulders: [number, number][] = [
  [640, 470], [700, 445], [755, 470], [690, 505], [745, 515],
  [795, 495], [650, 530], [720, 545],
];

// The fence ring around the windmill yard (dashed), with a gate gap east.
const fencePoints: string = (() => {
  const pts: string[] = [];
  for (let a = 30; a <= 330; a += 15) {
    const rad = (a * Math.PI) / 180;
    const r = 78 + (a % 45 === 0 ? 5 : 0);
    pts.push(`${(300 + Math.cos(rad) * r).toFixed(1)},${(390 + Math.sin(rad) * r).toFixed(1)}`);
  }
  return pts.join(' ');
})();
---

<g class="submap-umbrage" aria-hidden="true">
  <rect class="sm-ground" x="0" y="0" width="900" height="570"></rect>

  <!-- Contours climbing toward the southeast heights -->
  <g class="sm-contour">
    <path d="M 80 60 C 300 120 600 130 880 170"></path>
    <path d="M 60 200 C 300 262 620 250 885 300"></path>
    <path d="M 40 360 C 150 430 240 505 420 486 C 600 462 740 428 890 430"></path>
    <path d="M 60 528 C 300 560 560 502 895 520"></path>
    <path d="M 560 570 C 580 480 700 430 810 460 C 880 480 892 530 872 570"></path>
    <!-- The windmill's knoll -->
    <path d="M 300 292 C 372 300 410 348 402 396 C 394 448 350 480 296 476 C 236 472 196 430 202 384 C 208 336 244 296 300 292 Z"></path>
  </g>
  <text class="sm-note" x="836" y="158">+0 ft.</text>
  <text class="sm-note" x="840" y="288">+10 ft.</text>
  <text class="sm-note" x="846" y="418">+20 ft.</text>
  <text class="sm-note" x="842" y="506">+30 ft.</text>
  <text class="sm-note" x="614" y="502">+40 ft.</text>

  <!-- The trail up from Phandalin, arriving at the yard gate -->
  <path class="sm-path" d="M 60 60 C 160 130 240 200 298 264 C 330 300 344 340 347 384"></path>

  <!-- Grass tufts -->
  <g class="sm-grass">
    {[
      [150, 160], [260, 110], [420, 90], [560, 140], [680, 100], [790, 230],
      [130, 300], [190, 420], [120, 480], [480, 250], [590, 300], [700, 360],
      [480, 540], [300, 530], [550, 430], [820, 380], [420, 170], [640, 220],
    ].map(([x, y]) => (
      <path d="M-5 0 L-3 -6 M0 0 L0 -7 M5 0 L3 -6" transform={`translate(${x} ${y})`} />
    ))}
  </g>

  <!-- Fence around the yard -->
  <polyline class="sm-fence" points={fencePoints}></polyline>

  <!-- The windmill: walled yard, tower, sails -->
  <rect class="sm-floor" x="262" y="352" width="76" height="76" rx="3"></rect>
  <g class="sm-detail">
    <line x1="274" y1="364" x2="326" y2="416"></line>
    <line x1="326" y1="364" x2="274" y2="416"></line>
  </g>
  <circle class="sm-building" cx="300" cy="390" r="14"></circle>
  <circle class="sm-detail-fill" cx="300" cy="390" r="2.5" style="stroke:none;"></circle>
  <!-- Yard gate east -->
  <rect class="sm-door" x="334" y="386" width="6" height="9"></rect>

  <!-- Ruined outbuilding and old garden walls -->
  <g class="sm-detail" style="stroke-width: 2.4;">
    <path d="M 370 415 L 398 415 L 398 442"></path>
    <path d="M 372 452 L 390 452"></path>
    <path d="M 408 462 L 408 478"></path>
  </g>
  <rect class="sm-building" x="371" y="366" width="15" height="11" rx="1"></rect>
  <g class="sm-detail">
    <circle cx="404" cy="425" r="2.4"></circle>
    <circle cx="382" cy="462" r="2.1"></circle>
    <circle cx="414" cy="450" r="2.2"></circle>
  </g>

  <!-- The boulder field -->
  <g>
    {boulders.map(([x, y]) => (
      <g class="sm-rock">
        <circle cx={x} cy={y} r="5.5" />
        <circle cx={x + 8} cy={y + 4} r="4" />
        <circle cx={x - 6} cy={y + 6} r="3.4" />
      </g>
    ))}
  </g>

  <!-- Numbered points of interest -->
  <g class="sm-poi" data-tip-title="Adabra Gwynn's windmill" data-tip-sub="The potions brew here and nowhere else">
    <circle cx="266" cy="342" r="8"></circle><text x="266" y="342">1</text>
  </g>
  <g class="sm-poi" data-tip-title="Ruined outbuilding" data-tip-sub="Old garden walls; good cover in the fight">
    <circle cx="422" cy="408" r="8"></circle><text x="422" y="408">2</text>
  </g>
  <g class="sm-poi danger" data-tip-title="The boulder field" data-tip-sub="Manticore country">
    <circle cx="700" cy="478" r="8"></circle><text x="700" y="478">3</text>
  </g>

  <!-- Scale -->
  <g class="sm-scale" transform="translate(430 545)">
    <line x1="0" y1="0" x2="125" y2="0"></line>
    <line x1="0" y1="-4" x2="0" y2="4"></line>
    <line x1="125" y1="-4" x2="125" y2="4"></line>
    <text x="62" y="-8">≈ 50 feet</text>
  </g>

  <!-- Compass -->
  <g class="m-compass" transform="translate(70 502)">
    <circle r="18"></circle>
    <line x1="0" y1="13" x2="0" y2="-9"></line>
    <path class="m-compass-arrow" d="M0 -16 L5 -5 L0 -8 L-5 -5 Z"></path>
    <text y="-25">N</text>
  </g>
</g>
