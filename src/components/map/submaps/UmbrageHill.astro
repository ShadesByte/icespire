---
// Local map of Umbrage Hill, traced 1-to-1 from the official map
// (offical-assets/Maps/map-13.02-umbrage-hill.jpg — reference only).
// Measured against that scan on a 900 × 573 grid (its exact aspect):
// Adabra Gwynn's windmill on its walled knoll, the ruined outbuilding
// beside it, the boulder field on the high ground to the south-east,
// and the elevation contours. Only the drawing style departs from the
// source. North is up.

function makeRnd(seed: number) {
  return () => ((seed = (seed * 1103515245 + 12345) & 0x7fffffff) / 0x7fffffff);
}
// A closed, slightly irregular contour ring (points list).
function blob(cx: number, cy: number, rx: number, ry: number, rot: number, seed: number): string {
  const rnd = makeRnd(seed);
  const n = 22;
  const rad = (rot * Math.PI) / 180, cos = Math.cos(rad), sin = Math.sin(rad);
  const pts: string[] = [];
  for (let i = 0; i < n; i++) {
    const a = (i / n) * Math.PI * 2;
    const j = 0.92 + rnd() * 0.16;
    const ex = Math.cos(a) * rx * j, ey = Math.sin(a) * ry * j;
    pts.push(`${(cx + ex * cos - ey * sin).toFixed(1)},${(cy + ex * sin + ey * cos).toFixed(1)}`);
  }
  return pts.join(' ');
}

// Concentric hill contours: [cx, cy, rx, ry, rot, rings, seed].
const hills: [number, number, number, number, number, number, number][] = [
  [258, 200, 206, 128, -8, 4, 7],   // the broad hill north-west
  [322, 388, 152, 128, 6, 3, 19],   // the windmill knoll
];

// The low wall ringing the windmill yard (beaded), with a gap at the top.
const fenceRing: [number, number][] = [
  [320, 272], [360, 285], [395, 305], [425, 330], [445, 360], [452, 395],
  [448, 428], [432, 462], [405, 488], [368, 502], [330, 505], [292, 498],
  [258, 478], [232, 448], [216, 412], [212, 378], [218, 342], [238, 312],
  [268, 288],
];

// Boulder clusters of the field (U1): [x, y].
const boulders: [number, number][] = [
  [590, 470], [645, 450], [716, 465], [615, 505], [686, 510], [746, 500],
  [566, 537], [650, 545], [700, 556],
];

// Grass tufts.
const grass: [number, number][] = [
  [140, 160], [240, 110], [430, 120], [560, 150], [700, 120], [810, 240],
  [120, 320], [180, 430], [110, 490], [500, 250], [610, 300], [720, 360],
  [490, 540], [300, 540], [560, 430], [830, 400], [430, 180], [640, 220],
  [850, 300], [780, 500],
];
---

<g class="submap-umbrage" aria-hidden="true">
  <rect class="sm-ground" x="0" y="0" width="900" height="573"></rect>

  <!-- Elevation contours: the knoll, the north-west hill, and the slope east -->
  <g class="sm-contour">
    {hills.map(([cx, cy, rx, ry, rot, rings, seed]) =>
      Array.from({ length: rings }, (_, i) => {
        const k = 1 - i / (rings + 0.5);
        return <polygon points={blob(cx, cy, rx * k, ry * k, rot, seed + i)} />;
      })
    )}
    <!-- The graded slope descending to the south-east -->
    <path d="M 895 224 C 800 234 700 222 600 238 C 520 250 460 250 470 232"></path>
    <path d="M 895 292 C 800 286 700 276 610 286 C 540 294 500 300 512 282"></path>
    <path d="M 895 362 C 800 352 704 336 632 332 C 580 330 548 336 556 320"></path>
    <path d="M 895 432 C 806 414 712 392 648 380 C 604 372 578 378 586 360"></path>
    <path d="M 895 500 C 812 470 726 436 660 426 C 616 420 598 428 608 408"></path>
    <!-- The boulder field's high ground -->
    <path d="M 560 573 C 566 512 640 470 720 486 C 800 502 828 546 812 573"></path>
  </g>
  <text class="sm-note" x="836" y="224">+0 ft.</text>
  <text class="sm-note" x="840" y="292">+10 ft.</text>
  <text class="sm-note" x="846" y="362">+20 ft.</text>
  <text class="sm-note" x="842" y="432">+30 ft.</text>
  <text class="sm-note" x="620" y="470">+40 ft.</text>

  <!-- Grass tufts -->
  <g class="sm-grass">
    {grass.map(([x, y]) => (
      <path d="M-5 0 L-3 -6 M0 0 L0 -7 M5 0 L3 -6" transform={`translate(${x} ${y})`} />
    ))}
  </g>

  <!-- The low wall ringing the yard (a gap at the top is the way in) -->
  <polyline class="sm-fence" points={fenceRing.map(([x, y]) => `${x},${y}`).join(' ')}></polyline>

  <!-- U3 · the windmill: walled yard, tower, millstone -->
  <rect class="sm-yardwall" x="267" y="337" width="78" height="78" rx="2"></rect>
  <rect class="sm-floor" x="277" y="347" width="58" height="58" rx="2"></rect>
  <rect class="sm-inner" x="285" y="354" width="43" height="44" rx="1"></rect>
  <circle class="sm-building" cx="308" cy="378" r="12"></circle>
  <g class="sm-detail">
    <path d="M 296 378 H 320 M 308 366 V 390 M 300 370 L 316 386 M 316 370 L 300 386"></path>
  </g>
  <circle class="sm-detail-fill" cx="308" cy="378" r="2.5" style="stroke:none;"></circle>
  <!-- Yard entrances -->
  <g class="sm-detail-fill" style="stroke:none;">
    <path d="M 289 337 l 8 0 l -4 6 Z"></path>
    <path d="M 317 337 l 8 0 l -4 6 Z"></path>
    <path d="M 345 358 l 0 8 l -6 -4 Z"></path>
    <path d="M 267 356 l 0 8 l 6 -4 Z"></path>
    <path d="M 289 415 l 8 0 l -4 -6 Z"></path>
    <path d="M 317 415 l 8 0 l -4 -6 Z"></path>
  </g>

  <!-- U2 · the ruined outbuilding and its broken garden walls -->
  <g class="sm-detail">
    <!-- the little hut with its dark doorway -->
    <path d="M 362 386 L 362 370 L 388 370 L 388 386" style="stroke-width:2.4;"></path>
    <path d="M 371 386 L 371 377 L 379 377 L 379 386" style="stroke-width:1.6;"></path>
  </g>
  <g class="sm-rubble">
    <!-- rubble linking the hut to the yard -->
    <path d="M 346 378 q 8 -4 16 0"></path>
    <!-- the broken garden enclosure -->
    <path d="M 388 380 L 410 384 L 408 424"></path>
    <path d="M 396 430 L 396 468 L 344 466 L 344 420"></path>
  </g>
  <g class="sm-detail">
    <circle cx="404" cy="404" r="2.2"></circle>
    <circle cx="360" cy="448" r="2"></circle>
    <circle cx="392" cy="452" r="2.1"></circle>
  </g>

  <!-- U1 · the boulder field -->
  <g>
    {boulders.map(([x, y]) => (
      <g class="sm-rock">
        <circle cx={x} cy={y} r="5.5" />
        <circle cx={x + 8} cy={y + 4} r="4" />
        <circle cx={x - 6} cy={y + 6} r="3.4" />
      </g>
    ))}
  </g>

  <!-- Inset: the windmill's upper floors, as on the official map -->
  <g transform="translate(492 38)">
    <rect class="sm-inset-frame" x="0" y="0" width="342" height="148" rx="3"></rect>
    <!-- Second floor -->
    <g transform="translate(88 58)">
      <rect class="sm-floor" x="-23" y="-23" width="46" height="46" rx="2"></rect>
      <rect class="sm-inner" x="-8" y="-31" width="16" height="8"></rect>
      <rect class="sm-inner" x="-8" y="23" width="16" height="8"></rect>
      <circle class="sm-building" cx="0" cy="0" r="6"></circle>
      <circle class="sm-detail-fill" cx="0" cy="0" r="1.6" style="stroke:none;"></circle>
    </g>
    <text class="sm-inset-label" x="88" y="126">Second floor</text>
    <!-- Third floor -->
    <g transform="translate(252 58)">
      <rect class="sm-floor" x="-21" y="-21" width="42" height="42" rx="2"></rect>
      <line class="sm-detail" x1="-31" y1="0" x2="9" y2="0"></line>
      <circle class="sm-building" cx="9" cy="0" r="5"></circle>
    </g>
    <text class="sm-inset-label" x="252" y="126">Third floor</text>
  </g>

  <!-- Numbered points of interest -->
  <g class="sm-poi" data-tip-title="Adabra Gwynn's windmill" data-tip-sub="The potions brew here and nowhere else">
    <circle cx="306" cy="326" r="8"></circle><text x="306" y="326">1</text>
  </g>
  <g class="sm-poi" data-tip-title="Ruined outbuilding" data-tip-sub="Old garden walls; good cover in the fight">
    <circle cx="418" cy="392" r="8"></circle><text x="418" y="392">2</text>
  </g>
  <g class="sm-poi danger" data-tip-title="The boulder field" data-tip-sub="Manticore country">
    <circle cx="654" cy="478" r="8"></circle><text x="654" y="478">3</text>
  </g>

  <!-- Scale -->
  <g class="sm-scale" transform="translate(120 545)">
    <line x1="0" y1="0" x2="125" y2="0"></line>
    <line x1="0" y1="-4" x2="0" y2="4"></line>
    <line x1="125" y1="-4" x2="125" y2="4"></line>
    <text x="62" y="-8">≈ 50 feet</text>
  </g>

  <!-- Compass (bottom-left, as on the official map) -->
  <g class="m-compass" transform="translate(76 470)">
    <circle r="18"></circle>
    <line x1="0" y1="13" x2="0" y2="-9"></line>
    <path class="m-compass-arrow" d="M0 -16 L5 -5 L0 -8 L-5 -5 Z"></path>
    <text y="-25">N</text>
  </g>
</g>
