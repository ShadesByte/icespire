---
// Local map of Gnomengarde, drawn from the official map's layout
// (offical-assets/Maps/map-07.02-gnomengarde.png — reference only).
// A cave complex either side of a waterfall grotto. viewBox 900 × 580;
// north is up; the whole warren spans roughly 350 feet.

// Rock texture cracks as [x, y, rot].
const cracks: [number, number, number][] = [
  [90, 90, 20], [260, 60, -15], [420, 100, 30], [820, 60, 10],
  [850, 500, -25], [120, 560, 15], [500, 60, -30], [860, 250, 40],
  [60, 300, -10], [320, 560, 25],
];

// Storage-room barrels as [x, y].
const barrels: [number, number][] = [
  [742, 368], [755, 365], [768, 365], [802, 377], [808, 391], [808, 405],
];

// Mushroom patches on the isles as [x, y].
const mushrooms: [number, number][] = [
  [540, 322], [548, 331], [534, 334], [545, 341], [553, 318],
  [576, 400], [584, 408], [572, 410], [582, 396],
];
---

<g class="submap-gnomengarde" aria-hidden="true">
  <rect class="sm-rock" x="0" y="0" width="900" height="580" style="stroke:none;"></rect>

  <g class="sm-crack">
    {cracks.map(([x, y, r]) => (
      <path d="M-14 0 Q-4 -4 2 1 Q8 5 14 2" transform={`translate(${x} ${y}) rotate(${r})`} />
    ))}
  </g>

  <!-- Corridors (walls first, then floor) -->
  {
    [0, 1].map((pass) => (
      <g class={pass === 0 ? 'sm-hall-wall' : 'sm-hall'}>
        {/* West wing */}
        <path d="M 193 288 C 185 315 172 340 158 358" />
        <path d="M 138 417 C 150 450 175 480 205 494" />
        <path d="M 238 505 C 280 502 310 492 365 481" />
        <path d="M 302 387 C 310 360 325 335 336 322" />
        <path d="M 315 428 C 340 450 358 462 372 468" />
        <path d="M 382 300 C 405 305 425 310 444 318" />
        <path d="M 425 480 C 455 478 480 470 503 460" />
        {/* East wing */}
        <path d="M 678 118 L 733 122" />
        <path d="M 638 137 C 632 165 628 185 624 205" />
        <path d="M 650 230 C 680 230 700 228 718 228" />
        <path d="M 754 206 C 758 180 760 160 762 148" />
        <path d="M 622 247 C 628 275 638 295 646 306" />
        <path d="M 680 330 C 710 345 725 360 735 372" />
        <path d="M 624 330 C 612 331 602 332 594 334" />
        <path d="M 634 468 C 620 462 612 452 606 444" />
        <path d="M 690 452 C 715 435 730 420 742 410" />
        {/* The looping dead-end passage off the southeast room */}
        <path d="M 688 480 C 730 490 752 520 730 545 C 710 563 676 554 668 528" />
      </g>
    ))
  }

  <!-- Rooms -->
  <g>
    <rect class="sm-floor" x="163" y="242" width="64" height="46" rx="12" transform="rotate(-3 195 265)"></rect>
    <rect class="sm-floor" x="90" y="353" width="80" height="64" rx="14" transform="rotate(2 130 385)"></rect>
    <rect class="sm-floor" x="308" y="267" width="74" height="56" rx="14" transform="rotate(3 345 295)"></rect>
    <rect class="sm-floor" x="269" y="387" width="58" height="42" rx="12" transform="rotate(-4 298 408)"></rect>
    <rect class="sm-floor" x="365" y="457" width="60" height="42" rx="12" transform="rotate(2 395 478)"></rect>
    <rect class="sm-floor" x="186" y="484" width="52" height="36" rx="11" transform="rotate(-2 212 502)"></rect>
    <rect class="sm-floor" x="610" y="93" width="70" height="44" rx="12" transform="rotate(-2 645 115)"></rect>
    <rect class="sm-floor" x="735" y="109" width="54" height="38" rx="11" transform="rotate(3 762 128)"></rect>
    <rect class="sm-floor" x="718" y="206" width="60" height="44" rx="12" transform="rotate(-3 748 228)"></rect>
    <rect class="sm-floor" x="594" y="205" width="56" height="42" rx="12" transform="rotate(2 622 226)"></rect>
    <rect class="sm-floor" x="624" y="305" width="56" height="42" rx="12" transform="rotate(-2 652 326)"></rect>
    <rect class="sm-floor" x="729" y="360" width="86" height="64" rx="14" transform="rotate(2 772 392)"></rect>
    <rect class="sm-floor" x="634" y="449" width="56" height="38" rx="11" transform="rotate(3 662 468)"></rect>
  </g>

  <!-- The grotto: pool, isles, waterfall -->
  <path
    class="sm-water"
    d="M 505 0
       C 500 45 540 80 535 125
       C 530 165 495 200 488 250
       C 482 300 468 330 475 375
       C 483 425 510 465 540 500
       L 548 540 L 585 540
       C 600 500 625 470 630 430
       C 636 385 620 350 618 300
       C 616 250 600 210 595 160
       C 590 110 570 50 575 0
       Z"></path>
  <ellipse class="sm-ground" cx="545" cy="330" rx="17" ry="26" transform="rotate(-14 545 330)" style="stroke: var(--map-shore); stroke-width: 1;"></ellipse>
  <ellipse class="sm-ground" cx="579" cy="404" rx="12" ry="17" transform="rotate(10 579 404)" style="stroke: var(--map-shore); stroke-width: 1;"></ellipse>
  <g>
    {mushrooms.map(([x, y]) => (
      <circle class="sm-tree" cx={x} cy={y} r="2.4" />
    ))}
  </g>
  <!-- Waterfall over the south lip -->
  <g class="sm-detail" style="opacity:.8;">
    <path d="M 552 542 C 550 556 551 568 549 578"></path>
    <path d="M 562 542 C 561 558 563 570 561 578"></path>
    <path d="M 573 542 C 574 556 572 568 574 578"></path>
  </g>
  <text class="sm-note" x="598" y="556">waterfall</text>

  <!-- The rope bridge -->
  <g class="sm-bridge" data-tip-title="Rope bridge" data-tip-sub="Goop-covered. Crossed anyway.">
    <line x1="505" y1="461" x2="625" y2="449"></line>
    <line x1="505" y1="455" x2="625" y2="443"></line>
    {Array.from({ length: 10 }, (_, i) => {
      const t = (i + 0.5) / 10;
      const x = 505 + 120 * t;
      const y = 458 - 12 * t;
      return <line x1={x - 2} y1={y - 4} x2={x + 2} y2={y + 4} />;
    })}
  </g>

  <!-- Ledges above the pool -->
  <text class="sm-note" x="418" y="304">+30 ft.</text>
  <text class="sm-note" x="626" y="318">+20 ft.</text>
  <text class="sm-note" x="612" y="432">+20 ft.</text>

  <!-- Throne dais in the throne room -->
  <g class="sm-inner">
    <rect x="109" y="366" width="30" height="22" rx="2"></rect>
    <rect x="116" y="371" width="16" height="12" rx="1"></rect>
  </g>
  <!-- Secret passage between throne room and the royal chambers -->
  <text class="sm-note" x="182" y="330">s</text>

  <!-- The ballista workshop: gnomish fan contraptions -->
  <g class="sm-detail">
    <g transform="translate(384 471)">
      <path d="M-8 -8 L8 8 M8 -8 L-8 8"></path><circle r="2" class="sm-detail-fill" style="stroke:none;"></circle>
    </g>
    <g transform="translate(408 486) rotate(20)">
      <path d="M-7 -7 L7 7 M7 -7 L-7 7"></path><circle r="2" class="sm-detail-fill" style="stroke:none;"></circle>
    </g>
  </g>

  <!-- The wheel contraption -->
  <g class="sm-detail" transform="translate(648 322)">
    <circle r="9"></circle>
    <path d="M-9 0 H9 M0 -9 V9 M-6.4 -6.4 L6.4 6.4 M6.4 -6.4 L-6.4 6.4"></path>
  </g>

  <!-- Barrels in the storage room -->
  <g>
    {barrels.map(([x, y]) => (
      <circle class="sm-detail" cx={x} cy={y} r="3.2" />
    ))}
  </g>

  <!-- Doors -->
  <g class="sm-door">
    <rect x="153" y="354" width="9" height="6" transform="rotate(35 158 358)"></rect>
    <rect x="201" y="490" width="9" height="6" transform="rotate(60 205 494)"></rect>
    <rect x="641" y="302" width="9" height="6" transform="rotate(70 646 306)"></rect>
    <rect x="729" y="119" width="9" height="6"></rect>
  </g>

  <!-- Numbered points of interest -->
  <g class="sm-poi" data-tip-title="The grotto pool" data-tip-sub="Mushroom farm on the isles">
    <circle cx="514" cy="288" r="8"></circle><text x="514" y="288">1</text>
  </g>
  <g class="sm-poi" data-tip-title="Rope bridge &amp; waterfall" data-tip-sub="The way across, goop included">
    <circle cx="565" cy="478" r="8"></circle><text x="565" y="478">2</text>
  </g>
  <g class="sm-poi" data-tip-title="Throne room" data-tip-sub="Hidden passage, peephole, paranoid king">
    <circle cx="103" cy="350" r="8"></circle><text x="103" y="350">3</text>
  </g>
  <g class="sm-poi" data-tip-title="Royal chambers" data-tip-sub="Where Queen Gnerkli was found tied up">
    <circle cx="195" cy="238" r="8"></circle><text x="195" y="238">4</text>
  </g>
  <g class="sm-poi danger" data-tip-title="The ballista workshop" data-tip-sub="Facktoré field-tested it on Thom">
    <circle cx="395" cy="450" r="8"></circle><text x="395" y="450">5</text>
  </g>
  <g class="sm-poi danger" data-tip-title="Storage room" data-tip-sub="Two mimics. Both dealt with.">
    <circle cx="772" cy="355" r="8"></circle><text x="772" y="355">6</text>
  </g>
  <g class="sm-poi" data-tip-title="The wheel room" data-tip-sub="A gnomish contraption, purpose unclear">
    <circle cx="626" cy="300" r="8"></circle><text x="626" y="300">7</text>
  </g>

  <!-- Scale -->
  <g class="sm-scale" transform="translate(742 552)">
    <line x1="0" y1="0" x2="125" y2="0"></line>
    <line x1="0" y1="-4" x2="0" y2="4"></line>
    <line x1="125" y1="-4" x2="125" y2="4"></line>
    <text x="62" y="-8">≈ 50 feet</text>
  </g>

  <!-- Compass -->
  <g class="m-compass" transform="translate(62 520)">
    <circle r="18"></circle>
    <line x1="0" y1="13" x2="0" y2="-9"></line>
    <path class="m-compass-arrow" d="M0 -16 L5 -5 L0 -8 L-5 -5 Z"></path>
    <text y="-25">N</text>
  </g>
</g>
