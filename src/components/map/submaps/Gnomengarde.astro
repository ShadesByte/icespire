---
// Local map of Gnomengarde, traced 1-to-1 from the official map
// (offical-assets/Maps/map-07.02-gnomengarde.png — reference only).
// Room and corridor positions are measured against that scan on a
// 900 × 573 grid (its exact aspect): the natural caverns west of the
// grotto, the carved gnome-warren east of it, and the pool between.
// Only the drawing style departs from the original. North is up.

// Rock-texture cracks: [x, y, rot].
const cracks: [number, number, number][] = [
  [120, 90, 20], [300, 70, -15], [470, 60, 30], [250, 470, -25],
  [140, 540, 15], [430, 545, 25], [820, 470, -20], [860, 250, 40],
  [700, 60, 10], [520, 520, -10],
];

// West-cavern corridors (centre-lines): connect the natural caves.
const westHalls: string[] = [
  'M 158 292 L 156 344',                         // G15 → G14 (secret stair)
  'M 205 288 C 222 300 236 322 250 342',         // G15 → G11 approach
  'M 176 392 C 205 396 232 400 256 404',         // G14 → G11
  'M 306 374 L 322 344',                         // G11 → G12
  'M 276 436 C 258 452 236 466 216 478',         // G11 → G13
  'M 302 438 C 328 448 350 456 362 470',         // G11 → G10 (long gallery)
  'M 388 312 C 408 306 430 300 450 292',         // G12 → pool (+30 ft.)
  'M 436 462 C 462 454 488 444 506 436',         // G10 → rope bridge
];

// East-warren corridors.
const eastHalls: string[] = [
  'M 690 92 L 682 172',                          // G4 → G3
  'M 768 96 C 786 100 800 102 806 104',          // G4 → G5
  'M 695 196 L 760 192',                         // G3 → G6
  'M 664 230 L 666 263',                         // G3 → G7
  'M 802 164 L 814 138',                         // G6 → G5
  'M 716 300 C 732 312 742 324 748 336',         // G7 → G8
  'M 660 300 C 638 320 620 336 606 348',         // G7 → pool (+20 ft.)
  'M 748 418 C 722 434 704 448 692 460',         // G8 → G9
  'M 658 462 C 632 448 616 438 606 432',         // G9 → bridge (+20 ft.)
  'M 676 494 C 694 502 704 516 694 528 C 682 538 664 530 660 514', // G9 loop
];

// The pool's two isles: mushroom clusters.
const redCaps: [number, number][] = [
  [514, 296], [524, 300], [512, 312], [522, 318], [530, 308],
  [516, 330], [526, 336], [512, 344], [524, 350],
];
const blueCaps: [number, number][] = [
  [556, 382], [566, 386], [554, 396], [564, 402], [572, 392], [558, 410],
];

// G8 storage barrels: along the north and east walls.
const barrels: [number, number][] = [
  [758, 312], [772, 312], [786, 312], [800, 312],
  [826, 344], [826, 360], [826, 378], [826, 396], [786, 414], [800, 414],
];
---

<g class="submap-gnomengarde" aria-hidden="true">
  <rect class="sm-rock" x="0" y="0" width="900" height="573" style="stroke:none;"></rect>

  <g class="sm-crack">
    {cracks.map(([x, y, r]) => (
      <path d="M-14 0 Q-4 -4 2 1 Q8 5 14 2" transform={`translate(${x} ${y}) rotate(${r})`} />
    ))}
  </g>

  <!-- Corridors: walls first, then floors -->
  {[0, 1].map((pass) => (
    <g class={pass === 0 ? 'sm-hall-wall' : 'sm-hall'}>
      {westHalls.map((d) => <path d={d} />)}
      {eastHalls.map((d) => <path d={d} />)}
    </g>
  ))}

  <!-- Natural caverns (west of the grotto): organic floors -->
  <g class="sm-cave">
    <!-- G15 · royal chambers -->
    <path d="M 145 252 C 160 244 195 243 216 250 C 228 254 227 273 218 285 C 206 294 175 295 158 291 C 144 287 138 264 145 252 Z"></path>
    <!-- G14 · throne room -->
    <path d="M 100 350 C 108 343 140 340 162 344 C 175 346 178 358 177 382 C 177 406 172 427 152 434 C 132 440 110 433 100 417 C 94 399 95 368 100 350 Z"></path>
    <!-- G12 · the splat cavern -->
    <path d="M 340 258 C 352 262 350 284 362 288 C 380 293 392 300 390 315 C 388 332 372 340 360 344 C 348 348 344 362 336 372 C 328 380 317 372 315 360 C 313 346 300 348 292 340 C 282 330 286 316 292 306 C 298 296 288 285 292 277 C 298 267 312 272 320 268 C 328 264 330 256 340 258 Z"></path>
    <!-- G11 -->
    <path d="M 258 388 C 262 377 285 373 305 375 C 325 377 334 388 332 405 C 330 424 314 438 294 438 C 274 438 258 425 256 409 C 255 402 255 393 258 388 Z"></path>
    <!-- G13 -->
    <path d="M 172 481 C 180 477 230 477 250 481 C 256 491 255 517 248 525 C 235 531 190 531 178 525 C 170 517 168 493 172 481 Z"></path>
    <!-- G10 · the ballista workshop -->
    <path d="M 362 452 C 370 448 430 448 438 454 C 444 464 443 496 436 503 C 424 508 375 508 366 502 C 358 494 357 462 362 452 Z"></path>
  </g>

  <!-- Carved warren (east of the grotto): rooms -->
  <g class="sm-floor">
    <rect x="676" y="44" width="92" height="48" rx="6"></rect>
    <rect x="806" y="68" width="44" height="70" rx="6"></rect>
    <rect x="629" y="172" width="66" height="56" rx="6"></rect>
    <rect x="760" y="164" width="70" height="56" rx="6"></rect>
    <rect x="660" y="263" width="56" height="44" rx="6"></rect>
    <rect x="746" y="304" width="88" height="118" rx="6"></rect>
    <rect x="658" y="446" width="50" height="46" rx="6"></rect>
  </g>

  <!-- The grotto pool -->
  <path
    class="sm-water"
    d="M 504 0
       C 494 42 484 82 478 120 C 468 158 458 202 453 246
       C 449 288 443 320 447 352 C 451 390 470 414 494 430
       C 512 442 528 456 548 470 C 574 456 596 442 610 412
       C 622 374 626 336 620 292 C 614 248 596 202 582 156
       C 570 108 560 58 560 30 C 562 16 554 8 546 0 Z"></path>
  <!-- Isles -->
  <ellipse class="sm-rock" cx="520" cy="320" rx="18" ry="34" transform="rotate(10 520 320)" style="stroke: var(--map-shore); stroke-width: 1;"></ellipse>
  <ellipse class="sm-rock" cx="563" cy="396" rx="16" ry="22" transform="rotate(-8 563 396)" style="stroke: var(--map-shore); stroke-width: 1;"></ellipse>
  <g class="sm-detail-fill" style="stroke:none;">
    {redCaps.map(([x, y]) => <circle cx={x} cy={y} r="2.4" />)}
    {blueCaps.map(([x, y]) => <circle cx={x} cy={y} r="2.4" />)}
  </g>

  <!-- Waterfall over the south lip -->
  <g class="sm-detail" style="opacity:.8;">
    <path d="M 536 470 C 534 486 535 500 533 514"></path>
    <path d="M 548 472 C 547 488 549 502 547 516"></path>
    <path d="M 560 470 C 561 486 559 500 561 514"></path>
  </g>
  <text class="sm-note" x="512" y="528">waterfall</text>

  <!-- Rope bridge across the south of the pool -->
  <g class="sm-bridge" data-tip-title="Rope bridge" data-tip-sub="Goop-covered. Crossed anyway.">
    <line x1="506" y1="437" x2="604" y2="431"></line>
    <line x1="506" y1="431" x2="604" y2="425"></line>
    {Array.from({ length: 10 }, (_, i) => {
      const t = (i + 0.5) / 10;
      const x = 506 + 98 * t;
      const y = 434 - 6 * t;
      return <line x1={x - 2} y1={y - 4} x2={x + 2} y2={y + 4} />;
    })}
  </g>

  <!-- Throne dais (G14) -->
  <g class="sm-inner">
    <rect x="112" y="356" width="46" height="26" rx="2"></rect>
    <rect x="120" y="362" width="14" height="14" rx="1"></rect>
    <rect x="138" y="362" width="14" height="14" rx="1"></rect>
  </g>
  <!-- Secret stair marks between G15 and G14 -->
  <text class="sm-note" x="146" y="300">s</text>
  <text class="sm-note" x="146" y="332">s</text>

  <!-- Ballista workshop contraptions (G10) -->
  <g class="sm-detail">
    <g transform="translate(414 460)">
      <path d="M-8 -8 L8 8 M8 -8 L-8 8"></path><circle r="2" class="sm-detail-fill" style="stroke:none;"></circle>
    </g>
    <g transform="translate(400 488) rotate(20)">
      <path d="M-7 -7 L7 7 M7 -7 L-7 7"></path><circle r="2" class="sm-detail-fill" style="stroke:none;"></circle>
    </g>
  </g>

  <!-- The wheel contraption (G7) -->
  <g class="sm-detail" transform="translate(687 283)">
    <circle r="9"></circle>
    <path d="M-9 0 H9 M0 -9 V9 M-6.4 -6.4 L6.4 6.4 M6.4 -6.4 L-6.4 6.4"></path>
  </g>

  <!-- Storage barrels (G8) -->
  <g>
    {barrels.map(([x, y]) => (
      <circle class="sm-detail" cx={x} cy={y} r="3.2" />
    ))}
  </g>

  <!-- Doors -->
  <g class="sm-door">
    <rect x="153" y="288" width="8" height="5"></rect>
    <rect x="193" y="323" width="8" height="5" transform="rotate(20 197 325)"></rect>
    <rect x="193" y="475" width="8" height="5"></rect>
    <rect x="763" y="58" width="6" height="8"></rect>
  </g>

  <!-- Ledge notes -->
  <text class="sm-note" x="586" y="238">+30 ft.</text>
  <text class="sm-note" x="392" y="290">+30 ft.</text>
  <text class="sm-note" x="606" y="350">+20 ft.</text>
  <text class="sm-note" x="600" y="426">+20 ft.</text>
  <text class="sm-note" x="252" y="402">+10 ft.</text>
  <text class="sm-note" x="674" y="480">+10 ft.</text>

  <!-- Numbered points of interest -->
  <g class="sm-poi" data-tip-title="The grotto pool" data-tip-sub="Mushroom farm on the isles">
    <circle cx="486" cy="340" r="8"></circle><text x="486" y="340">1</text>
  </g>
  <g class="sm-poi" data-tip-title="Rope bridge &amp; waterfall" data-tip-sub="The way across, goop included">
    <circle cx="554" cy="448" r="8"></circle><text x="554" y="448">2</text>
  </g>
  <g class="sm-poi" data-tip-title="Throne room" data-tip-sub="Hidden passage, peephole, paranoid king">
    <circle cx="120" cy="410" r="8"></circle><text x="120" y="410">3</text>
  </g>
  <g class="sm-poi" data-tip-title="Royal chambers" data-tip-sub="Where Queen Gnerkli was found tied up">
    <circle cx="185" cy="266" r="8"></circle><text x="185" y="266">4</text>
  </g>
  <g class="sm-poi danger" data-tip-title="The ballista workshop" data-tip-sub="Facktoré field-tested it on Thom">
    <circle cx="400" cy="476" r="8"></circle><text x="400" y="476">5</text>
  </g>
  <g class="sm-poi danger" data-tip-title="Storage room" data-tip-sub="Two mimics. Both dealt with.">
    <circle cx="790" cy="366" r="8"></circle><text x="790" y="366">6</text>
  </g>
  <g class="sm-poi" data-tip-title="The wheel room" data-tip-sub="A gnomish contraption, purpose unclear">
    <circle cx="687" cy="283" r="8"></circle><text x="687" y="283">7</text>
  </g>

  <!-- Scale -->
  <g class="sm-scale" transform="translate(742 545)">
    <line x1="0" y1="0" x2="125" y2="0"></line>
    <line x1="0" y1="-4" x2="0" y2="4"></line>
    <line x1="125" y1="-4" x2="125" y2="4"></line>
    <text x="62" y="-8">≈ 50 feet</text>
  </g>

  <!-- Compass (bottom-left, as on the official map) -->
  <g class="m-compass" transform="translate(78 476)">
    <circle r="18"></circle>
    <line x1="0" y1="13" x2="0" y2="-9"></line>
    <path class="m-compass-arrow" d="M0 -16 L5 -5 L0 -8 L-5 -5 Z"></path>
    <text y="-25">N</text>
  </g>
</g>
