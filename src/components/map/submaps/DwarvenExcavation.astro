---
// Local map of the Dwarven Excavation — the buried temple of Abbathor —
// drawn from the official map's layout (offical-assets/Maps/
// map-05.02-dwarven-excavation.jpg — reference only). An open canyon dig
// in the west; the carved temple complex in the east. viewBox 900 × 560;
// north is up.

// Broken settlement walls in the dig as [x, y, rot].
const ruinWalls: [number, number, number][] = [
  [200, 200, 0], [230, 185, 90], [262, 210, 0], [215, 250, 90],
  [252, 255, 0], [287, 235, 45], [300, 262, 90], [180, 226, 45],
  [270, 180, 0],
];

// Rubble piles as [x, y] (each renders a pebble cluster).
const digRubble: [number, number][] = [
  [330, 270], [346, 295], [320, 300], [356, 274], [338, 316], [310, 280],
];
const hallRubble: [number, number][] = [[508, 208], [520, 214]];
const eastRubble: [number, number][] = [[704, 284], [714, 290]];
const roomRubble: [number, number][] = [[612, 384], [622, 376], [757, 307], [634, 318]];

// Cliff hachure ticks along the canyon rim as [x, y, rot].
const rimTicks: [number, number, number][] = [
  [56, 470, 100], [52, 420, 95], [62, 372, 80], [80, 322, 70], [92, 272, 75],
  [104, 224, 60], [128, 178, 45], [166, 142, 30], [214, 118, 10], [262, 112, -5],
  [312, 124, -25], [352, 152, -45], [376, 192, -65], [388, 232, -80],
  [382, 330, 65], [362, 366, 45], [330, 400, 35], [292, 434, 30],
  [252, 466, 25], [210, 496, 20], [162, 522, 12], [110, 542, 6],
];
---

<g class="submap-excavation" aria-hidden="true">
  <rect class="sm-rock" x="0" y="0" width="900" height="560" style="stroke:none;"></rect>

  <g class="sm-crack">
    <path d="M-14 0 Q-4 -4 2 1 Q8 5 14 2" transform="translate(560 90) rotate(15)"></path>
    <path d="M-14 0 Q-4 -4 2 1 Q8 5 14 2" transform="translate(820 170) rotate(-20)"></path>
    <path d="M-14 0 Q-4 -4 2 1 Q8 5 14 2" transform="translate(760 480) rotate(30)"></path>
    <path d="M-14 0 Q-4 -4 2 1 Q8 5 14 2" transform="translate(460 470) rotate(-10)"></path>
    <path d="M-14 0 Q-4 -4 2 1 Q8 5 14 2" transform="translate(850 350) rotate(50)"></path>
  </g>

  <!-- The open canyon of the dig -->
  <path
    class="sm-open"
    d="M 40 560
       C 50 480 45 420 70 360
       C 90 310 85 255 110 210
       C 135 160 190 120 255 115
       C 320 110 368 140 384 190
       C 396 228 390 252 398 268
       L 398 302
       C 388 330 374 360 340 390
       C 300 430 250 470 210 505
       C 175 535 120 552 40 560
       Z"></path>
  <g class="sm-cliff">
    {rimTicks.map(([x, y, r]) => (
      <path d="M0 0 l 10 0" transform={`translate(${x} ${y}) rotate(${r})`} />
    ))}
  </g>

  <!-- Buried settlement: broken walls under the scree -->
  <g>
    {ruinWalls.map(([x, y, r]) => (
      <rect
        class="sm-detail-fill"
        x="-9"
        y="-2"
        width="18"
        height="4"
        rx="1"
        transform={`translate(${x} ${y}) rotate(${r})`}
        style="stroke: none;"
      />
    ))}
  </g>

  <!-- Rubble -->
  {
    [...digRubble, ...hallRubble, ...eastRubble, ...roomRubble].map(([x, y]) => (
      <g class="sm-detail">
        <circle cx={x} cy={y} r="3.4" />
        <circle cx={x + 6} cy={y + 3} r="2.6" />
        <circle cx={x - 4} cy={y + 5} r="2.2" />
      </g>
    ))
  }

  <!-- The dwarves' camp -->
  <g class="sm-detail-fill" style="stroke:none;">
    <path d="M 155 292 l 20 -10 l 6 12 l -20 10 Z"></path>
    <path d="M 214 320 l 22 -8 l 5 13 l -22 8 Z"></path>
  </g>

  <!-- Halls (walls then floors) -->
  {
    [0, 1].map((pass) => (
      <g class={pass === 0 ? 'sm-hall-wall' : 'sm-hall'}>
        <path d="M 467 285 L 491 285" />
        <path d="M 507 246 L 507 212 L 655 212" />
        <path d="M 630 212 L 630 238" />
        <path d="M 507 324 L 507 366 L 590 366" />
        <path d="M 630 268 L 630 299" />
        <path d="M 647 252 L 655 252 L 655 314 L 647 314" />
        <path d="M 655 285 L 736 285" />
      </g>
    ))
  }

  <!-- The broken black-stone gate -->
  <g class="sm-detail-fill" style="stroke:none;">
    <rect x="392" y="250" width="9" height="24" rx="1"></rect>
    <rect x="392" y="288" width="9" height="24" rx="1"></rect>
  </g>
  <path class="sm-hall" d="M 400 281 L 424 281" style="stroke-width: 13;"></path>

  <!-- Rooms -->
  <rect class="sm-floor" x="423" y="263" width="44" height="40" rx="3"></rect>
  <!-- E5 · the octagonal temple hall of Abbathor -->
  <path
    class="sm-floor"
    d="M 507 242 L 571 242 L 589 260 L 589 310 L 571 328 L 507 328 L 489 310 L 489 260 Z"></path>
  <rect class="sm-floor" x="642" y="162" width="46" height="42" rx="3"></rect>
  <rect class="sm-floor" x="613" y="238" width="34" height="28" rx="3"></rect>
  <rect class="sm-floor" x="612" y="299" width="36" height="30" rx="3"></rect>
  <rect class="sm-floor" x="591" y="362" width="42" height="36" rx="3"></rect>
  <path
    class="sm-floor"
    d="M 754 251 L 802 251 L 818 267 L 818 303 L 802 319 L 754 319 L 738 303 L 738 267 Z"></path>

  <!-- Main chamber furniture: pillars and the altar -->
  <g class="sm-inner">
    <circle cx="514" cy="265" r="5.5"></circle>
    <circle cx="560" cy="265" r="5.5"></circle>
    <circle cx="514" cy="305" r="5.5"></circle>
    <circle cx="560" cy="305" r="5.5"></circle>
    <rect x="573" y="277" width="8" height="16" rx="1"></rect>
  </g>

  <!-- Secret doors found in Session 5 -->
  <text class="sm-note" x="540" y="243">s</text>
  <text class="sm-note" x="540" y="334">s</text>

  <!-- Doors -->
  <g class="sm-door">
    <rect x="419" y="272" width="6" height="8"></rect>
    <rect x="419" y="290" width="6" height="8"></rect>
    <rect x="651" y="204" width="8" height="6"></rect>
    <rect x="586" y="369" width="6" height="8"></rect>
    <rect x="732" y="281" width="6" height="8"></rect>
  </g>

  <!-- Numbered points of interest -->
  <g class="sm-poi" data-tip-title="The dwarves' camp" data-tip-sub="Norbus &amp; Dazlyn — food, lodging, 60/40">
    <circle cx="172" cy="330" r="8"></circle><text x="172" y="330">1</text>
  </g>
  <g class="sm-poi" data-tip-title="Buried settlement" data-tip-sub="Ruins under Abbathor's avalanche">
    <circle cx="232" cy="168" r="8"></circle><text x="232" y="168">2</text>
  </g>
  <g class="sm-poi" data-tip-title="The broken gate" data-tip-sub="Black stone, long since shattered">
    <circle cx="398" cy="234" r="8"></circle><text x="398" y="234">3</text>
  </g>
  <g class="sm-poi danger" data-tip-title="Main chamber" data-tip-sub="The jelly fight; a pillar base hid the coffer">
    <circle cx="535" cy="285" r="8"></circle><text x="535" y="285">4</text>
  </g>
  <g class="sm-poi danger" data-tip-title="Rubble hallway" data-tip-sub="The glint was one more jelly">
    <circle cx="520" cy="196" r="8"></circle><text x="520" y="196">5</text>
  </g>
  <g class="sm-poi" data-tip-title="South passage" data-tip-sub="A short walk to a still-closed door">
    <circle cx="560" cy="344" r="8"></circle><text x="560" y="344">6</text>
  </g>

  <!-- Scale -->
  <g class="sm-scale" transform="translate(742 528)">
    <line x1="0" y1="0" x2="116" y2="0"></line>
    <line x1="0" y1="-4" x2="0" y2="4"></line>
    <line x1="116" y1="-4" x2="116" y2="4"></line>
    <text x="58" y="-8">≈ 50 feet</text>
  </g>

  <!-- Compass (bottom-right, as on the official excavation map) -->
  <g class="m-compass" transform="translate(838 478)">
    <circle r="18"></circle>
    <line x1="0" y1="13" x2="0" y2="-9"></line>
    <path class="m-compass-arrow" d="M0 -16 L5 -5 L0 -8 L-5 -5 Z"></path>
    <text y="-25">N</text>
  </g>
</g>
