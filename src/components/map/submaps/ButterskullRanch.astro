---
// Local map of Butterskull Ranch, drawn from the official map's layout
// (offical-assets/Maps/map-02.02-butterskull-ranch.jpg — reference only).
// viewBox 900 × 560; north is up.

// Orchard grid.
const orchard: [number, number][] = [];
for (let row = 0; row < 5; row++) {
  for (let col = 0; col < 6; col++) {
    orchard.push([330 + col * 22 + (row % 2) * 7, 400 + row * 24]);
  }
}

// Field hachures: two corn fields.
const fields = [
  { cx: 660, cy: 480, w: 95, rows: 6, rot: -6 },
  { cx: 770, cy: 290, w: 85, rows: 6, rot: 8 },
];

// Pasture fence (irregular ring, gap southeast toward the barn).
const pasture: string = (() => {
  const pts: string[] = [];
  for (let a = -40; a <= 250; a += 14) {
    const rad = (a * Math.PI) / 180;
    const rx = 108 + (a % 42 === 0 ? 10 : 0);
    const ry = 112 + (a % 28 === 0 ? 8 : 0);
    pts.push(`${(195 + Math.cos(rad) * rx).toFixed(1)},${(205 + Math.sin(rad) * ry).toFixed(1)}`);
  }
  return pts.join(' ');
})();
---

<g class="submap-butterskull" aria-hidden="true">
  <rect class="sm-ground" x="0" y="0" width="900" height="560"></rect>

  <!-- Contours in the corners -->
  <g class="sm-contour">
    <path d="M 640 40 C 720 70 800 60 880 90"></path>
    <path d="M 660 100 C 740 130 810 118 885 150"></path>
    <path d="M 700 160 C 770 185 830 175 890 205"></path>
    <path d="M 620 560 C 700 520 800 520 890 545"></path>
    <path d="M 700 560 C 770 535 830 532 892 552"></path>
  </g>
  <text class="sm-note" x="836" y="84">+30 ft.</text>
  <text class="sm-note" x="842" y="144">+20 ft.</text>
  <text class="sm-note" x="848" y="200">+10 ft.</text>

  <!-- Triboar Trail, passing the ranch -->
  <path class="sm-path" d="M 50 540 C 200 520 300 480 380 440 C 440 410 480 355 505 320"></path>
  <text class="sm-note" transform="translate(130 516) rotate(-8)">Triboar Trail</text>

  <!-- Grass tufts and shade trees -->
  <g class="sm-grass">
    {[
      [480, 120, 0], [560, 180, 0], [420, 200, 0], [620, 120, 0], [120, 420, 0],
      [200, 470, 0], [300, 380, 0], [520, 520, 0], [420, 320, 0], [650, 400, 0],
      [80, 100, 0], [340, 100, 0], [860, 420, 0], [820, 520, 0], [90, 520, 0],
    ].map(([x, y]) => (
      <path d="M-5 0 L-3 -6 M0 0 L0 -7 M5 0 L3 -6" transform={`translate(${x} ${y})`} />
    ))}
  </g>
  <g>
    {[
      [70, 60, 13], [560, 60, 12], [430, 90, 10], [640, 550, 11],
      [420, 545, 12], [60, 340, 11], [880, 250, 10],
    ].map(([x, y, r]) => (
      <circle class="sm-tree" cx={x} cy={y} r={r} />
    ))}
  </g>

  <!-- Pasture -->
  <polyline class="sm-fence" points={pasture}></polyline>
  <text class="sm-note" x="162" y="208">pasture</text>

  <!-- Destroyed barn and smithy -->
  <g class="sm-detail" style="stroke-width: 2;">
    <path d="M 316 288 L 344 288 L 344 306 M 322 312 L 340 312"></path>
    <path d="M 382 214 L 400 214 L 400 228"></path>
  </g>
  {
    [[332, 300], [352, 296], [392, 224]].map(([x, y]) => (
      <g class="sm-detail">
        <circle cx={x} cy={y} r="2.6" />
        <circle cx={x + 5} cy={y + 3} r="2" />
      </g>
    ))
  }

  <!-- Pond -->
  <ellipse class="sm-water" cx="450" cy="300" rx="38" ry="24" transform="rotate(-8 450 300)"></ellipse>

  <!-- Farmhouse and outhouse -->
  <g transform="translate(530 290)">
    <path class="sm-building" d="M -22 -14 H 10 V 0 H 24 V 16 H -22 Z"></path>
    <line class="sm-roofline" x1="-18" y1="0" x2="18" y2="8"></line>
  </g>
  <rect class="sm-building" x="581" y="251" width="9" height="9"></rect>
  <circle class="sm-detail" cx="556" cy="318" r="3.5"></circle>

  <!-- Gardens -->
  <g class="sm-field">
    {Array.from({ length: 4 }, (_, i) => (
      <path d={`M -42 ${(i - 1.5) * 10} h 84`} transform="translate(470 372) rotate(4)" />
    ))}
  </g>
  <text class="sm-note" x="440" y="404">gardens</text>

  <!-- Orchard -->
  <g>
    {orchard.map(([x, y]) => (
      <circle class="sm-tree" cx={x} cy={y} r="6.5" />
    ))}
  </g>

  <!-- Corn fields -->
  <g class="sm-field">
    {fields.map((f) =>
      Array.from({ length: f.rows }, (_, i) => (
        <path
          d={`M ${-f.w} ${(i - (f.rows - 1) / 2) * 11} h ${f.w * 2}`}
          transform={`translate(${f.cx} ${f.cy}) rotate(${f.rot})`}
        />
      ))
    )}
  </g>
  <polyline class="sm-fence" points="560,420 760,420 780,540 560,540 560,420"></polyline>
  <polyline class="sm-fence" points="680,230 860,230 870,350 690,355 680,230"></polyline>
  <text class="sm-note" x="620" y="484">corn field</text>
  <text class="sm-note" x="730" y="296">corn field</text>

  <!-- Numbered points of interest -->
  <g class="sm-poi" data-tip-title="The farmhouse" data-tip-sub="Home of Alfonse 'Big Al' Kalazorn">
    <circle cx="530" cy="264" r="8"></circle><text x="530" y="264">1</text>
  </g>
  <g class="sm-poi danger" data-tip-title="Destroyed barn" data-tip-sub="Something tore through here">
    <circle cx="330" cy="272" r="8"></circle><text x="330" y="272">2</text>
  </g>
  <g class="sm-poi" data-tip-title="Destroyed smithy" data-tip-sub="The forge fared no better">
    <circle cx="392" cy="200" r="8"></circle><text x="392" y="200">3</text>
  </g>
  <g class="sm-poi" data-tip-title="The pasture" data-tip-sub="Prize cattle — the famous butter">
    <circle cx="195" cy="120" r="8"></circle><text x="195" y="120">4</text>
  </g>

  <!-- Scale -->
  <g class="sm-scale" transform="translate(742 62)">
    <line x1="0" y1="0" x2="110" y2="0"></line>
    <line x1="0" y1="-4" x2="0" y2="4"></line>
    <line x1="110" y1="-4" x2="110" y2="4"></line>
    <text x="55" y="-8">≈ 100 feet</text>
  </g>

  <!-- Compass -->
  <g class="m-compass" transform="translate(64 476)">
    <circle r="18"></circle>
    <line x1="0" y1="13" x2="0" y2="-9"></line>
    <path class="m-compass-arrow" d="M0 -16 L5 -5 L0 -8 L-5 -5 Z"></path>
    <text y="-25">N</text>
  </g>
</g>
