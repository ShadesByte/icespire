---
// Local map of Axeholm, drawn from the official map's layout
// (offical-assets/Maps/map-01.02-axeholm.jpg — reference only).
// An abandoned dwarven stronghold in two levels, shown side by side.
// viewBox 900 × 560; north is up.

// Rectangular rooms as [x, y, w, h] (centers).
const lowerRooms: [number, number, number, number][] = [
  [200, 95, 60, 52],   // west bastion
  [312, 95, 60, 52],   // east bastion
  [255, 268, 112, 110], // great hall
  [95, 182, 92, 62],   // A7 hall
  [110, 268, 80, 50],  // A5
  [46, 268, 26, 38],   // A8 cells
  [95, 348, 50, 40],   // A9 cellar
  [151, 348, 30, 36],  // A10
  [255, 362, 46, 50],  // A11
  [198, 378, 44, 40],  // A12
  [313, 378, 44, 40],  // A13
  [255, 470, 132, 72], // feast hall
  [120, 442, 50, 40],  // A15
  [126, 508, 46, 36],  // A16
];

const upperRooms: [number, number, number, number][] = [
  [700, 148, 132, 92], // audience chamber
  [641, 82, 40, 40],   // west tower top
  [762, 82, 40, 40],   // east tower top
  [596, 152, 40, 36],  // A23
  [812, 152, 40, 36],  // A21
  [700, 305, 112, 92], // gallery over the great hall
  [816, 305, 40, 52],  // A25
  [641, 455, 44, 44],  // A28
  [706, 455, 44, 44],  // A27
  [776, 455, 44, 44],  // A26
  [621, 515, 30, 26],  // A29
  [587, 392, 30, 30],  // A30
];

// Corridor strokes per level (drawn under rooms).
const lowerHalls = [
  'M 255 122 L 255 212',
  'M 199 268 L 310 268',
  'M 95 214 L 95 242',
  'M 255 324 L 255 336',
  'M 255 388 L 255 433',
  'M 145 442 L 188 452',
  'M 313 268 L 372 268',
  'M 371 282 L 371 315',
  'M 396 300 L 420 380',
];
const upperHalls = [
  'M 700 195 L 700 258',
  'M 618 152 L 633 152',
  'M 790 152 L 791 152',
  'M 700 352 L 700 372',
  'M 620 392 L 780 392',
  'M 641 414 L 641 432',
  'M 706 414 L 706 432',
  'M 776 414 L 776 432',
  'M 621 478 L 621 501',
  'M 806 392 L 846 392',
];

// Stair glyphs as [x, y, rot].
const stairs: [number, number, number][] = [
  [186, 152, 90], [328, 152, 90], [452, 452, 0], [851, 458, 0], [834, 524, 0],
];

// Great-hall and feast-hall pillars as [x, y].
const pillars: [number, number][] = [
  [222, 235, ], [290, 235], [222, 300], [290, 300],
  [660, 275], [740, 275], [660, 335], [740, 335],
  [215, 470], [240, 470], [268, 470], [294, 470],
];
---

<g class="submap-axeholm" aria-hidden="true">
  <rect class="sm-rock" x="0" y="0" width="900" height="560" style="stroke:none;"></rect>
  <line x1="545" y1="30" x2="545" y2="530" class="sm-crack" style="stroke-dasharray:none; opacity:.6;"></line>
  <text class="sm-note" x="60" y="36">Lower Halls</text>
  <text class="sm-note" x="590" y="36">Upper Halls</text>

  {
    [0, 1].map((pass) => (
      <g class={pass === 0 ? 'sm-hall-wall' : 'sm-hall'}>
        {[...lowerHalls, ...upperHalls].map((d) => (
          <path d={d} />
        ))}
      </g>
    ))
  }

  <g>
    {[...lowerRooms, ...upperRooms].map(([cx, cy, w, h]) => (
      <rect class="sm-floor" x={cx - w / 2} y={cy - h / 2} width={w} height={h} rx="4" />
    ))}
  </g>

  <!-- Natural caverns east of the lower halls -->
  <path
    class="sm-floor"
    d="M 372 240 C 400 232 428 240 440 258 C 452 276 448 292 436 302 C 452 310 464 326 460 344
       C 480 352 496 372 492 396 C 488 424 462 442 434 438 C 410 434 396 416 398 396
       C 380 390 370 374 374 356 C 360 344 356 322 368 308 C 356 294 356 268 372 252 Z"></path>
  <!-- Winding cave up from the caverns -->
  <path class="sm-hall-wall" d="M 420 236 C 428 210 418 190 430 168 C 438 152 452 144 460 130" style="stroke-width: 12;"></path>
  <path class="sm-hall" d="M 420 236 C 428 210 418 190 430 168 C 438 152 452 144 460 130" style="stroke-width: 7;"></path>

  <!-- Entry: portcullis and murder-slits -->
  <path class="sm-hall-wall" d="M 255 60 L 255 96" style="stroke-width: 20;"></path>
  <path class="sm-hall" d="M 255 56 L 255 96" style="stroke-width: 14;"></path>
  <g class="sm-detail">
    <line x1="247" y1="78" x2="263" y2="78" stroke-dasharray="2 2"></line>
    <path d="M 240 66 l 6 4 M 240 88 l 6 4 M 270 66 l -6 4 M 270 88 l -6 4"></path>
  </g>

  <!-- Feast-hall thrones -->
  <g class="sm-inner">
    <rect x="243" y="490" width="10" height="10" rx="1"></rect>
    <rect x="258" y="490" width="10" height="10" rx="1"></rect>
  </g>

  <!-- Cellar bottles -->
  <g class="sm-detail">
    <circle cx="86" cy="342" r="2"></circle>
    <circle cx="96" cy="352" r="2"></circle>
  </g>

  <!-- Braziers in the audience chamber -->
  <g class="sm-detail">
    <circle cx="672" cy="128" r="2.6"></circle>
    <circle cx="700" cy="128" r="2.6"></circle>
    <circle cx="728" cy="128" r="2.6"></circle>
  </g>

  <!-- Pillars -->
  <g class="sm-inner">
    {pillars.map(([x, y]) => (
      <circle cx={x} cy={y} r="4.5" />
    ))}
  </g>

  <!-- Stairs -->
  <g class="sm-stairs">
    {stairs.map(([x, y, r]) => (
      <g transform={`translate(${x} ${y}) rotate(${r})`}>
        <path d="M-8 -5 H8 M-8 -1 H8 M-8 3 H8 M-8 7 H8" />
      </g>
    ))}
  </g>

  <!-- Doors -->
  <g class="sm-door">
    <rect x="196" y="265" width="6" height="8"></rect>
    <rect x="141" y="265" width="6" height="8"></rect>
    <rect x="251" y="209" width="9" height="6"></rect>
    <rect x="251" y="430" width="9" height="6"></rect>
    <rect x="696" y="254" width="9" height="6"></rect>
    <rect x="696" y="369" width="9" height="6"></rect>
  </g>

  <!-- Numbered points of interest -->
  <g class="sm-poi" data-tip-title="The gatehouse" data-tip-sub="Murder-slits, twin bastions, one portcullis">
    <circle cx="255" cy="42" r="8"></circle><text x="255" y="42">1</text>
  </g>
  <g class="sm-poi" data-tip-title="The great hall" data-tip-sub="Four pillars, dwarven stonework">
    <circle cx="255" cy="268" r="8"></circle><text x="255" y="268">2</text>
  </g>
  <g class="sm-poi" data-tip-title="The feast hall" data-tip-sub="Twin thrones, long cold">
    <circle cx="330" cy="500" r="8"></circle><text x="330" y="500">3</text>
  </g>
  <g class="sm-poi danger" data-tip-title="Natural caverns" data-tip-sub="Something has moved in below">
    <circle cx="428" cy="330" r="8"></circle><text x="428" y="330">4</text>
  </g>
  <g class="sm-poi" data-tip-title="Audience chamber" data-tip-sub="The upper seat of the hold">
    <circle cx="762" cy="120" r="8"></circle><text x="762" y="120">5</text>
  </g>
  <g class="sm-poi" data-tip-title="Dormitories" data-tip-sub="Bunk rooms off the south gallery">
    <circle cx="706" cy="428" r="8"></circle><text x="706" y="428">6</text>
  </g>

  <!-- Scale -->
  <g class="sm-scale" transform="translate(60 528)">
    <line x1="0" y1="0" x2="90" y2="0"></line>
    <line x1="0" y1="-4" x2="0" y2="4"></line>
    <line x1="90" y1="-4" x2="90" y2="4"></line>
    <text x="45" y="-8">≈ 50 feet</text>
  </g>

  <!-- Compass -->
  <g class="m-compass" transform="translate(846 66)">
    <circle r="18"></circle>
    <line x1="0" y1="13" x2="0" y2="-9"></line>
    <path class="m-compass-arrow" d="M0 -16 L5 -5 L0 -8 L-5 -5 Z"></path>
    <text y="-25">N</text>
  </g>
</g>
