---
// Local map of the Woodland Manse, drawn from the official map's layout
// (offical-assets/Maps/map-14.02-woodland-manse.jpg — reference only).
// A vine-choked ruin deep in eastern Neverwinter Wood. viewBox 900 × 560;
// north is up.

// Berry thickets as [x, y] blob centers.
const thickets: [number, number][] = [
  [240, 130], [330, 105], [560, 130], [640, 250], [660, 340],
  [250, 300], [240, 390], [330, 500], [450, 515], [560, 480],
];

// Forest edge trees.
const trees: [number, number, number][] = [
  [70, 80, 16], [150, 50, 13], [70, 200, 14], [60, 330, 15], [80, 450, 13],
  [170, 530, 14], [700, 80, 15], [790, 130, 13], [850, 240, 15], [830, 380, 13],
  [780, 480, 15], [660, 530, 13], [870, 60, 12], [420, 60, 13], [880, 500, 12],
];

// The vine tangle in the courtyard.
const vines = [
  'M 470 345 C 450 330 440 350 455 360 C 470 370 490 355 480 340 C 472 328 452 332 448 345',
  'M 470 345 C 485 330 500 342 492 356 C 484 368 465 366 462 352',
  'M 470 345 C 460 362 475 374 488 366',
  'M 470 345 C 480 320 462 315 452 325',
];
---

<g class="submap-woodlandmanse" aria-hidden="true">
  <rect class="sm-ground" x="0" y="0" width="900" height="560"></rect>

  <!-- Trails in from the wood, northwest -->
  <path class="sm-path" d="M 20 210 C 90 190 150 150 210 130 C 260 114 300 110 340 118"></path>
  <path class="sm-path" d="M 340 118 C 400 100 470 90 540 60"></path>
  <path class="sm-path" d="M 210 130 C 200 180 220 230 260 260"></path>

  <!-- The manse -->
  <!-- Central courtyard, open to the sky and badly overgrown -->
  <rect class="sm-open" x="425" y="305" width="90" height="80" rx="4" style="stroke: var(--map-shore); stroke-width: 3;"></rect>
  <g class="sm-grass" style="opacity: .9; stroke-width: 1.4;">
    {vines.map((d) => (
      <path d={d} />
    ))}
  </g>

  <!-- Rooms -->
  <rect class="sm-floor" x="407" y="194" width="46" height="32" rx="3"></rect>
  <rect class="sm-floor" x="485" y="195" width="40" height="34" rx="3"></rect>
  <rect class="sm-floor" x="312" y="260" width="36" height="30" rx="3"></rect>
  <rect class="sm-floor" x="367" y="260" width="56" height="36" rx="3"></rect>
  <rect class="sm-floor" x="475" y="264" width="60" height="36" rx="3"></rect>
  <rect class="sm-floor" x="318" y="325" width="44" height="30" rx="3"></rect>
  <rect class="sm-floor" x="305" y="390" width="90" height="60" rx="3"></rect>
  <rect class="sm-floor" x="460" y="402" width="80" height="56" rx="3"></rect>
  <!-- The round tower -->
  <circle class="sm-rock" cx="365" cy="205" r="26"></circle>

  <!-- Outside stair up the west face -->
  <g class="sm-stairs" transform="translate(288 268)">
    <path d="M-8 -6 H8 M-8 -2 H8 M-8 2 H8 M-8 6 H8"></path>
  </g>

  <!-- Spiral stair in the southwest room -->
  <g class="sm-detail" transform="translate(332 340)">
    <circle r="7"></circle>
    <path d="M0 0 L7 0 M0 0 L-5 5 M0 0 L-2 -6.5"></path>
  </g>

  <!-- Cracked floor in the southeast hall -->
  <path class="sm-crack" d="M 492 430 L 504 418 L 512 428 L 522 420"></path>

  <!-- Doors -->
  <g class="sm-door">
    <rect x="425" y="256" width="9" height="6"></rect>
    <rect x="498" y="257" width="9" height="6"></rect>
    <rect x="346" y="270" width="6" height="9"></rect>
    <rect x="465" y="425" width="6" height="9"></rect>
    <rect x="418" y="340" width="6" height="9"></rect>
  </g>

  <!-- Berry thickets -->
  <g>
    {thickets.map(([x, y]) => (
      <g>
        <path
          class="sm-tree"
          d="M -18 4 Q -20 -8 -8 -10 Q -4 -18 6 -14 Q 18 -16 18 -4 Q 24 4 14 8 Q 4 14 -6 10 Q -16 12 -18 4 Z"
          transform={`translate(${x} ${y})`}
        />
        <circle class="sm-detail-fill" cx={x - 6} cy={y - 4} r="1.6" style="stroke:none; fill: var(--accent-gold-muted);" />
        <circle class="sm-detail-fill" cx={x + 5} cy={y + 2} r="1.6" style="stroke:none; fill: var(--accent-gold-muted);" />
      </g>
    ))}
  </g>

  <!-- Forest edge -->
  <g>
    {trees.map(([x, y, r]) => (
      <circle class="sm-tree" cx={x} cy={y} r={r} />
    ))}
  </g>

  <!-- Numbered points of interest -->
  <g class="sm-poi" data-tip-title="The manse" data-tip-sub="A manor the wood is taking back">
    <circle cx="397" cy="240" r="8"></circle><text x="397" y="240">1</text>
  </g>
  <g class="sm-poi danger" data-tip-title="The courtyard" data-tip-sub="The vines in there are not still">
    <circle cx="470" cy="310" r="8"></circle><text x="470" y="310">2</text>
  </g>
  <g class="sm-poi" data-tip-title="The round tower" data-tip-sub="The last sound structure">
    <circle cx="365" cy="176" r="8"></circle><text x="365" y="176">3</text>
  </g>
  <g class="sm-poi" data-tip-title="Berry thickets" data-tip-sub="Tempting. Watched.">
    <circle cx="240" cy="108" r="8"></circle><text x="240" y="108">4</text>
  </g>

  <!-- Scale -->
  <g class="sm-scale" transform="translate(742 530)">
    <line x1="0" y1="0" x2="110" y2="0"></line>
    <line x1="0" y1="-4" x2="0" y2="4"></line>
    <line x1="110" y1="-4" x2="110" y2="4"></line>
    <text x="55" y="-8">≈ 60 feet</text>
  </g>

  <!-- Compass -->
  <g class="m-compass" transform="translate(846 66)">
    <circle r="18"></circle>
    <line x1="0" y1="13" x2="0" y2="-9"></line>
    <path class="m-compass-arrow" d="M0 -16 L5 -5 L0 -8 L-5 -5 Z"></path>
    <text y="-25">N</text>
  </g>
</g>
