---
// Local map of Falcon's Hunting Lodge, drawn from the official map's layout
// (offical-assets/Maps/map-06.02-falcons-hunting-lodge.jpg — reference only).
// A walled lodge on the river in Neverwinter Wood. viewBox 900 × 560;
// north is up.

// Compound wall (log palisade).
const wall = 'M 228 120 L 470 120 L 470 260 L 500 300 L 500 452 L 228 452 L 228 340 L 196 320 L 196 240 L 228 220 Z';

const trees: [number, number, number][] = [
  [560, 80, 14], [640, 120, 12], [720, 70, 15], [820, 130, 13], [860, 240, 12],
  [600, 250, 11], [700, 320, 13], [800, 400, 14], [640, 460, 12], [560, 380, 11],
  [740, 500, 13], [80, 100, 12], [70, 420, 13], [110, 510, 11], [850, 520, 12],
];

// Kennel row: small stalls south of the yard.
const kennels = [252, 268, 284, 300];
---

<g class="submap-falconslodge" aria-hidden="true">
  <rect class="sm-ground" x="0" y="0" width="900" height="560"></rect>

  <!-- The river -->
  <path
    class="sm-water"
    d="M 96 0 C 120 60 100 130 116 200 C 130 262 118 330 132 390 C 146 452 130 510 140 560
       L 60 560 C 50 500 64 440 52 380 C 40 320 56 250 44 190 C 34 130 50 60 42 0 Z"></path>
  <path class="m-river" d="M 80 40 C 92 90 82 150 94 210" style="opacity:.4; stroke-width:1.6;"></path>

  <!-- Trails -->
  <path class="sm-path" d="M 20 208 L 96 208"></path>
  <path class="sm-path" d="M 500 330 C 600 320 700 260 780 180 C 820 140 860 120 890 110"></path>
  <path class="sm-path" d="M 520 380 C 600 420 660 480 700 550"></path>

  <!-- The bridge -->
  <g class="sm-bridge">
    <line x1="118" y1="202" x2="168" y2="202"></line>
    <line x1="118" y1="216" x2="168" y2="216"></line>
    {[126, 138, 150, 162].map((x) => (
      <line x1={x} y1="202" x2={x} y2="216" />
    ))}
  </g>

  <!-- Compound wall -->
  <path class="sm-fence" d={wall} style="stroke-width: 2; stroke-dasharray: 6 3;"></path>

  <!-- Gatehouse over the bridge road -->
  <rect class="sm-rock" x="176" y="192" width="36" height="36" rx="3"></rect>

  <!-- Barracks (north) with the outhouse beyond -->
  <g transform="translate(300 152)">
    <path class="sm-building" d="M -48 -17 H 48 V 17 H 10 V 6 H -10 V 17 H -48 Z"></path>
    <line class="sm-roofline" x1="-40" y1="0" x2="40" y2="0"></line>
  </g>
  <rect class="sm-building" x="352" y="106" width="10" height="10"></rect>

  <!-- Stone watchtower -->
  <g transform="translate(428 200)">
    <rect class="sm-rock" x="-22" y="-22" width="44" height="44" rx="4"></rect>
    <g class="sm-detail">
      <circle r="9"></circle>
      <path d="M0 0 L9 0 M0 0 L-6 6 M0 0 L-3 -8"></path>
    </g>
  </g>

  <!-- Main lodge, kitchen, and annex -->
  <g transform="translate(392 320)">
    <rect class="sm-building" x="-32" y="-62" width="64" height="124" rx="3"></rect>
    <line class="sm-roofline" x1="0" y1="-52" x2="0" y2="52"></line>
  </g>
  <rect class="sm-building" x="330" y="300" width="26" height="30" rx="2"></rect>
  <rect class="sm-rock" x="266" y="292" width="52" height="48" rx="3"></rect>

  <!-- Stone store and stable house, southwest corner -->
  <rect class="sm-rock" x="212" y="352" width="36" height="36" rx="3"></rect>
  <rect class="sm-building" x="214" y="398" width="32" height="28" rx="2"></rect>

  <!-- Kennels -->
  <g class="sm-detail" style="stroke-width: 1.6;">
    <path d="M 246 436 H 312"></path>
    {kennels.map((x) => (
      <path d={`M ${x} 436 V 420`} />
    ))}
  </g>

  <!-- Pens -->
  <path class="sm-fence" d="M 360 388 C 400 372 452 372 484 392 C 500 402 504 420 498 436"></path>
  <path class="sm-fence" d="M 380 452 C 420 428 460 424 498 436"></path>
  <text class="sm-note" x="408" y="416">pens</text>

  <!-- Yard labels -->
  <text class="sm-note" x="264" y="238">north yard</text>
  <text class="sm-note" x="252" y="378">south yard</text>

  <!-- Trees -->
  <g>
    {trees.map(([x, y, r]) => (
      <circle class="sm-tree" cx={x} cy={y} r={r} />
    ))}
  </g>

  <!-- Numbered points of interest -->
  <g class="sm-poi" data-tip-title="Bridge &amp; gatehouse" data-tip-sub="The only way across the river">
    <circle cx="148" cy="184" r="8"></circle><text x="148" y="184">1</text>
  </g>
  <g class="sm-poi" data-tip-title="The main lodge" data-tip-sub="Falcon's hall — game on the fire">
    <circle cx="440" cy="300" r="8"></circle><text x="440" y="300">2</text>
  </g>
  <g class="sm-poi" data-tip-title="The watchtower" data-tip-sub="Stone, with a spiral stair">
    <circle cx="458" cy="172" r="8"></circle><text x="458" y="172">3</text>
  </g>
  <g class="sm-poi" data-tip-title="Kennels &amp; pens" data-tip-sub="The hounds announce visitors">
    <circle cx="330" cy="440" r="8"></circle><text x="330" y="440">4</text>
  </g>
  <g class="sm-poi" data-tip-title="The barracks" data-tip-sub="Bunks for the hunting parties">
    <circle cx="300" cy="126" r="8"></circle><text x="300" y="126">5</text>
  </g>

  <!-- Scale -->
  <g class="sm-scale" transform="translate(742 530)">
    <line x1="0" y1="0" x2="110" y2="0"></line>
    <line x1="0" y1="-4" x2="0" y2="4"></line>
    <line x1="110" y1="-4" x2="110" y2="4"></line>
    <text x="55" y="-8">≈ 60 feet</text>
  </g>

  <!-- Compass -->
  <g class="m-compass" transform="translate(846 66)">
    <circle r="18"></circle>
    <line x1="0" y1="13" x2="0" y2="-9"></line>
    <path class="m-compass-arrow" d="M0 -16 L5 -5 L0 -8 L-5 -5 Z"></path>
    <text y="-25">N</text>
  </g>
</g>
