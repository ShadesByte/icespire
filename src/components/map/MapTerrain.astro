---
// Static terrain artwork for the campaign map — stylized line-art of the
// Phandalin region in the site's design language, traced feature-by-feature
// against the official Sword Coast regional map (offical-assets/Maps/
// map-00.02-sword-coast.jpg, reference only — never shipped to the site).
//
// Coordinate space: 1000 × 750 viewBox units, shared with the location
// coordinates in src/content/locations/. The mapping from the official
// sheet is uniform (my = (official_display − (240, 860)) × 0.8), so every
// road bend, river curve, forest boundary, and landmark sits where the
// official map puts it. The crop covers the campaign region: the official
// sheet's own east border falls at x ≈ 910; terrain beyond that is a quiet
// continuation. North of y = 0 (Neverwinter, Mount Hotenow, the Crags) is
// cropped out per the campaign's house rule.

// Mountain peaks as [x, y, scale], sitting on the dark massif shapes below.
const peaks: [number, number, number][] = [
  // The Icespire ridge, southwest to northeast
  [612, 456, 1.0], [650, 440, 1.2], [692, 447, 0.9], [734, 456, 1.0],
  [772, 468, 0.9], [802, 448, 1.0], [840, 420, 1.1], [876, 394, 0.9],
  [906, 364, 1.0], [932, 338, 0.8], [662, 486, 0.9], [702, 508, 0.8],
  [746, 508, 0.9],
  // The spur down toward Gnomengarde
  [628, 544, 0.9], [604, 580, 0.8], [592, 610, 0.7],
  // The southwestern massif over the excavation and Axeholm
  [382, 692, 0.8], [412, 662, 0.9], [446, 670, 0.8], [482, 692, 0.9],
  [516, 682, 0.8], [452, 700, 0.7],
];

// Sunburst hill country as [x, y, scale] arcs.
const hills: [number, number, number][] = [
  // The knot around Phandalin and Umbrage Hill
  [478, 552, 0.8], [512, 542, 0.9], [548, 566, 0.8], [524, 606, 0.7],
  [464, 612, 0.7],
  // Between the Triboar Trail and the mountains
  [545, 352, 0.9], [576, 320, 0.8], [612, 344, 0.9], [642, 302, 0.8],
  [672, 270, 0.9], [582, 396, 0.8], [620, 415, 0.7],
  // The northeast hill country, Conyberry to the sheet edge
  [640, 120, 0.9], [672, 88, 0.8], [704, 58, 0.8], [732, 100, 0.9],
  [762, 70, 0.8], [796, 94, 0.9], [832, 120, 0.8], [862, 88, 0.9],
  [886, 142, 0.8], [838, 192, 0.9], [872, 232, 0.8], [902, 272, 0.9],
  [692, 256, 0.8], [736, 230, 0.7], [796, 236, 0.8], [718, 300, 0.8],
  // The gap between the mountains and Kryptgarden
  [572, 680, 0.8], [602, 712, 0.7], [636, 690, 0.8], [662, 730, 0.7],
  [610, 748, 0.6],
];

// Scrub and grass marks scattered over the open country, [x, y, rot].
const scrub: [number, number, number][] = [
  [230, 130, 10], [300, 160, -15], [360, 110, 20], [250, 250, 5],
  [320, 300, -10], [255, 330, 15], [352, 370, -5], [300, 420, 10],
  [225, 420, -20], [330, 470, 5], [372, 430, 18], [412, 390, -8],
  [455, 350, 12], [502, 310, -14], [420, 300, 6], [378, 250, -6],
  [430, 220, 14], [480, 250, -18], [520, 220, 8], [560, 250, -4],
  [478, 420, 8], [520, 460, -10], [548, 500, 6], [420, 570, -12],
  [386, 610, 8], [340, 640, -6], [310, 590, 14], [250, 560, -8],
  [225, 620, 10], [255, 690, -14], [610, 180, 8], [590, 90, -10],
  [770, 300, 12], [840, 300, -8], [700, 360, 6], [745, 395, -12],
  [660, 620, 10], [700, 680, -8], [755, 720, 12], [590, 660, -15],
];

// Marsh tufts of the Mere of Dead Men (mostly below the sheet's crop).
const marshes: [number, number, number][] = [
  [306, 730, 1.0], [346, 742, 0.9], [388, 730, 0.8], [428, 744, 0.9],
  [468, 734, 0.8], [270, 742, 0.8], [500, 746, 0.7],
];

// Faint hex grid, matching the official sheet's cartography. Flat-top
// hexes, one path for the whole lattice.
const hexPath: string = (() => {
  const r = 27;
  const parts: string[] = [];
  const colStep = r * 1.5;
  const rowStep = r * Math.sqrt(3);
  for (let col = 0; col * colStep < 1060; col++) {
    const cx = col * colStep;
    const yOff = col % 2 === 1 ? rowStep / 2 : 0;
    for (let row = 0; row * rowStep + yOff < 800; row++) {
      const cy = row * rowStep + yOff;
      const pts: string[] = [];
      for (let i = 0; i < 6; i++) {
        const a = (Math.PI / 3) * i;
        pts.push(`${(cx + r * Math.cos(a)).toFixed(1)} ${(cy + r * Math.sin(a)).toFixed(1)}`);
      }
      parts.push(`M ${pts.join(' L ')} Z`);
    }
  }
  return parts.join(' ');
})();
---

<g class="map-terrain" aria-hidden="true">
  <defs>
    <g id="m-peak">
      <path class="m-peak" d="M-16 0 L-6 -20 L-1 -13 L7 -26 L20 0 Z"></path>
