    <path d="M 640 330 C 700 348 760 340 815 358"></path>
    <path d="M 230 190 C 275 205 315 198 350 212"></path>
  </g>

  <!-- The sea, west of the coastline -->
  <path
    class="m-sea"
    d="M 48 0
       C 58 60 66 100 90 140
