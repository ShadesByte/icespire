    </g>
    <g id="m-marsh">
      <path class="m-marsh" d="M-7 0 L-4 -7 M0 0 L0 -8 M7 0 L4 -7 M-10 2 L10 2"></path>
    </g>
  </defs>

  <!-- Land -->
  <rect class="m-land" x="0" y="0" width="1000" height="750"></rect>

  <!-- Hex lattice -->
  <path class="m-hex" d={hexPath}></path>

  <!-- Neverwinter Wood: both banks of the river, the great southern lobe,
       and the long southeast boundary toward Conyberry -->
