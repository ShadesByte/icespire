---
// Static terrain artwork for the campaign map — stylized line-art of the
// Phandalin region in the site's design language, drawn to match the
// geography of the official Sword Coast regional map (offical-assets/Maps/
// map-00.02-sword-coast.jpg, reference only — never shipped to the site).
// Everything is colored via CSS variables (see the Map section of
// global.css) so the art restyles itself between the dark and light themes.
//
// Coordinate space: 1000 × 750 viewBox units, shared with the location
// coordinates in src/content/locations/. The mapping from the official map
// is uniform, so bearings and relative distances are true: the coast runs
// down the west, Neverwinter Wood spans the north, and the Sword Mountains
// run northeast–southwest to the east of Phandalin.

// Mountain peaks as [x, y, scale].
const peaks: [number, number, number][] = [
  // The Sword Mountains: main ridge, NE (Icespire country) to SW (Axeholm)
  [836, 368, 1.1], [872, 396, 0.9], [806, 402, 1.0], [772, 430, 0.9],
  [742, 452, 1.0], [676, 486, 1.0], [646, 512, 1.2], [614, 540, 0.9],
  [586, 566, 1.0], [556, 594, 0.9], [524, 622, 1.0], [494, 610, 0.8],
  [886, 340, 1.0], [908, 388, 0.9], [864, 452, 0.8], [896, 480, 0.9],
  // Southern knot around Axeholm and Gnomengarde
  [540, 665, 0.9], [600, 668, 1.0], [640, 640, 0.9], [666, 608, 1.0],
  [632, 584, 0.8], [462, 670, 0.7], [696, 640, 0.8], [730, 600, 0.9],
  [762, 560, 1.0], [794, 520, 0.9], [826, 492, 1.0],
];

// Pine clusters as [x, y, scale].
const pines: [number, number, number][] = [
  // Neverwinter Wood: the southern reaches, spanning the top of the map
  [345, 18, 1.1], [385, 40, 0.9], [425, 14, 1.2], [462, 42, 1.0],
  [502, 20, 0.9], [540, 44, 1.1], [580, 18, 1.0], [618, 40, 1.2],
  [655, 16, 0.9], [692, 38, 1.0], [718, 14, 0.8], [352, 74, 0.9],
  [430, 80, 1.0], [508, 84, 1.1], [586, 78, 0.9], [660, 76, 1.0],
  [700, 108, 0.9], [390, 112, 1.1], [468, 118, 0.9], [545, 116, 1.0],
  [618, 112, 0.8],
  // The wood's southern lobe, west of Conyberry country
  [420, 156, 1.0], [478, 162, 1.1], [532, 158, 0.9], [446, 200, 0.9],
  [502, 206, 1.0], [548, 196, 0.8], [472, 246, 0.9], [520, 250, 1.0],
  [498, 288, 0.8], [545, 282, 0.7],
  // Kryptgarden Forest, creeping in at the southeast corner
  [790, 636, 1.0], [836, 618, 1.1], [880, 646, 0.9], [922, 622, 1.2],
  [958, 660, 1.0], [828, 672, 0.9], [874, 696, 1.1], [918, 714, 0.9],
  [962, 700, 0.8], [786, 700, 0.8], [940, 594, 0.9], [968, 630, 0.7],
];

// Low hill arcs as [x, y, scale].
const hills: [number, number, number][] = [
  // Rolling country north and east of Phandalin, toward the gold mine
  [428, 442, 1.0], [468, 428, 0.9], [508, 448, 0.8], [545, 424, 1.0],
  [582, 398, 0.9], [620, 372, 0.8], [548, 470, 0.7], [610, 430, 0.9],
  [652, 402, 0.8], [660, 350, 0.9],
  // Conyberry and Shrine of Savras country, northeast
  [700, 170, 0.9], [736, 232, 0.8], [792, 192, 1.0], [826, 244, 0.9],
  [858, 176, 0.8], [886, 260, 0.9], [706, 262, 0.7], [852, 122, 0.8],
  // Around Umbrage Hill
  [510, 578, 0.7], [472, 566, 0.6],
  // Open country northeast, toward the Starmetal Hills
  [668, 302, 0.8], [726, 330, 0.9], [786, 300, 0.8], [842, 322, 0.9],
  [920, 240, 0.8], [946, 300, 0.9], [898, 152, 0.8], [936, 128, 0.7],
];

// Marsh tufts of the Mere of Dead Men as [x, y, scale].
const marshes: [number, number, number][] = [
  [246, 712, 1.0], [286, 728, 0.9], [322, 706, 0.8], [206, 696, 0.8],
  [350, 732, 0.9], [262, 742, 0.7], [312, 744, 0.8],
];
---

<g class="map-terrain" aria-hidden="true">
  <defs>
    <g id="m-peak">
      <path class="m-peak" d="M-16 0 L-6 -20 L-1 -13 L7 -26 L20 0 Z"></path>
      <path class="m-ridge" d="M7 -26 L3 -14"></path>
    </g>
    <g id="m-pine">
      <path class="m-pine" d="M0 -14 L5 -6 L2 -6 L7 1 L-7 1 L-2 -6 L-5 -6 Z"></path>
      <line class="m-pine-trunk" x1="0" y1="1" x2="0" y2="4"></line>
    </g>
    <g id="m-marsh">
      <path class="m-marsh" d="M-7 0 L-4 -7 M0 0 L0 -8 M7 0 L4 -7 M-10 2 L10 2"></path>
    </g>
  </defs>

  <!-- Land -->
  <rect class="m-land" x="0" y="0" width="1000" height="750"></rect>

  <!-- Forest canopies: the woods as masses, with tree glyphs on top -->
  <path
    class="m-canopy"
    d="M 300 0
       C 290 40 300 80 320 104
       C 350 140 390 150 396 180
       C 402 226 430 262 470 284
       C 510 304 550 296 566 268
       C 586 234 570 200 596 172
       C 626 140 680 150 710 120
       C 736 96 742 50 748 0
       Z"></path>
  <path
    class="m-canopy"
    d="M 1000 560
       C 950 570 900 580 870 600
       C 830 626 800 640 776 668
       C 756 690 760 720 776 750
       L 1000 750 Z"></path>

  <!-- The Sword Mountains as a mass beneath the peaks -->
  <path
    class="m-ridge-wash"
    d="M 870 320
       C 920 370 915 450 875 510
       C 835 570 770 610 705 650
       C 655 680 575 700 515 695
       C 465 690 440 660 465 625
       C 495 585 545 570 585 540
       C 635 500 675 460 715 425
       C 755 390 810 350 870 320 Z"></path>

  <!-- Faint contour hints in the open country -->
  <g class="m-contour">
    <path d="M 210 470 C 265 490 320 482 365 502"></path>
    <path d="M 255 305 C 305 322 355 312 395 330"></path>
    <path d="M 645 300 C 705 318 760 310 815 328"></path>
    <path d="M 330 645 C 380 660 430 652 480 668"></path>
    <path d="M 230 150 C 275 165 315 158 350 172"></path>
  </g>

  <!-- The sea, west of the coastline -->
  <path
    class="m-sea"
    d="M 46 0
       C 64 90 90 150 102 210
       C 118 280 132 300 142 352
       C 158 420 166 412 172 472
       C 184 530 196 536 206 592
       C 218 640 226 646 232 688
       C 238 716 244 730 248 750
       L 0 750 L 0 0 Z"></path>
  <!-- Deeper water offshore -->
  <path
    class="m-sea-deep"
    d="M 0 0 L 20 0
       C 36 90 56 150 66 210
       C 80 280 92 300 100 352
       C 114 420 122 412 128 472
       C 138 530 148 536 156 592
       C 166 640 172 646 178 688
       C 182 716 186 730 190 750
       L 0 750 Z"></path>
  <path
    class="m-shore"
    d="M 46 0
       C 64 90 90 150 102 210
       C 118 280 132 300 142 352
       C 158 420 166 412 172 472
       C 184 530 196 536 206 592
       C 218 640 226 646 232 688
       C 238 716 244 730 248 750"></path>
  <g class="m-wave">
    <path d="M 22 150 q 12 -6 24 0 q 12 6 24 0"></path>
    <path d="M 58 402 q 12 -6 24 0 q 12 6 24 0"></path>
    <path d="M 34 560 q 12 -6 24 0 q 12 6 24 0"></path>
  </g>

  <!-- River: out of Neverwinter Wood, west to the sea -->
  <path
    class="m-river"
    d="M 470 30
       C 450 44 425 52 400 58
       C 340 66 290 76 240 82
       C 180 88 120 84 62 70"></path>

  <!-- Mere of Dead Men, south along the coast -->
  <g>
    {marshes.map(([x, y, s]) => (
      <use href="#m-marsh" transform={`translate(${x} ${y}) scale(${s})`} />
    ))}
  </g>

  <!-- Mountains -->
  <g>
    {peaks.map(([x, y, s]) => (
      <use href="#m-peak" transform={`translate(${x} ${y}) scale(${s})`} />
    ))}
  </g>

  <!-- Icespire Peak itself -->
  <g transform="translate(704 470)">
    <path class="m-peak m-peak-major" d="M-52 0 L-22 -62 L-11 -45 L9 -84 L28 -42 L52 0 Z"></path>
    <path class="m-snow" d="M9 -84 L17 -66 L8 -58 L0 -68 Z"></path>
    <path class="m-ridge" d="M9 -84 L4 -52 M-22 -62 L-18 -40"></path>
  </g>

  <!-- Forests -->
  <g>
    {pines.map(([x, y, s]) => (
      <use href="#m-pine" transform={`translate(${x} ${y}) scale(${s})`} />
    ))}
  </g>

  <!-- Hills -->
  <g class="m-hill">
    {hills.map(([x, y, s]) => (
      <path
        d="M-12 0 Q0 -11 12 0"
        transform={`translate(${x} ${y}) scale(${s})`}
      />
    ))}
  </g>

  <!-- Roads (solid) -->
  <g class="m-road">
    <!-- The High Road, hugging the coast through Leilon -->
    <path d="M 78 0 C 100 100 130 240 152 340 C 176 448 216 560 268 640 C 282 662 298 700 310 750"></path>
  </g>

  <!-- Trails (dashed) -->
  <g class="m-trail">
    <!-- Triboar Trail: off the High Road, east across the hills, then
         northeast to Conyberry and on toward Butterskull Ranch -->
    <path d="M 262 302 C 330 334 400 368 452 388 C 520 360 566 322 616 264 C 660 216 706 176 756 136"></path>
    <path d="M 756 136 C 780 142 798 148 816 152 C 840 156 862 158 884 160"></path>
    <!-- Spur south into Phandalin -->
    <path d="M 452 388 C 456 430 458 472 460 520"></path>
    <!-- Spur northeast to Mountain's Toe Gold Mine -->
    <path d="M 452 388 C 500 404 552 428 596 452"></path>
    <!-- Phandalin south to Umbrage Hill, continuing to the excavation, with
         the split trail down to the orc encampment -->
    <path d="M 462 536 C 472 556 482 576 490 588"></path>
    <path d="M 484 600 C 464 622 448 632 432 640"></path>
    <path d="M 458 618 C 454 636 452 648 450 656"></path>
    <!-- The road the party cut southeast to Gnomengarde, via the camp -->
    <path d="M 468 534 C 490 544 510 552 528 564 C 548 582 564 598 574 608"></path>
    <!-- Trivial Trail, south out of Phandalin — fading past the ruined temple -->
    <path d="M 454 536 C 438 590 420 646 408 690"></path>
    <path class="m-trail-faint" d="M 404 704 C 400 722 398 736 396 750"></path>
  </g>

  <!-- Terrain labels -->
  <g class="m-terrain-label">
    <text transform="translate(30 400) rotate(-90)">The Sword Coast</text>
    <text class="m-label-forest" transform="translate(400 190) rotate(-6)">Neverwinter Wood</text>
    <text transform="translate(596 568) rotate(-38)">Sword Mountains</text>
    <text transform="translate(534 330) rotate(-30)">Triboar Trail</text>
    <text class="m-label-sm" transform="translate(421 655) rotate(78)">Trivial Trail</text>
    <text transform="translate(146 372) rotate(76)">The High Road</text>
    <text class="m-label-sm" transform="translate(222 690)">Mere of Dead Men</text>
    <text class="m-label-forest" transform="translate(800 700) rotate(-20)">Kryptgarden Forest</text>
  </g>

  <!-- Map sheet border and title -->
  <rect class="m-sheet" x="12" y="12" width="976" height="726" rx="6"></rect>
  <g class="m-title" text-anchor="end">
    <text class="m-title-main" x="896" y="52">The Phandalin Region</text>
    <text class="m-title-sub" x="896" y="74">as charted by the party</text>
  </g>

  <!-- Compass, out over the open sea -->
  <g class="m-compass" transform="translate(66 646)">
    <circle r="22"></circle>
    <line x1="0" y1="16" x2="0" y2="-12"></line>
    <path class="m-compass-arrow" d="M0 -20 L6 -6 L0 -10 L-6 -6 Z"></path>
    <text y="-30">N</text>
  </g>
</g>
