---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import StatusPill from '../../components/StatusPill.astro';
import { url } from '../../utils/url';

export async function getStaticPaths() {
  const npcs = await getCollection('npcs');
  return npcs.map((npc) => ({ params: { id: npc.id }, props: { npc } }));
}

const { npc } = Astro.props;
const { Content } = await render(npc);
const roleLine = [npc.data.role, npc.data.affiliation].filter(Boolean).join(' · ');
---

<Base title={npc.data.name}>
  <div class="kicker">NPC</div>
  <h1 class="page-title" style="margin-bottom: var(--space-3);">{npc.data.name}</h1>
  <p class="session-meta" style="display: flex; align-items: center; gap: var(--space-3); flex-wrap: wrap;">
    {roleLine && <span>{roleLine}</span>}
    <StatusPill status={npc.data.status} />
    {npc.data.firstAppearance != null && (
      <span>First appeared in session {npc.data.firstAppearance}</span>
    )}
  </p>
  {
    npc.data.faction && (
      <p class="session-meta">
        Faction: <a href={url(`/factions/${npc.data.faction}/`)}>{npc.data.faction}</a>
      </p>
    )
  }
  <div class="prose">
    <Content />
  </div>
</Base>
