---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import NpcEntry from '../../components/NpcEntry.astro';
import { url } from '../../utils/url';

const npcs = (await getCollection('npcs')).sort((a, b) => a.data.name.localeCompare(b.data.name));
---

<Base title="NPC Directory" description="Everyone the party has met.">
  <h1 class="page-title">NPC Directory</h1>
  {
    npcs.length === 0 ? (
      <p class="prose">No NPCs recorded yet.</p>
    ) : (
      <ul class="npc-list">
        {npcs.map((npc) => (
          <NpcEntry
            name={npc.data.name}
            role={npc.data.role}
            affiliation={npc.data.affiliation}
            status={npc.data.status}
            note={npc.data.note}
            href={url(`/npcs/${npc.id}/`)}
            portrait={npc.data.portrait ? url(npc.data.portrait) : undefined}
          />
        ))}
      </ul>
    )
  }
</Base>
