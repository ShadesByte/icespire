---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { url } from '../../utils/url';

// The timeline threads every session — and every event pinned to a location —
// into a single chronological spine. The map paints where the story went; this
// reads it out in order, with the dates, the full event notes, and a link from
// each moment to both its recap and its place on the map.
//
// Session-driven (not journey-driven like the map's list), so a session with no
// recorded travel — a session zero, a downtime session — still takes its place
// on the spine.
const sessions = (await getCollection('sessions', ({ data }) => !data.draft)).sort(
  (a, b) => a.data.sessionNumber - b.data.sessionNumber
);
const journey = await getCollection('journey');
const locations = await getCollection('locations');

const journeyByNumber = new Map(journey.map((leg) => [leg.data.session, leg]));
const locBySlug = new Map(locations.map((loc) => [loc.id, loc]));

// A place link resolves to the region map's deep link, but only for places that
// are actually on the map (status !== unknown). Undiscovered slugs render as
// plain text so we never link to a marker the map won't draw.
function placeName(slug: string) {
  return locBySlug.get(slug)?.data.name ?? slug;
}
function placeHref(slug: string) {
  const loc = locBySlug.get(slug);
  return loc && loc.data.status !== 'unknown' ? url(`/map/#${slug}`) : undefined;
}

const eventKindLabels: Record<string, string> = {
  battle: 'Battle',
  discovery: 'Discovery',
  social: 'Encounter',
  omen: 'Omen',
};

const nodes = sessions.map((session) => {
  const leg = journeyByNumber.get(session.data.sessionNumber);
  return {
    number: session.data.sessionNumber,
    title: session.data.title,
    date: session.data.date,
    dateStr: session.data.date.toLocaleDateString('en-US', {
      month: 'long',
      day: 'numeric',
      year: 'numeric',
    }),
    summary: session.data.summary,
    recapHref: url(`/sessions/${session.id}/`),
    encounters: session.data.encounters.map((e) => ({ name: e.name, image: url(e.image) })),
    stops: (leg?.data.route ?? []).map((slug) => ({
      slug,
      name: placeName(slug),
      href: placeHref(slug),
    })),
    events: (leg?.data.events ?? []).map((ev) => ({
      title: ev.title,
      kind: ev.kind,
      note: ev.note,
      at: ev.at,
      atName: placeName(ev.at),
      atHref: placeHref(ev.at),
    })),
  };
});

const eventCount = nodes.reduce((sum, n) => sum + n.events.length, 0);
const latestNumber = nodes.length ? nodes[nodes.length - 1].number : 0;
---

<Base
  title="Timeline"
  description="The whole story so far, in order: every session and every notable moment along the way."
>
  <div class="kicker">The story so far</div>
  <h1 class="page-title">Timeline</h1>
  <p class="prose timeline-intro">
    Every session in order, with the moments that mattered pinned where they
    happened. {eventCount} recorded {eventCount === 1 ? 'moment' : 'moments'} across{' '}
    {nodes.length} {nodes.length === 1 ? 'session' : 'sessions'}. Follow a place to
    find it on the map; follow a session to read the full recap.
  </p>

  {
    nodes.length === 0 ? (
      <p class="prose">The chronicle hasn't begun yet.</p>
    ) : (
      <ol class="timeline">
        {nodes.map((node) => (
          <li class:list={['tl-node', { latest: node.number === latestNumber }]}>
            <div class="tl-date">{node.dateStr}</div>
            <h2 class="tl-session">
              <a href={node.recapHref}>
                <span class="tl-session-num">Session {node.number}</span>
                <span class="tl-session-title">{node.title}</span>
              </a>
            </h2>
            {node.summary && <p class="tl-summary">{node.summary}</p>}

            {node.stops.length > 0 && (
              <p class="tl-route" aria-label="Route this session">
                {node.stops.map((s, i) => (
                  <>
                    {i > 0 && (
                      <span class="tl-arrow" aria-hidden="true">
                        →
                      </span>
                    )}
                    {s.href ? (
                      <a class="tl-place" href={s.href}>
                        {s.name}
                      </a>
                    ) : (
                      <span class="tl-place tl-place-static">{s.name}</span>
                    )}
                  </>
                ))}
              </p>
            )}

            {node.events.length > 0 && (
              <ul class="tl-events">
                {node.events.map((ev) => (
                  <li class:list={['tl-event', ev.kind]}>
                    <div class="tl-event-head">
                      <span class="tl-event-kind">{eventKindLabels[ev.kind]}</span>
                      <span class="tl-event-title">{ev.title}</span>
                      {ev.atHref ? (
                        <a class="tl-event-at" href={ev.atHref}>
                          {ev.atName}
                        </a>
                      ) : (
                        <span class="tl-event-at tl-place-static">{ev.atName}</span>
                      )}
                    </div>
                    {ev.note && <p class="tl-event-note">{ev.note}</p>}
                  </li>
                ))}
              </ul>
            )}

            {node.encounters.length > 0 && (
              <div class="tl-encounters" aria-label="Encountered this session">
                {node.encounters.map((e) => (
                  <img src={e.image} alt={e.name} title={e.name} loading="lazy" />
                ))}
              </div>
            )}

            <p class="tl-more">
              <a href={node.recapHref}>Read the recap →</a>
            </p>
          </li>
        ))}
      </ol>
    )
  }
</Base>
