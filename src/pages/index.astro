---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import SessionRecapCard from '../components/SessionRecapCard.astro';
import { url } from '../utils/url';

const sessions = (await getCollection('sessions', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.sessionNumber - a.data.sessionNumber
);
const latest = sessions[0];
---

<Base title="Home">
  <div class="kicker">A campaign journal</div>
  <h1 class="page-title">Dragon of Icespire Peak</h1>
  <div class="prose">
    <p>
      Session recaps, a running summary of the story so far, the party roster, an NPC
      directory, and a codex of factions and lore — kept by the party, for the party.
    </p>
  </div>

  {
    latest ? (
      <section style="margin-top: var(--space-7);">
        <div class="kicker">Latest recap</div>
        <div class="recap-feed" style="margin-top: var(--space-3);">
          <SessionRecapCard
            sessionNumber={latest.data.sessionNumber}
            date={latest.data.date}
            title={latest.data.title}
            excerpt={latest.data.summary}
            href={url(`/sessions/${latest.id}/`)}
          />
        </div>
      </section>
    ) : (
      <p class="prose">No sessions recorded yet. The tale has yet to begin.</p>
    )
  }
</Base>
