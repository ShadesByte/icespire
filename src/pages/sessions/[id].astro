---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import CreatureCard from '../../components/CreatureCard.astro';
import { url } from '../../utils/url';

export async function getStaticPaths() {
  const sessions = (await getCollection('sessions')).sort(
    (a, b) => a.data.sessionNumber - b.data.sessionNumber
  );
  // Drafts get pages but stay out of the prev/next chain.
  const published = sessions.filter((s) => !s.data.draft);
  return sessions.map((session) => {
    const i = published.findIndex((s) => s.id === session.id);
    return {
      params: { id: session.id },
      props: {
        session,
        prev: i > 0 ? published[i - 1] : null,
        next: i >= 0 && i < published.length - 1 ? published[i + 1] : null,
      },
    };
  });
}

const { session, prev, next } = Astro.props;
const { Content } = await render(session);
const dateStr = session.data.date.toLocaleDateString('en-US', {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
});

// The session's travels, from the same data that draws the campaign map.
const journey = (await getCollection('journey')).find(
  (j) => j.data.session === session.data.sessionNumber
);
const locations = await getCollection('locations');
const locationName = (slug: string) => locations.find((l) => l.id === slug)?.data.name ?? slug;

const hasEncounters = session.data.encounters.length > 0;
const hasJourney = journey && (journey.data.route.length > 0 || journey.data.events.length > 0);
const hasAside = hasEncounters || hasJourney;
---

<Base
  title={`Session ${session.data.sessionNumber}: ${session.data.title}`}
  description={session.data.summary}
  ogImage={`/og/sessions/${session.id}.png`}
>
  <a class="backlink" href={url('/sessions/')}>← All recaps</a>
  <div class="recap-kicker">
    Session {session.data.sessionNumber}
    <span class="date">{dateStr}</span>
  </div>
  <h1 class="session-title">{session.data.title}</h1>
  {
    session.data.playersPresent.length > 0 && (
      <p class="session-meta">At the table: {session.data.playersPresent.join(', ')}</p>
    )
  }
  <div class={`session-layout${hasAside ? '' : ' no-aside'}`}>
    <div class="prose">
      <Content />
    </div>
    {
      hasAside && (
        <aside class="session-aside">
          {hasEncounters && (
            <section class="aside-block">
              <div class="kicker">Encountered this session</div>
              <div class="aside-encounters">
                {session.data.encounters.map((encounter) => (
                  <CreatureCard
                    name={encounter.name}
                    image={url(encounter.image)}
                    note={encounter.note}
                    href={encounter.href ? url(encounter.href) : undefined}
                  />
                ))}
              </div>
            </section>
          )}
          {hasJourney && (
            <section class="aside-block card journey-card">
              <div class="kicker">The journey</div>
              {journey.data.route.length > 0 && (
                <p class="journey-route">
                  {journey.data.route.map((slug, i) => (
                    <>
                      {i > 0 && <span class="route-sep" aria-hidden="true">→</span>}
                      <a href={url(`/map/#${slug}`)}>{locationName(slug)}</a>
                    </>
                  ))}
                </p>
              )}
              {journey.data.events.length > 0 && (
                <ul class="journey-events">
                  {journey.data.events.map((event) => (
                    <li class={event.kind === 'battle' ? 'battle' : undefined}>
                      <div class="ev-title">{event.title}</div>
                      <div class="ev-place">at {locationName(event.at)}</div>
                    </li>
                  ))}
                </ul>
              )}
              <a class="journey-map-link" href={url('/map/')}>Trace it on the map →</a>
            </section>
          )}
        </aside>
      )
    }
  </div>
  <nav class="session-pager" aria-label="Session navigation">
    {
      prev ? (
        <a class="pager-link prev" href={url(`/sessions/${prev.id}/`)}>
          <span class="pager-dir">← Session {prev.data.sessionNumber}</span>
          <span class="pager-title">{prev.data.title}</span>
        </a>
      ) : (
        <span />
      )
    }
    <a class="pager-all" href={url('/sessions/')}>All recaps</a>
    {
      next ? (
        <a class="pager-link next" href={url(`/sessions/${next.id}/`)}>
          <span class="pager-dir">Session {next.data.sessionNumber} →</span>
          <span class="pager-title">{next.data.title}</span>
        </a>
      ) : (
        <span />
      )
    }
  </nav>
</Base>
