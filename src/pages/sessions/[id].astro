---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const sessions = await getCollection('sessions');
  return sessions.map((session) => ({ params: { id: session.id }, props: { session } }));
}

const { session } = Astro.props;
const { Content } = await render(session);
---

<Base title={`Session ${session.data.sessionNumber}: ${session.data.title}`}>
  <h1>Session {session.data.sessionNumber}: {session.data.title}</h1>
  <p class="meta">
    {session.data.date.toLocaleDateString('en-US', { dateStyle: 'long' })}
    {session.data.playersPresent.length > 0 && ` · At the table: ${session.data.playersPresent.join(', ')}`}
  </p>
  <Content />
</Base>
