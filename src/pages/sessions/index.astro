---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import SessionRecapCard from '../../components/SessionRecapCard.astro';
import { url } from '../../utils/url';

const sessions = (await getCollection('sessions', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.sessionNumber - a.data.sessionNumber
);
---

<Base title="Session Recaps" description="Recaps of every session, newest first.">
  <h1 class="page-title">Session Recaps</h1>
  {
    sessions.length === 0 ? (
      <p class="prose">No sessions yet.</p>
    ) : (
      <div class="recap-feed">
        {sessions.map((session) => (
          <SessionRecapCard
            sessionNumber={session.data.sessionNumber}
            date={session.data.date}
            title={session.data.title}
            excerpt={session.data.summary}
            href={url(`/sessions/${session.id}/`)}
            encounters={session.data.encounters.map((e) => ({
              name: e.name,
              image: url(e.image),
            }))}
          />
        ))}
      </div>
    )
  }
</Base>
