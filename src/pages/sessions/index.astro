---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { url } from '../../utils/url';

const sessions = (await getCollection('sessions', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.sessionNumber - a.data.sessionNumber
);
---

<Base title="Sessions" description="Recaps of every session, newest first.">
  <h1>Session Recaps</h1>
  {
    sessions.length === 0 ? (
      <p>No sessions yet.</p>
    ) : (
      <ul class="entry-list">
        {sessions.map((session) => (
          <li>
            <a href={url(`/sessions/${session.id}/`)}>
              Session {session.data.sessionNumber}: {session.data.title}
            </a>
            <div class="meta">
              {session.data.date.toLocaleDateString('en-US', { dateStyle: 'long' })}
            </div>
            {session.data.summary && <p>{session.data.summary}</p>}
          </li>
        ))}
      </ul>
    )
  }
</Base>
