---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import CharacterCard from '../../components/CharacterCard.astro';
import { url } from '../../utils/url';

const characters = (await getCollection('characters')).sort((a, b) =>
  a.data.name.localeCompare(b.data.name)
);
---

<Base title="Party Roster" description="The player characters of the campaign.">
  <h1 class="page-title">Party Roster</h1>
  {
    characters.length === 0 ? (
      <p class="prose">No characters yet.</p>
    ) : (
      <div class="roster-grid">
        {characters.map((character) => (
          <CharacterCard
            name={character.data.name}
            player={character.data.player}
            classRace={`${character.data.ancestry} ${character.data.class}`}
            portrait={character.data.portrait ? url(character.data.portrait) : undefined}
            bio={character.data.tagline}
            traits={character.data.traits}
            href={url(`/characters/${character.id}/`)}
            variant="roster"
          />
        ))}
      </div>
    )
  }
</Base>
