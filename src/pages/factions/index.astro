---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { url } from '../../utils/url';

const factions = (await getCollection('factions')).sort((a, b) =>
  a.data.name.localeCompare(b.data.name)
);
---

<Base title="Factions" description="The powers at play in the campaign.">
  <h1>Factions</h1>
  {
    factions.length === 0 ? (
      <p>No factions recorded yet.</p>
    ) : (
      <ul class="entry-list">
        {factions.map((faction) => (
          <li>
            <a href={url(`/factions/${faction.id}/`)}>{faction.data.name}</a>
            <div class="meta">
              {[faction.data.type, faction.data.alignment, faction.data.status]
                .filter(Boolean)
                .join(' · ')}
            </div>
            {faction.data.summary && <p>{faction.data.summary}</p>}
          </li>
        ))}
      </ul>
    )
  }
</Base>
