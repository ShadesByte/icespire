---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import MapTerrain from '../../components/map/MapTerrain.astro';
import { submaps } from '../../components/map/submaps/registry';
import { url } from '../../utils/url';

// Undiscovered locations exist in the collection but render nowhere.
const locations = (await getCollection('locations'))
  .filter((loc) => loc.data.status !== 'unknown')
  .sort((a, b) => a.data.name.localeCompare(b.data.name));
const journey = (await getCollection('journey')).sort((a, b) => a.data.session - b.data.session);
const sessions = await getCollection('sessions');
const loreEntries = await getCollection('lore');
const factionEntries = await getCollection('factions');

const locBySlug = new Map(locations.map((loc) => [loc.id, loc]));
const sessionIdByNumber = new Map(sessions.map((s) => [s.data.sessionNumber, s.id]));

function requireLoc(slug: string, context: string) {
  const loc = locBySlug.get(slug);
  if (!loc) throw new Error(`Map: unknown location slug "${slug}" in ${context}`);
  return loc;
}

// ---- Party route, drawn chronologically: every traversal of a stretch is
// its own gently-bowed arc, so an out-and-back trip renders as two parallel
// curves with opposing chevrons — the journey reads in story order.
// Later sessions draw brighter; the newest leg is the boldest.
interface Traversal {
  d: string;
  midX: number;
  midY: number;
  tagX: number;
  tagY: number;
  angle: number;
  session: number;
  opacity: number;
  latest: boolean;
}

const repCount = new Map<string, number>();
const routeSessions = journey
  .filter((leg) => leg.data.route.length > 1)
  .map((leg) => leg.data.session);
const lastRouteSession = routeSessions[routeSessions.length - 1] ?? 0;
const rankDenom = Math.max(1, routeSessions.length - 1);
const traversals: Traversal[] = [];

for (const leg of journey) {
  const stops = leg.data.route.map((slug) =>
    requireLoc(slug, `journey session ${leg.data.session} route`)
  );
  for (let i = 0; i < stops.length - 1; i++) {
    const a = stops[i];
    const b = stops[i + 1];
    const key = [a.id, b.id].sort().join('|');
    const rep = repCount.get(key) ?? 0;
    repCount.set(key, rep + 1);

    const dx = b.data.x - a.data.x;
    const dy = b.data.y - a.data.y;
    const len = Math.hypot(dx, dy) || 1;
    // First pass bows one way, the return trip the other, a third pass bows
    // wider — computed against a canonical orientation so the sides hold no
    // matter which way the party walked it.
    const orient = a.id < b.id ? 1 : -1;
    const side = rep === 0 ? 1 : rep === 1 ? -1 : 1.9;
    const bow = Math.min(0.13 * len, 16) * side * orient;
    const cx = (a.data.x + b.data.x) / 2 - (dy / len) * bow;
    const cy = (a.data.y + b.data.y) / 2 + (dx / len) * bow;

    const midX = 0.25 * a.data.x + 0.5 * cx + 0.25 * b.data.x;
    const midY = 0.25 * a.data.y + 0.5 * cy + 0.25 * b.data.y;
    const chordMidX = (a.data.x + b.data.x) / 2;
    const chordMidY = (a.data.y + b.data.y) / 2;
    let tagX = midX + (midX - chordMidX) * 2.4;
    let tagY = midY + (midY - chordMidY) * 2.4;
    if (Math.abs(midX - chordMidX) < 1 && Math.abs(midY - chordMidY) < 1) tagY -= 11;

    const rank = routeSessions.indexOf(leg.data.session);
    traversals.push({
      d: `M ${a.data.x} ${a.data.y} Q ${cx.toFixed(1)} ${cy.toFixed(1)} ${b.data.x} ${b.data.y}`,
      midX,
      midY,
      tagX,
      tagY,
      angle: (Math.atan2(dy, dx) * 180) / Math.PI,
      session: leg.data.session,
      opacity: 0.4 + 0.6 * (rank / rankDenom),
      latest: leg.data.session === lastRouteSession,
    });
  }
}

// Where the party currently stands: the last stop of the latest session
// that recorded any travel.
const latestLeg = [...journey].reverse().find((leg) => leg.data.route.length > 0);
const currentLocation = latestLeg
  ? requireLoc(
      latestLeg.data.route[latestLeg.data.route.length - 1],
      `journey session ${latestLeg.data.session} route`
    )
  : undefined;

// ---- Events, grouped per location and pinned in a fan around the marker,
// on whichever side the label doesn't occupy.
interface MapEvent {
  session: number;
  title: string;
  note?: string;
  kind: 'battle' | 'discovery' | 'social' | 'omen';
}
const eventsByLoc = new Map<string, MapEvent[]>();
for (const leg of journey) {
  for (const ev of leg.data.events) {
    requireLoc(ev.at, `journey session ${leg.data.session} events`);
    const list = eventsByLoc.get(ev.at) ?? [];
    list.push({ session: leg.data.session, title: ev.title, note: ev.note, kind: ev.kind });
    eventsByLoc.set(ev.at, list);
  }
}
for (const list of eventsByLoc.values()) list.sort((a, b) => a.session - b.session);

// Pin fan angles (degrees; 0 = east, 90 = south) keyed by label placement.
const pinSlots: Record<string, number[]> = {
  bottom: [-90, -25, -155, 35],
  top: [90, 25, 155, -35],
  right: [-135, -90, 180, 90],
  left: [-45, -90, 0, 90],
};

const kindLabels: Record<string, string> = {
  town: 'Town',
  settlement: 'Settlement',
  landmark: 'Landmark',
  dungeon: 'Ruin',
  camp: 'Camp',
  lair: 'Lair',
};
const statusLabels: Record<string, string> = {
  visited: 'Visited',
  known: 'Sighted',
  rumored: 'Rumored',
};
const labelOffsets: Record<string, { x: number; y: number; anchor: string }> = {
  top: { x: 0, y: -17, anchor: 'middle' },
  bottom: { x: 0, y: 25, anchor: 'middle' },
  left: { x: -15, y: 5, anchor: 'end' },
  right: { x: 15, y: 5, anchor: 'start' },
};

// ---- Assemble everything each marker/panel needs, including the rendered
// Markdown body for the detail panel.
const entries = await Promise.all(
  locations.map(async (loc) => {
    if (loc.data.lore && !loreEntries.some((e) => e.id === loc.data.lore)) {
      throw new Error(`Map: location "${loc.id}" links unknown lore entry "${loc.data.lore}"`);
    }
    const faction = loc.data.faction
      ? factionEntries.find((f) => f.id === loc.data.faction)
      : undefined;
    if (loc.data.faction && !faction) {
      throw new Error(`Map: location "${loc.id}" links unknown faction "${loc.data.faction}"`);
    }
    const events = eventsByLoc.get(loc.id) ?? [];
    // Local maps only surface once the party has actually been there.
    const hasLocalMap = loc.data.status === 'visited' && loc.id in submaps;
    const slots = pinSlots[loc.data.labelPlacement];
    const pins = events.map((ev, i) => {
      const angle = (slots[i % slots.length] * Math.PI) / 180;
      const radius = 27 + Math.floor(i / slots.length) * 16;
      return {
        ...ev,
        x: loc.data.x + Math.cos(angle) * radius,
        y: loc.data.y + Math.sin(angle) * radius,
        tickX1: loc.data.x + Math.cos(angle) * 10,
        tickY1: loc.data.y + Math.sin(angle) * 10,
        tickX2: loc.data.x + Math.cos(angle) * (radius - 9),
        tickY2: loc.data.y + Math.sin(angle) * (radius - 9),
      };
    });
    const { Content } = await render(loc);
    return { loc, Content, events, pins, faction, hasLocalMap };
  })
);

// ---- The journey as a plain, tappable list. The map paints the shape of the
// story; this reads it out session by session, so nothing depends on landing
// a finger on a tiny marker — the reliable path on a phone.
const eventKindLabels: Record<string, string> = {
  battle: 'Battle',
  discovery: 'Discovery',
  social: 'Encounter',
  omen: 'Omen',
};
const journeySteps = journey
  .filter((leg) => leg.data.route.length > 0 || leg.data.events.length > 0)
  .sort((a, b) => a.data.session - b.data.session)
  .map((leg) => ({
    session: leg.data.session,
    sessionId: sessionIdByNumber.get(leg.data.session),
    stops: leg.data.route.map((slug) => ({
      slug,
      name: locBySlug.get(slug)?.data.name ?? slug,
    })),
    events: leg.data.events.map((ev) => ({
      title: ev.title,
      kind: ev.kind,
      at: ev.at,
      atName: locBySlug.get(ev.at)?.data.name ?? ev.at,
    })),
  }));

// ---- Time-scrubber. The map holds the whole campaign at once; the scrubber
// winds it back and lets a reader watch the journey reveal itself session by
// session — trail, tags, event pins and markers each keyed to the session
// they first appear.
const sessionTitle = new Map(sessions.map((s) => [s.data.sessionNumber, s.data.title]));

// Earliest session each location enters the story, via a route stop or an
// event. Places only ever heard about — never travelled or fought at — have no
// journey session and stay on the map throughout, as ambient world context.
const revealBySlug = new Map<string, number>();
function markReveal(slug: string, session: number) {
  const cur = revealBySlug.get(slug);
  if (cur === undefined || session < cur) revealBySlug.set(slug, session);
}
for (const leg of journey) {
  for (const slug of leg.data.route) markReveal(slug, leg.data.session);
  for (const ev of leg.data.events) markReveal(ev.at, leg.data.session);
}

// The ordered rungs of the scrubber: every session that moved the party or
// recorded an event. Each rung carries where the party stands at that point
// (the last stop travelled up to and including it) so the "here" beacon walks
// the trail as you scrub. A session with events but no travel (session 3)
// leaves the beacon where the last leg left it.
interface ScrubRung {
  session: number;
  title?: string;
  route: string;
  hereX?: number;
  hereY?: number;
}
const scrubSessions: ScrubRung[] = [];
let runningHere: { x: number; y: number } | undefined;
for (const leg of journey) {
  if (leg.data.route.length > 0) {
    const last = requireLoc(
      leg.data.route[leg.data.route.length - 1],
      `journey session ${leg.data.session} route`
    );
    runningHere = { x: last.data.x, y: last.data.y };
  }
  if (leg.data.route.length > 0 || leg.data.events.length > 0) {
    scrubSessions.push({
      session: leg.data.session,
      title: sessionTitle.get(leg.data.session),
      route: leg.data.route.map((slug) => locBySlug.get(slug)?.data.name ?? slug).join(' → '),
      hereX: runningHere?.x,
      hereY: runningHere?.y,
    });
  }
}
---

<Base title="Campaign Map" description="The Phandalin region: where the party has gone and what happened there.">
  <div class="kicker">The lands so far</div>
  <h1 class="page-title">Campaign Map</h1>

  <div class="map-layout">
    <div class="map-main">
    {scrubSessions.length > 1 && (
      <div class="map-scrubber" id="map-scrubber">
        <button type="button" class="scrub-play" id="scrub-play" aria-label="Play the journey" aria-pressed="false">
          <span class="scrub-play-icon" aria-hidden="true">▶</span>
        </button>
        <div class="scrub-body">
          <input
            type="range"
            class="scrub-range"
            id="scrub-range"
            min="0"
            max={scrubSessions.length - 1}
            value={scrubSessions.length - 1}
            step="1"
            aria-label="Replay the campaign session by session"
          />
          <div class="scrub-readout" id="scrub-readout" aria-live="polite"></div>
        </div>
      </div>
      <script is:inline type="application/json" id="scrub-data" set:html={JSON.stringify(scrubSessions)} />
    )}
    <div class="map-frame" id="map-frame">
      <svg
        class="map-svg"
        id="map-svg"
        viewBox="0 0 1000 750"
        role="group"
        aria-label="Map of the Phandalin region with campaign locations"
      >
        <MapTerrain />

        <g class="map-route" aria-hidden="true">
          {traversals.map((t) => (
            <g
              class:list={['map-route-leg', { latest: t.latest }]}
              style={`opacity:${t.opacity.toFixed(2)}`}
              data-session={t.session}
            >
              <path class="leg" d={t.d} />
              <path
                class="map-route-chevron map-cscale"
                d="M -5 -4.5 L 4 0 L -5 4.5"
                transform={`translate(${t.midX.toFixed(1)} ${t.midY.toFixed(1)}) rotate(${t.angle.toFixed(1)})`}
              />
            </g>
          ))}
        </g>
        <g class="map-route-tags" aria-hidden="true">
          {traversals.map((t) => (
            <text
              class="map-cscale"
              transform={`translate(${t.tagX.toFixed(1)} ${t.tagY.toFixed(1)})`}
              data-session={t.session}
            >
              S{t.session}
            </text>
          ))}
        </g>

        {
          currentLocation && (
            <g
              id="map-here-anchor"
              transform={`translate(${currentLocation.data.x} ${currentLocation.data.y})`}
              aria-hidden="true"
            >
              <g class="map-here map-cscale">
                <circle class="here-pulse" r="13" />
                <circle class="here-ring" r="11" />
              </g>
            </g>
          )
        }

        {
          entries.map(({ loc, pins }) => (
            <g class="map-pin-group" data-loc={loc.id}>
              {pins.map((pin) => (
                <>
                  <line
                    class="map-pin-tick"
                    x1={pin.tickX1}
                    y1={pin.tickY1}
                    x2={pin.tickX2}
                    y2={pin.tickY2}
                    data-session={pin.session}
                  />
                  <g
                    class:list={['map-pin', 'map-cscale', { battle: pin.kind === 'battle' }]}
                    transform={`translate(${pin.x.toFixed(1)} ${pin.y.toFixed(1)})`}
                    data-session={pin.session}
                    data-open={loc.id}
                    data-tip-title={pin.title}
                    data-tip-sub={`Session ${pin.session}`}
                    tabindex="0"
                    role="button"
                    aria-label={`${pin.title} — Session ${pin.session}`}
                  >
                    <circle class="hit" r="12" />
                    <rect x="-6.5" y="-6.5" width="13" height="13" transform="rotate(45)" />
                    <text>{pin.session}</text>
                  </g>
                </>
              ))}
            </g>
          ))
        }

        {
          entries.map(({ loc }) => {
            // Towns anchor the map; camps and other footnotes stay small so
            // the busy stretches read cleanly.
            const r = loc.data.kind === 'town' ? 8.5 : loc.data.kind === 'camp' ? 5.5 : 7;
            return (
              <g
                class:list={[
                  'map-marker',
                  'map-cscale',
                  `s-${loc.data.status}`,
                  { danger: loc.data.danger, minor: loc.data.kind === 'camp' },
                ]}
                transform={`translate(${loc.data.x} ${loc.data.y})`}
                data-open={loc.id}
                data-slug={loc.id}
                data-reveal={revealBySlug.get(loc.id)}
                data-tip-title={loc.data.name}
                data-tip-sub={`${kindLabels[loc.data.kind]} · ${statusLabels[loc.data.status]}`}
                tabindex="0"
                role="button"
                aria-label={`${loc.data.name} — ${kindLabels[loc.data.kind]}, ${statusLabels[loc.data.status]}`}
              >
                <circle class="hit" r={r + 10} />
                <circle class="ring" r={r + 5.5} />
                <circle class="dot" r={r} />
                <text
                  class="map-label"
                  x={labelOffsets[loc.data.labelPlacement].x}
                  y={labelOffsets[loc.data.labelPlacement].y}
                  text-anchor={labelOffsets[loc.data.labelPlacement].anchor}
                >
                  {loc.data.name}
                </text>
              </g>
            );
          })
        }
      </svg>

      <div class="map-controls">
        <button type="button" id="map-zoom-in" aria-label="Zoom in">+</button>
        <button type="button" id="map-zoom-out" aria-label="Zoom out">−</button>
        <button type="button" id="map-zoom-reset" aria-label="Reset view">⌂</button>
      </div>
      <div class="map-tooltip" id="map-tooltip" hidden>
        <div class="tip-title"></div>
        <div class="tip-sub"></div>
      </div>
      <div class="map-zoom-note" aria-hidden="true">Tap a place to reveal what happened there</div>
    </div>

    {
      entries.some((e) => e.hasLocalMap) && (
        <nav class="map-quicklinks" aria-label="Local maps">
          <span class="ql-label">Local maps</span>
          {entries
            .filter((e) => e.hasLocalMap)
            .map(({ loc }) => (
              <a href={url(`/map/${loc.id}/`)}>{loc.data.name}</a>
            ))}
        </nav>
      )
    }

    <section class="map-journey" aria-label="The journey so far">
      <div class="kicker">The journey so far</div>
      <ol class="mj-list">
        {journeySteps.map((step) => (
          <li class="mj-leg" data-session={step.session}>
            <div class="mj-leg-head">
              {step.sessionId ? (
                <a href={url(`/sessions/${step.sessionId}/`)}>Session {step.session}</a>
              ) : (
                <span>Session {step.session}</span>
              )}
            </div>
            {step.stops.length > 0 && (
              <p class="mj-route">
                {step.stops.map((s, i) => (
                  <>
                    {i > 0 && <span class="mj-arrow" aria-hidden="true">→</span>}
                    <button type="button" class="mj-place" data-goto={s.slug}>
                      {s.name}
                    </button>
                  </>
                ))}
              </p>
            )}
            {step.events.length > 0 && (
              <ul class="mj-events">
                {step.events.map((ev) => (
                  <li class:list={['mj-event', ev.kind]}>
                    <span class="mj-event-kind">{eventKindLabels[ev.kind]}</span>
                    <button type="button" class="mj-place mj-event-title" data-goto={ev.at}>
                      {ev.title}
                    </button>
                    <span class="mj-at">{ev.atName}</span>
                  </li>
                ))}
              </ul>
            )}
          </li>
        ))}
      </ol>
    </section>
    </div>

    <aside class="map-panel" id="map-panel" aria-live="polite">
      <div id="map-panel-home">
        <div class="kicker">Legend</div>
        <ul class="map-legend">
          <li><span class="legend-dot visited"></span> Visited by the party</li>
          <li><span class="legend-dot known"></span> Sighted, not entered</li>
          <li><span class="legend-dot rumored"></span> Only rumors, so far</li>
          <li><span class="legend-dot danger"></span> Ember means danger</li>
          <li><span class="legend-pin"></span> Event — the number is the session</li>
          <li><span class="legend-pin battle"></span> Battle</li>
          <li><span class="legend-route"></span> The party's route — chevrons point the way travelled; brighter legs are more recent, and paired arcs mean there and back</li>
          <li><span class="legend-here"></span> Where the party now stands</li>
        </ul>
        <p class="map-panel-hint">
          Select a place to read about it — what happened there, and which recaps
          tell the story. Its session events light up on the map the moment you
          choose it; zoom in to see every place's at once. Prefer to read straight
          through? The journey below the map walks it session by session.
        </p>
      </div>
      <div id="map-panel-detail" hidden></div>

      {
        entries.map(({ loc, Content, events, faction, hasLocalMap }) => (
          <template data-loc={loc.id}>
            <button class="map-panel-close" type="button" aria-label="Back to legend">
              ×
            </button>
            <div class="kicker">
              {kindLabels[loc.data.kind]} · {statusLabels[loc.data.status]}
            </div>
            <h2 class="map-panel-title">{loc.data.name}</h2>
            {loc.data.firstVisited != null && (
              <p class="map-panel-meta">
                First visited in{' '}
                {sessionIdByNumber.has(loc.data.firstVisited) ? (
                  <a href={url(`/sessions/${sessionIdByNumber.get(loc.data.firstVisited)}/`)}>
                    Session {loc.data.firstVisited}
                  </a>
                ) : (
                  `Session ${loc.data.firstVisited}`
                )}
              </p>
            )}
            <div class="prose map-panel-prose">
              <Content />
            </div>
            {(hasLocalMap || loc.data.lore || faction) && (
              <p class="map-panel-links">
                {hasLocalMap && (
                  <a class="map-btn" href={url(`/map/${loc.id}/`)}>
                    Local map →
                  </a>
                )}
                {loc.data.lore && (
                  <a href={url(`/lore/${loc.data.lore}/`)}>Codex entry →</a>
                )}
                {faction && (
                  <a href={url(`/factions/${faction.id}/`)}>Faction: {faction.data.name} →</a>
                )}
              </p>
            )}
            {events.length > 0 && (
              <>
                <h3 class="map-panel-events-title">On the record</h3>
                <ul class="map-panel-events">
                  {events.map((ev) => (
                    <li class:list={[{ battle: ev.kind === 'battle' }]}>
                      <div class="ev-head">
                        {sessionIdByNumber.has(ev.session) ? (
                          <a href={url(`/sessions/${sessionIdByNumber.get(ev.session)}/`)}>
                            Session {ev.session}
                          </a>
                        ) : (
                          <span>Session {ev.session}</span>
                        )}
                        <span class="ev-title">{ev.title}</span>
                      </div>
                      {ev.note && <p class="ev-note">{ev.note}</p>}
                    </li>
                  ))}
                </ul>
              </>
            )}
          </template>
        ))
      }
    </aside>
  </div>
</Base>

<script>
  import { initMapViewer } from '../../scripts/map-viewer';

  const svg = document.getElementById('map-svg') as unknown as SVGSVGElement;
  const frame = document.getElementById('map-frame')!;
  const tooltip = document.getElementById('map-tooltip')!;
  const panelHome = document.getElementById('map-panel-home')!;
  const panelDetail = document.getElementById('map-panel-detail')!;
  const panel = document.getElementById('map-panel')!;

  // Markers, labels, pins and tags are drawn in map coordinates, so left alone
  // they balloon as you zoom and shrink to nothing on a narrow phone. We
  // counter-scale each mark so a map unit always paints at ~TARGET_PX_PER_UNIT
  // screen pixels — a constant, legible size on every device and at every zoom.
  const TARGET_PX_PER_UNIT = 0.72;
  const cscaleEls = [...svg.querySelectorAll<SVGGraphicsElement>('.map-cscale')];
  for (const el of cscaleEls) el.dataset.base = el.getAttribute('transform') ?? '';

  let lastScale = 1;
  function applyCounterScale(scale: number) {
    lastScale = scale;
    const rect = svg.getBoundingClientRect();
    const vbW = 1000 / scale; // current viewBox width, in map units
    const pxPerUnit = rect.width / vbW || 1; // how big a map unit paints right now
    const k = Math.min(2.8, Math.max(0.14, TARGET_PX_PER_UNIT / pxPerUnit)).toFixed(3);
    for (const el of cscaleEls) {
      el.setAttribute('transform', `${el.dataset.base} scale(${k})`);
    }
  }

  const viewer = initMapViewer({
    svg,
    frame,
    tooltip,
    width: 1000,
    height: 750,
    zoomInBtn: document.getElementById('map-zoom-in'),
    zoomOutBtn: document.getElementById('map-zoom-out'),
    resetBtn: document.getElementById('map-zoom-reset'),
    // Session pins only fade in once the reader is actually looking closely —
    // at the resting zoom they'd bury the markers.
    onZoom: (scale) => {
      svg.dataset.zoom = scale >= 1.6 ? 'in' : 'out';
      applyCounterScale(scale);
    },
  });

  // The map's rendered width changes on rotate/resize; re-fit the marks so they
  // keep their target pixel size.
  let resizeRaf = 0;
  window.addEventListener('resize', () => {
    cancelAnimationFrame(resizeRaf);
    resizeRaf = requestAnimationFrame(() => applyCounterScale(lastScale));
  });

  // ---- Detail panel -----------------------------------------------------------
  function clearSelection() {
    for (const m of svg.querySelectorAll('.map-marker.selected')) m.classList.remove('selected');
    for (const g of svg.querySelectorAll('.map-pin-group.reveal')) g.classList.remove('reveal');
  }

  function closePanel() {
    panelDetail.hidden = true;
    panelDetail.innerHTML = '';
    panelHome.hidden = false;
    clearSelection();
    history.replaceState(null, '', location.pathname + location.search);
  }

  function openLocation(slug: string, scrollTo = false) {
    const tpl = panel.querySelector<HTMLTemplateElement>(`template[data-loc="${slug}"]`);
    if (!tpl) return;
    panelDetail.innerHTML = '';
    panelDetail.appendChild(tpl.content.cloneNode(true));
    panelDetail.hidden = false;
    panelHome.hidden = true;
    clearSelection();
    svg.querySelector(`.map-marker[data-slug="${slug}"]`)?.classList.add('selected');
    // Surface this place's event pins even at the resting zoom, so its
    // highlights show the moment you choose it.
    svg.querySelector(`.map-pin-group[data-loc="${slug}"]`)?.classList.add('reveal');
    history.replaceState(null, '', `#${slug}`);
    if (scrollTo && window.matchMedia('(max-width: 900px)').matches) {
      panel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }
  }

  panel.addEventListener('click', (e) => {
    if ((e.target as HTMLElement).closest('.map-panel-close')) closePanel();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !panelDetail.hidden) closePanel();
  });

  for (const el of svg.querySelectorAll<SVGGraphicsElement>('[data-open]')) {
    el.addEventListener('click', () => {
      if (viewer.wasDrag()) return; // it was a pan, not a click
      openLocation(el.dataset.open!, true);
    });
    el.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        openLocation(el.dataset.open!, true);
      }
    });
  }

  // The journey list is the no-zoom, no-tiny-target path: tapping a place or an
  // event opens it on the map and brings the map into view.
  for (const el of document.querySelectorAll<HTMLElement>('.map-journey [data-goto]')) {
    el.addEventListener('click', () => {
      openLocation(el.dataset.goto!);
      frame.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  }

  // Deep link: /map/#phandalin opens that location.
  if (location.hash.length > 1) openLocation(decodeURIComponent(location.hash.slice(1)));

  // ---- Time-scrubber ----------------------------------------------------------
  // Wind the campaign back and forth: at each rung, the trail, tags, event pins
  // and markers that belong to a later session fall away, and the "here" beacon
  // walks back down the trail. The rightmost rung is the full, present-day map.
  interface ScrubRung {
    session: number;
    title?: string;
    route: string;
    hereX?: number;
    hereY?: number;
  }
  const scrubDataEl = document.getElementById('scrub-data');
  const range = document.getElementById('scrub-range') as HTMLInputElement | null;
  const readout = document.getElementById('scrub-readout');
  const playBtn = document.getElementById('scrub-play');
  const hereAnchor = document.getElementById('map-here-anchor');

  if (scrubDataEl && range && readout && playBtn) {
    const rungs: ScrubRung[] = JSON.parse(scrubDataEl.textContent || '[]');
    const legs = [...svg.querySelectorAll<SVGGElement>('.map-route-leg[data-session]')];
    const tags = [...svg.querySelectorAll<SVGTextElement>('.map-route-tags text[data-session]')];
    const pins = [...svg.querySelectorAll<SVGElement>('.map-pin[data-session], .map-pin-tick[data-session]')];
    const markers = [...svg.querySelectorAll<SVGGElement>('.map-marker[data-reveal]')];
    const journeyLegs = [...document.querySelectorAll<HTMLElement>('.mj-leg[data-session]')];
    const lastIndex = rungs.length - 1;

    function applyScrub(index: number) {
      const rung = rungs[index];
      if (!rung) return;
      const current = rung.session;
      const isPresent = index === lastIndex;

      // Fade away anything that belongs to a session still ahead of this rung.
      const hideAfter = (els: Element[]) => {
        for (const el of els) {
          const s = Number(el.getAttribute('data-session') ?? el.getAttribute('data-reveal'));
          el.classList.toggle('scrub-off', Number.isFinite(s) && s > current);
        }
      };
      hideAfter(legs);
      hideAfter(tags);
      hideAfter(pins);
      // Markers without a reveal session (ambient, only-rumored places) carry no
      // data-reveal number and are simply never hidden.
      hideAfter(markers);

      // The newest visible leg reads boldest, so the frontier of the journey
      // stands out no matter where the scrubber rests.
      let frontier = -Infinity;
      for (const leg of legs) {
        const s = Number(leg.getAttribute('data-session'));
        if (s <= current && s > frontier) frontier = s;
      }
      for (const leg of legs) {
        leg.classList.toggle('latest', Number(leg.getAttribute('data-session')) === frontier);
      }

      // Walk the "here" beacon to where the party stands at this rung.
      if (hereAnchor && rung.hereX != null && rung.hereY != null) {
        hereAnchor.setAttribute('transform', `translate(${rung.hereX} ${rung.hereY})`);
      }

      // Sync the read-out list highlight.
      for (const el of journeyLegs) {
        el.classList.toggle('is-current', Number(el.dataset.session) === current);
      }

      readout!.innerHTML = '';
      const s = document.createElement('span');
      s.className = 'scrub-session';
      s.textContent = `Session ${current}`;
      const sub = document.createElement('span');
      sub.className = 'scrub-sub';
      sub.textContent = isPresent
        ? rung.title ?? rung.route ?? 'The present day'
        : rung.title ?? rung.route ?? '';
      readout!.append(s, sub);
      svg.classList.toggle('is-scrubbing', !isPresent);
    }

    range.addEventListener('input', () => {
      stopPlay();
      applyScrub(Number(range.value));
    });

    // ---- Replay: step through the rungs on a timer, revealing the journey.
    let playTimer = 0;
    let playing = false;
    function stopPlay() {
      if (!playing) return;
      playing = false;
      window.clearInterval(playTimer);
      playBtn!.classList.remove('playing');
      playBtn!.setAttribute('aria-pressed', 'false');
      playBtn!.setAttribute('aria-label', 'Play the journey');
    }
    function startPlay() {
      playing = true;
      playBtn!.classList.add('playing');
      playBtn!.setAttribute('aria-pressed', 'true');
      playBtn!.setAttribute('aria-label', 'Pause the journey');
      // Replaying from the end restarts at the beginning.
      if (Number(range!.value) >= lastIndex) {
        range!.value = '0';
        applyScrub(0);
      }
      playTimer = window.setInterval(() => {
        const next = Number(range!.value) + 1;
        range!.value = String(next);
        applyScrub(next);
        if (next >= lastIndex) stopPlay();
      }, 1300);
    }
    playBtn.addEventListener('click', () => (playing ? stopPlay() : startPlay()));

    // Start fully revealed — the present-day map, identical to the static view.
    applyScrub(lastIndex);
  }
</script>
